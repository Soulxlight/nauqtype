fn parse_flag(text: str) -> result<bool, str> {
    if text == "yes" {
        return Ok(true);
    } else {
        return Err("expected yes");
    }
}

fn main() -> i32 {
    let parsed: result<bool, str> = parse_flag("yes");
    match parsed {
        Ok(value) => {
            if value {
                return 0;
            } else {
                return 1;
            }
        },
        Err(_) => {
            return 2;
        },
    }
}

