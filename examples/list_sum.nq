fn main() -> i32 {
    let mut items: list<i32> = list();
    list_push(mutref items, 40);
    list_push(mutref items, 2);
    let first: option<i32> = list_get(ref items, 0);
    match first {
        Some(value) => {
            return value + 2;
        },
        None => {
            return 0;
        },
    }
}
