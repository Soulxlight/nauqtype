fn main() -> i32 {
    let empty: list<i32> = [];
    let numbers: list<i32> = [40, 2];
    let words: list<str> = ["na", "uq"];

    let first = list_get(ref numbers, 0);
    match first {
        Some(left) => {
            let second = list_get(ref numbers, 1);
            match second {
                Some(right) => {
                    let base = left + right;
                    let with_empty = base + list_len(ref empty);
                    let with_words = with_empty + list_len(ref words);
                    return with_words - 2;
                },
                None => {
                    return 1;
                },
            }
        },
        None => {
            return 1;
        },
    }
}
