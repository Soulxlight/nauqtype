enum ParseState {
    Empty,
    Parsed(i32),
}

fn parse_small(text: str) -> result<ParseState, str> {
    if text == "" {
        return Ok(Empty);
    } else {
        return Ok(Parsed(7));
    }
}

fn main() -> i32 {
    let state: result<ParseState, str> = parse_small("seed");
    match state {
        Ok(value) => {
            match value {
                Empty => {
                    return 1;
                },
                Parsed(n) => {
                    return n;
                },
            }
        },
        Err(_) => {
            return 2;
        },
    }
}

