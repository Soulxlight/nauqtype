fn compute_fib(n: i32) -> i32 {
    if n == 0 {
        return 0;
    }
    if n == 1 {
        return 1;
    }

    let mut a = 0;
    let mut b = 1;
    let mut count = 2;

    while count < n + 1 {
        let temp = a + b;
        a = b;
        b = temp;
        count = count + 1;
    }
    return b;
}

fn main() -> i32 {
    let result = compute_fib(10);
    return result;
}
