use ast;
use diag;
use token;

fn token_at(tokens: ref list<token>, index: i32) -> token {
    let found = list_get(ref tokens, index);
    match found {
        Some(value) => {
            return value;
        },
        None => {
            return eof_token(index);
        },
    }
}

fn push_diag(diags: mutref list<diag>, file: str, tok: token, message: str) -> unit {
    list_push(mutref diags, make_diag(file, tok.start, message));
    return;
}

fn advance(cursor: mutref i32) -> unit {
    cursor = cursor + 1;
    return;
}

fn consume_ident(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str) -> token {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_ident => {
            advance(mutref cursor);
            return current;
        },
        _ => {
            push_diag(mutref diags, file, current, "expected identifier");
            return current;
        },
    }
}

fn consume_type(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, type_refs: mutref list<type_ref>, context_name: str, kind: type_ref_kind) -> unit {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_ref => {
            advance(mutref cursor);
            consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, context_name, kind);
            return;
        },
        tk_kw_mutref => {
            advance(mutref cursor);
            consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, context_name, kind);
            return;
        },
        tk_ident => {
            list_push(mutref type_refs, make_type_ref(file, context_name, current.text, current.start, kind));
            advance(mutref cursor);
            let next = token_at(ref tokens, cursor);
            match next.kind {
                tk_lt => {
                    advance(mutref cursor);
                    consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, context_name, kind);
                    let maybe_comma = token_at(ref tokens, cursor);
                    match maybe_comma.kind {
                        tk_comma => {
                            advance(mutref cursor);
                            consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, context_name, kind);
                        },
                        _ => {
                        },
                    }
                    let end = token_at(ref tokens, cursor);
                    match end.kind {
                        tk_gt => {
                            advance(mutref cursor);
                        },
                        _ => {
                            push_diag(mutref diags, file, end, "expected `>` after type arguments");
                        },
                    }
                },
                _ => {
                },
            }
            return;
        },
        _ => {
            push_diag(mutref diags, file, current, "expected type");
            return;
        },
    }
}

fn skip_until_semi(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                advance(mutref cursor);
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                advance(mutref cursor);
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
                advance(mutref cursor);
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
                advance(mutref cursor);
            },
            tk_semi => {
                if paren_depth == 0 and brace_depth == 0 {
                    advance(mutref cursor);
                    return;
                }
                advance(mutref cursor);
            },
            _ => {
                advance(mutref cursor);
            },
        }
    }
}

fn skip_until_block(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                advance(mutref cursor);
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                advance(mutref cursor);
            },
            tk_lbrace => {
                if paren_depth == 0 {
                    return;
                }
                advance(mutref cursor);
            },
            _ => {
                advance(mutref cursor);
            },
        }
    }
}

fn skip_pattern_until_arrow(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                advance(mutref cursor);
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                advance(mutref cursor);
            },
            tk_fat_arrow => {
                if paren_depth == 0 {
                    return;
                }
                advance(mutref cursor);
            },
            _ => {
                advance(mutref cursor);
            },
        }
    }
}

fn is_ident_token(tok: token) -> bool {
    match tok.kind {
        tk_ident => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_dot_token(tok: token) -> bool {
    match tok.kind {
        tk_dot => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_colon_token(tok: token) -> bool {
    match tok.kind {
        tk_colon => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_lparen_token(tok: token) -> bool {
    match tok.kind {
        tk_lparen => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_lbrace_token(tok: token) -> bool {
    match tok.kind {
        tk_lbrace => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_eq_token(tok: token) -> bool {
    match tok.kind {
        tk_eq => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn push_binding(bindings: mutref list<body_binding>, module: str, function_name: str, scope_id: i32, name: str, at: i32, kind: body_binding_kind) -> unit {
    list_push(mutref bindings, make_body_binding(module, function_name, scope_id, name, at, kind));
    return;
}

fn push_name_ref(refs: mutref list<name_ref>, module: str, function_name: str, scope_id: i32, name: str, at: i32, kind: name_ref_kind) -> unit {
    list_push(mutref refs, make_name_ref(module, function_name, scope_id, name, at, kind));
    return;
}

fn new_scope(scopes: mutref list<body_scope>, module: str, function_name: str, parent_scope_id: i32, depth: i32, next_scope_id: mutref i32) -> i32 {
    let scope_id = next_scope_id;
    next_scope_id = next_scope_id + 1;
    list_push(mutref scopes, make_body_scope(module, function_name, scope_id, parent_scope_id, depth));
    return scope_id;
}

fn scan_expr_names(tokens: ref list<token>, start: i32, end: i32, module: str, function_name: str, scope_id: i32, refs: mutref list<name_ref>) -> unit {
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_kw_ref => {
                let next = token_at(ref tokens, index + 1);
                match next.kind {
                    tk_ident => {
                        push_name_ref(mutref refs, module, function_name, scope_id, next.text, next.start, ref_borrow_target);
                        index = index + 2;
                    },
                    _ => {
                        index = index + 1;
                    },
                }
            },
            tk_kw_mutref => {
                let next = token_at(ref tokens, index + 1);
                match next.kind {
                    tk_ident => {
                        push_name_ref(mutref refs, module, function_name, scope_id, next.text, next.start, ref_borrow_target);
                        index = index + 2;
                    },
                    _ => {
                        index = index + 1;
                    },
                }
            },
            tk_ident => {
                let previous = token_at(ref tokens, index - 1);
                let next = token_at(ref tokens, index + 1);
                if is_dot_token(previous) or is_colon_token(next) {
                    index = index + 1;
                } else {
                    if is_lparen_token(next) {
                        push_name_ref(mutref refs, module, function_name, scope_id, current.text, current.start, ref_call);
                    } else {
                        if is_lbrace_token(next) and index + 1 < end {
                            push_name_ref(mutref refs, module, function_name, scope_id, current.text, current.start, ref_struct_type);
                        } else {
                            push_name_ref(mutref refs, module, function_name, scope_id, current.text, current.start, ref_value);
                        }
                    }
                    index = index + 1;
                }
            },
            _ => {
                index = index + 1;
            },
        }
    }
    return;
}

fn scan_pattern_bindings(tokens: ref list<token>, start: i32, end: i32, module: str, function_name: str, scope_id: i32, bindings: mutref list<body_binding>, refs: mutref list<name_ref>) -> unit {
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_ident => {
                let next = token_at(ref tokens, index + 1);
                if current.text != "_" {
                    if is_lparen_token(next) {
                        push_name_ref(mutref refs, module, function_name, scope_id, current.text, current.start, ref_pattern_ctor);
                    } else {
                        push_binding(mutref bindings, module, function_name, scope_id, current.text, current.start, bind_pattern);
                    }
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return;
}

fn parse_match(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, depth: i32, next_scope_id: mutref i32, scopes: mutref list<body_scope>, bindings: mutref list<body_binding>, refs: mutref list<name_ref>, type_refs: mutref list<type_ref>) -> unit {
    advance(mutref cursor);
    let expr_start = cursor;
    skip_until_block(ref tokens, mutref cursor);
    scan_expr_names(ref tokens, expr_start, cursor, file, function_name, scope_id, mutref refs);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after match expression");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated match block");
                return;
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                let arm_scope_id = new_scope(mutref scopes, file, function_name, scope_id, depth + 1, mutref next_scope_id);
                scan_pattern_bindings(ref tokens, pattern_start, cursor, file, function_name, arm_scope_id, mutref bindings, mutref refs);
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, arrow, "expected `=>` in match arm");
                        return;
                    },
                }
                parse_block(ref tokens, mutref cursor, mutref diags, file, function_name, arm_scope_id, depth + 1, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn parse_stmt(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, depth: i32, next_scope_id: mutref i32, scopes: mutref list<body_scope>, bindings: mutref list<body_binding>, refs: mutref list<name_ref>, type_refs: mutref list<type_ref>) -> unit {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_let => {
            advance(mutref cursor);
            let maybe_mut = token_at(ref tokens, cursor);
            match maybe_mut.kind {
                tk_kw_mut => {
                    advance(mutref cursor);
                },
                _ => {
                },
            }
            let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
            match name.kind {
                tk_ident => {
                    push_binding(mutref bindings, file, function_name, scope_id, name.text, name.start, bind_let);
                },
                _ => {
                },
            }
            let maybe_colon = token_at(ref tokens, cursor);
            match maybe_colon.kind {
                tk_colon => {
                    advance(mutref cursor);
                    consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, function_name, type_local_annotation);
                },
                _ => {
                },
            }
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            scan_expr_names(ref tokens, expr_start, cursor - 1, file, function_name, scope_id, mutref refs);
        },
        tk_kw_if => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            scan_expr_names(ref tokens, condition_start, cursor, file, function_name, scope_id, mutref refs);
            let then_scope_id = new_scope(mutref scopes, file, function_name, scope_id, depth + 1, mutref next_scope_id);
            parse_block(ref tokens, mutref cursor, mutref diags, file, function_name, then_scope_id, depth + 1, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
            let maybe_else = token_at(ref tokens, cursor);
            match maybe_else.kind {
                tk_kw_else => {
                    advance(mutref cursor);
                    let else_scope_id = new_scope(mutref scopes, file, function_name, scope_id, depth + 1, mutref next_scope_id);
                    parse_block(ref tokens, mutref cursor, mutref diags, file, function_name, else_scope_id, depth + 1, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
                },
                _ => {
                },
            }
        },
        tk_kw_while => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            scan_expr_names(ref tokens, condition_start, cursor, file, function_name, scope_id, mutref refs);
            let body_scope_id = new_scope(mutref scopes, file, function_name, scope_id, depth + 1, mutref next_scope_id);
            parse_block(ref tokens, mutref cursor, mutref diags, file, function_name, body_scope_id, depth + 1, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
        },
        tk_kw_match => {
            parse_match(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, depth, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
        },
        tk_kw_return => {
            advance(mutref cursor);
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            scan_expr_names(ref tokens, expr_start, cursor - 1, file, function_name, scope_id, mutref refs);
        },
        _ => {
            let next = token_at(ref tokens, cursor + 1);
            if is_ident_token(current) and is_eq_token(next) {
                push_name_ref(mutref refs, file, function_name, scope_id, current.text, current.start, ref_assign_target);
                let expr_start = cursor + 2;
                skip_until_semi(ref tokens, mutref cursor);
                scan_expr_names(ref tokens, expr_start, cursor - 1, file, function_name, scope_id, mutref refs);
            } else {
                let expr_start = cursor;
                skip_until_semi(ref tokens, mutref cursor);
                scan_expr_names(ref tokens, expr_start, cursor - 1, file, function_name, scope_id, mutref refs);
            }
        },
    }
}

fn parse_block(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, depth: i32, next_scope_id: mutref i32, scopes: mutref list<body_scope>, bindings: mutref list<body_binding>, refs: mutref list<name_ref>, type_refs: mutref list<type_ref>) -> unit {
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected block");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated block");
                return;
            },
            _ => {
                parse_stmt(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, depth, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
            },
        }
    }
}

fn parse_audit(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str) -> unit {
    let audit_tok = token_at(ref tokens, cursor);
    match audit_tok.kind {
        tk_kw_audit => {
            advance(mutref cursor);
        },
        _ => {
            return;
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after audit");
            return;
        },
    }
    skip_until_semi(ref tokens, mutref cursor);
    skip_until_semi(ref tokens, mutref cursor);
    skip_until_semi(ref tokens, mutref cursor);
    let close = token_at(ref tokens, cursor);
    match close.kind {
        tk_rbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, close, "expected `}` after audit block");
        },
    }
}

fn parse_type_decl(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, items: mutref list<top_item>, type_refs: mutref list<type_ref>, is_public: bool) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    match name.kind {
        tk_ident => {
            list_push(mutref items, make_top_item(file, name.text, item_type, is_public, name.start));
        },
        _ => {
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after type name");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated type declaration");
                return;
            },
            _ => {
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after field name");
                    },
                }
                consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, name.text, type_field);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn parse_enum_decl(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, items: mutref list<top_item>, type_refs: mutref list<type_ref>, is_public: bool) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    match name.kind {
        tk_ident => {
            list_push(mutref items, make_top_item(file, name.text, item_enum, is_public, name.start));
        },
        _ => {
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after enum name");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated enum declaration");
                return;
            },
            _ => {
                let variant = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                match variant.kind {
                    tk_ident => {
                        list_push(mutref items, make_top_item(file, variant.text, item_variant, is_public, variant.start));
                    },
                    _ => {
                    },
                }
                let maybe_lparen = token_at(ref tokens, cursor);
                match maybe_lparen.kind {
                    tk_lparen => {
                        advance(mutref cursor);
                        consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, name.text, type_enum_payload);
                        let maybe_comma = token_at(ref tokens, cursor);
                        match maybe_comma.kind {
                            tk_comma => {
                                advance(mutref cursor);
                                consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, name.text, type_enum_payload);
                            },
                            _ => {
                            },
                        }
                        let end = token_at(ref tokens, cursor);
                        match end.kind {
                            tk_rparen => {
                                advance(mutref cursor);
                            },
                            _ => {
                                push_diag(mutref diags, file, end, "expected `)` after enum payloads");
                            },
                        }
                    },
                    _ => {
                    },
                }
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn parse_function(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, items: mutref list<top_item>, scopes: mutref list<body_scope>, bindings: mutref list<body_binding>, refs: mutref list<name_ref>, type_refs: mutref list<type_ref>, is_public: bool) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut function_name = "";
    match name.kind {
        tk_ident => {
            function_name = name.text;
            list_push(mutref items, make_top_item(file, function_name, item_fn, is_public, name.start));
        },
        _ => {
        },
    }
    let mut next_scope_id = 1;
    let root_scope_id = new_scope(mutref scopes, file, function_name, -1, 0, mutref next_scope_id);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lparen => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `(` after function name");
            return;
        },
    }
    let mut scanning_params = true;
    while scanning_params {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rparen => {
                advance(mutref cursor);
                scanning_params = false;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated parameter list");
                return;
            },
            tk_ident => {
                let param_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                match param_name.kind {
                    tk_ident => {
                        push_binding(mutref bindings, file, function_name, root_scope_id, param_name.text, param_name.start, bind_param);
                    },
                    _ => {
                    },
                }
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after parameter name");
                    },
                }
                consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, function_name, type_param);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
            _ => {
                push_diag(mutref diags, file, current, "expected parameter or `)`");
                advance(mutref cursor);
            },
        }
    }
    let arrow = token_at(ref tokens, cursor);
    match arrow.kind {
        tk_arrow => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, arrow, "expected `->` after parameter list");
        },
    }
    consume_type(ref tokens, mutref cursor, mutref diags, file, mutref type_refs, function_name, type_return);
    parse_audit(ref tokens, mutref cursor, mutref diags, file);
    parse_block(ref tokens, mutref cursor, mutref diags, file, function_name, root_scope_id, 0, mutref next_scope_id, mutref scopes, mutref bindings, mutref refs, mutref type_refs);
}

pub fn extract_uses(tokens: ref list<token>) -> list<str>
audit {
    intent("Extract leading flat-root use declarations from a token stream");
    mutates();
    effects();
}
{
    let mut result: list<str> = list();
    let mut cursor = 0;
    let mut scanning = true;
    while scanning {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_kw_use => {
                advance(mutref cursor);
                let name = token_at(ref tokens, cursor);
                match name.kind {
                    tk_ident => {
                        list_push(mutref result, name.text);
                        advance(mutref cursor);
                    },
                    _ => {
                        scanning = false;
                    },
                }
                let end = token_at(ref tokens, cursor);
                match end.kind {
                    tk_semi => {
                        advance(mutref cursor);
                    },
                    _ => {
                        scanning = false;
                    },
                }
            },
            _ => {
                scanning = false;
            },
        }
    }
    return result;
}

pub fn parse_file(file: str, tokens: ref list<token>, items: mutref list<top_item>, uses: mutref list<module_use>, scopes: mutref list<body_scope>, bindings: mutref list<body_binding>, refs: mutref list<name_ref>, type_refs: mutref list<type_ref>, diags: mutref list<diag>) -> parse_summary
audit {
    intent("Parse a shallow current-syntax Nauqtype module into flat top-level, type, and body summaries");
    mutates(items, uses, scopes, bindings, refs, type_refs, diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let mut cursor = 0;
    let mut item_count = 0;
    let mut use_count = 0;
    let mut scanning_uses = true;

    while scanning_uses {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_kw_use => {
                advance(mutref cursor);
                let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                match name.kind {
                    tk_ident => {
                        list_push(mutref uses, make_module_use(file, name.text, name.start));
                        use_count = use_count + 1;
                    },
                    _ => {
                    },
                }
                let semi = token_at(ref tokens, cursor);
                match semi.kind {
                    tk_semi => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, semi, "expected `;` after use declaration");
                    },
                }
            },
            _ => {
                scanning_uses = false;
            },
        }
    }

    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return make_parse_summary(item_count, use_count, list_len(ref diags) - start_diag_count);
            },
            tk_kw_pub => {
                advance(mutref cursor);
                let next = token_at(ref tokens, cursor);
                match next.kind {
                    tk_kw_fn => {
                        parse_function(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref scopes, mutref bindings, mutref refs, mutref type_refs, true);
                        item_count = item_count + 1;
                    },
                    tk_kw_type => {
                        parse_type_decl(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref type_refs, true);
                        item_count = item_count + 1;
                    },
                    tk_kw_enum => {
                        parse_enum_decl(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref type_refs, true);
                        item_count = item_count + 1;
                    },
                    _ => {
                        push_diag(mutref diags, file, next, "expected fn, type, or enum after pub");
                        advance(mutref cursor);
                    },
                }
            },
            tk_kw_fn => {
                parse_function(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref scopes, mutref bindings, mutref refs, mutref type_refs, false);
                item_count = item_count + 1;
            },
            tk_kw_type => {
                parse_type_decl(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref type_refs, false);
                item_count = item_count + 1;
            },
            tk_kw_enum => {
                parse_enum_decl(ref tokens, mutref cursor, mutref diags, file, mutref items, mutref type_refs, false);
                item_count = item_count + 1;
            },
            _ => {
                push_diag(mutref diags, file, current, "expected top-level item");
                advance(mutref cursor);
            },
        }
    }
}

fn count_comma_args(tokens: ref list<token>, open_index: i32) -> i32 {
    let mut index = open_index + 1;
    let first = token_at(ref tokens, index);
    match first.kind {
        tk_rparen => {
            return 0;
        },
        _ => {
        },
    }

    let mut count = 1;
    let mut paren_depth = 0;
    let mut brace_depth = 0;

    while true {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_eof => {
                return count;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
            },
            tk_rparen => {
                if paren_depth == 0 {
                    return count;
                }
                paren_depth = paren_depth - 1;
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_comma => {
                if paren_depth == 0 and brace_depth == 0 {
                    count = count + 1;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
}

type parsed_type_shape {
    head: str,
    arg1_name: str,
    arg2_name: str,
}

fn make_parsed_type_shape(head: str, arg1_name: str, arg2_name: str) -> parsed_type_shape {
    return parsed_type_shape {
        head: head,
        arg1_name: arg1_name,
        arg2_name: arg2_name,
    };
}

fn consume_type_shape(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str) -> parsed_type_shape {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_ref => {
            advance(mutref cursor);
            return consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
        },
        tk_kw_mutref => {
            advance(mutref cursor);
            return consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
        },
        tk_ident => {
            let head = current.text;
            let mut arg1_name = "";
            let mut arg2_name = "";
            advance(mutref cursor);
            let next = token_at(ref tokens, cursor);
            match next.kind {
                tk_lt => {
                    advance(mutref cursor);
                    let first_arg = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                    arg1_name = first_arg.head;
                    let maybe_comma = token_at(ref tokens, cursor);
                    match maybe_comma.kind {
                        tk_comma => {
                            advance(mutref cursor);
                            let second_arg = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                            arg2_name = second_arg.head;
                        },
                        _ => {
                        },
                    }
                    let end = token_at(ref tokens, cursor);
                    match end.kind {
                        tk_gt => {
                            advance(mutref cursor);
                        },
                        _ => {
                            push_diag(mutref diags, file, end, "expected `>` after type arguments");
                        },
                    }
                },
                _ => {
                },
            }
            return make_parsed_type_shape(head, arg1_name, arg2_name);
        },
        _ => {
            push_diag(mutref diags, file, current, "expected type");
            return make_parsed_type_shape("", "", "");
        },
    }
}

fn consume_type_name(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str) -> str {
    let parsed = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
    return parsed.head;
}

fn scan_expr_calls(tokens: ref list<token>, start: i32, end: i32, module: str, function_name: str, calls: mutref list<call_fact>) -> unit {
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_ident => {
                let previous = token_at(ref tokens, index - 1);
                let next = token_at(ref tokens, index + 1);
                if is_dot_token(previous) or is_colon_token(next) {
                } else {
                    if is_lparen_token(next) {
                        let arg_count = count_comma_args(ref tokens, index + 1);
                        list_push(mutref calls, make_call_fact(module, function_name, current.text, current.start, arg_count));
                    }
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return;
}

fn scan_pattern_ctor_facts(tokens: ref list<token>, start: i32, end: i32, module: str, function_name: str, patterns: mutref list<pattern_ctor_fact>) -> unit {
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_ident => {
                let next = token_at(ref tokens, index + 1);
                if current.text != "_" and is_lparen_token(next) {
                    let arg_count = count_comma_args(ref tokens, index + 1);
                    list_push(mutref patterns, make_pattern_ctor_fact(module, function_name, current.text, current.start, arg_count));
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return;
}

fn collect_match_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, calls: mutref list<call_fact>, patterns: mutref list<pattern_ctor_fact>) -> unit {
    advance(mutref cursor);
    let expr_start = cursor;
    skip_until_block(ref tokens, mutref cursor);
    scan_expr_calls(ref tokens, expr_start, cursor, file, function_name, mutref calls);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after match expression");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated match block");
                return;
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                scan_pattern_ctor_facts(ref tokens, pattern_start, cursor, file, function_name, mutref patterns);
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, arrow, "expected `=>` in match arm");
                        return;
                    },
                }
                collect_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_typecheck_stmt_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, calls: mutref list<call_fact>, patterns: mutref list<pattern_ctor_fact>) -> unit {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_let => {
            advance(mutref cursor);
            let maybe_mut = token_at(ref tokens, cursor);
            match maybe_mut.kind {
                tk_kw_mut => {
                    advance(mutref cursor);
                },
                _ => {
                },
            }
            consume_ident(ref tokens, mutref cursor, mutref diags, file);
            let maybe_colon = token_at(ref tokens, cursor);
            match maybe_colon.kind {
                tk_colon => {
                    advance(mutref cursor);
                    consume_type_name(ref tokens, mutref cursor, mutref diags, file);
                },
                _ => {
                },
            }
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            scan_expr_calls(ref tokens, expr_start, cursor - 1, file, function_name, mutref calls);
        },
        tk_kw_if => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            scan_expr_calls(ref tokens, condition_start, cursor, file, function_name, mutref calls);
            collect_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
            let maybe_else = token_at(ref tokens, cursor);
            match maybe_else.kind {
                tk_kw_else => {
                    advance(mutref cursor);
                    collect_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
                },
                _ => {
                },
            }
        },
        tk_kw_while => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            scan_expr_calls(ref tokens, condition_start, cursor, file, function_name, mutref calls);
            collect_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
        },
        tk_kw_match => {
            collect_match_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
        },
        tk_kw_return => {
            advance(mutref cursor);
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            scan_expr_calls(ref tokens, expr_start, cursor - 1, file, function_name, mutref calls);
        },
        _ => {
            let next = token_at(ref tokens, cursor + 1);
            if is_ident_token(current) and is_eq_token(next) {
                let expr_start = cursor + 2;
                skip_until_semi(ref tokens, mutref cursor);
                scan_expr_calls(ref tokens, expr_start, cursor - 1, file, function_name, mutref calls);
            } else {
                let expr_start = cursor;
                skip_until_semi(ref tokens, mutref cursor);
                scan_expr_calls(ref tokens, expr_start, cursor - 1, file, function_name, mutref calls);
            }
        },
    }
}

fn collect_block_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, calls: mutref list<call_fact>, patterns: mutref list<pattern_ctor_fact>) -> unit {
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected block");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated block");
                return;
            },
            _ => {
                collect_typecheck_stmt_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
            },
        }
    }
}

fn collect_type_decl_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str) -> unit {
    advance(mutref cursor);
    consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after type name");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated type declaration");
                return;
            },
            _ => {
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after field name");
                    },
                }
                consume_type_name(ref tokens, mutref cursor, mutref diags, file);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_value_type_decl_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, field_facts: mutref list<field_fact>) -> unit {
    advance(mutref cursor);
    let type_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut type_name_text = "";
    match type_name.kind {
        tk_ident => {
            type_name_text = type_name.text;
        },
        _ => {
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after type name");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated type declaration");
                return;
            },
            _ => {
                let field_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let mut field_name_text = "";
                let mut field_at = current.start;
                match field_name.kind {
                    tk_ident => {
                        field_name_text = field_name.text;
                        field_at = field_name.start;
                    },
                    _ => {
                    },
                }
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after field name");
                    },
                }
                let field_type = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                let field_type_name = field_type.head;
                if type_name_text != "" and field_name_text != "" and field_type_name != "" {
                    list_push(mutref field_facts, make_field_fact(file, type_name_text, field_name_text, field_at, field_type_name, field_type.arg1_name, field_type.arg2_name));
                }
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_enum_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, variants: mutref list<variant_fact>, variant_payloads: mutref list<variant_payload_fact>) -> unit {
    advance(mutref cursor);
    let enum_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut enum_name_text = "";
    match enum_name.kind {
        tk_ident => {
            enum_name_text = enum_name.text;
        },
        _ => {
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after enum name");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated enum declaration");
                return;
            },
            _ => {
                let variant = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let mut variant_name_text = "";
                let mut variant_at = 0;
                match variant.kind {
                    tk_ident => {
                        variant_name_text = variant.text;
                        variant_at = variant.start;
                    },
                    _ => {
                    },
                }
                let mut payload_count = 0;
                let maybe_lparen = token_at(ref tokens, cursor);
                match maybe_lparen.kind {
                    tk_lparen => {
                        advance(mutref cursor);
                        let mut payload_index = 0;
                        let first_type = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                        if variant_name_text != "" and first_type.head != "" {
                            list_push(mutref variant_payloads, make_variant_payload_fact(file, variant_name_text, payload_index, variant_at, first_type.head, first_type.arg1_name, first_type.arg2_name));
                        }
                        payload_count = payload_count + 1;
                        payload_index = payload_index + 1;
                        let mut scanning_payloads = true;
                        while scanning_payloads {
                            let maybe_comma = token_at(ref tokens, cursor);
                            match maybe_comma.kind {
                                tk_comma => {
                                    advance(mutref cursor);
                                    let next_type = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                                    if variant_name_text != "" and next_type.head != "" {
                                        list_push(mutref variant_payloads, make_variant_payload_fact(file, variant_name_text, payload_index, variant_at, next_type.head, next_type.arg1_name, next_type.arg2_name));
                                    }
                                    payload_count = payload_count + 1;
                                    payload_index = payload_index + 1;
                                },
                                _ => {
                                    scanning_payloads = false;
                                },
                            }
                        }
                        let end = token_at(ref tokens, cursor);
                        match end.kind {
                            tk_rparen => {
                                advance(mutref cursor);
                            },
                            _ => {
                                push_diag(mutref diags, file, end, "expected `)` after enum payloads");
                            },
                        }
                    },
                    _ => {
                    },
                }
                if variant_name_text != "" {
                    list_push(mutref variants, make_variant_fact(file, enum_name_text, variant_name_text, variant_at, payload_count));
                }
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_function_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, functions: mutref list<function_fact>, function_params: mutref list<function_param_fact>, calls: mutref list<call_fact>, patterns: mutref list<pattern_ctor_fact>) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut function_name = "";
    let mut function_at = 0;
    match name.kind {
        tk_ident => {
            function_name = name.text;
            function_at = name.start;
        },
        _ => {
        },
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lparen => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `(` after function name");
            return;
        },
    }
    let mut param_count = 0;
    let mut param_index = 0;
    let mut scanning_params = true;
    while scanning_params {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rparen => {
                advance(mutref cursor);
                scanning_params = false;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated parameter list");
                return;
            },
            tk_ident => {
                let param_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after parameter name");
                    },
                }
                let is_borrow = type_starts_with_borrow(ref tokens, cursor);
                let type_shape = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                let type_name = type_shape.head;
                match param_name.kind {
                    tk_ident => {
                        if function_name != "" and type_name != "" {
                            list_push(mutref function_params, make_function_param_fact(file, function_name, param_index, param_name.text, param_name.start, type_name, type_shape.arg1_name, type_shape.arg2_name, is_borrow));
                        }
                    },
                    _ => {
                    },
                }
                param_count = param_count + 1;
                param_index = param_index + 1;
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
            _ => {
                push_diag(mutref diags, file, current, "expected parameter or `)`");
                advance(mutref cursor);
            },
        }
    }
    let arrow = token_at(ref tokens, cursor);
    match arrow.kind {
        tk_arrow => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, arrow, "expected `->` after parameter list");
        },
    }
    let return_current = token_at(ref tokens, cursor);
    let mut return_is_borrow = false;
    match return_current.kind {
        tk_kw_ref => {
            return_is_borrow = true;
        },
        tk_kw_mutref => {
            return_is_borrow = true;
        },
        _ => {
        },
    }
    let return_type = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
    let return_name = return_type.head;
    if function_name != "" {
        list_push(mutref functions, make_function_fact(file, function_name, function_at, param_count, return_name, return_type.arg1_name, return_type.arg2_name, return_is_borrow));
    }
    parse_audit(ref tokens, mutref cursor, mutref diags, file);
    collect_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, mutref calls, mutref patterns);
}

pub fn collect_typecheck_facts(file: str, tokens: ref list<token>, functions: mutref list<function_fact>, function_params: mutref list<function_param_fact>, variants: mutref list<variant_fact>, variant_payloads: mutref list<variant_payload_fact>, calls: mutref list<call_fact>, patterns: mutref list<pattern_ctor_fact>, diags: mutref list<diag>) -> typecheck_summary
audit {
    intent("Collect flat function, call, and pattern facts for the first selfhost type-checker slice");
    mutates(functions, function_params, variants, variant_payloads, calls, patterns, diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let start_function_count = list_len(ref functions);
    let start_call_count = list_len(ref calls);
    let start_pattern_count = list_len(ref patterns);
    let mut cursor = 0;
    let mut scanning_uses = true;

    while scanning_uses {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_kw_use => {
                advance(mutref cursor);
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let semi = token_at(ref tokens, cursor);
                match semi.kind {
                    tk_semi => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, semi, "expected `;` after use declaration");
                    },
                }
            },
            _ => {
                scanning_uses = false;
            },
        }
    }

    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return make_typecheck_summary(
                    list_len(ref functions) - start_function_count,
                    list_len(ref calls) - start_call_count,
                    list_len(ref patterns) - start_pattern_count,
                    list_len(ref diags) - start_diag_count
                );
            },
            tk_kw_pub => {
                advance(mutref cursor);
                let next = token_at(ref tokens, cursor);
                match next.kind {
                    tk_kw_fn => {
                        collect_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref functions, mutref function_params, mutref calls, mutref patterns);
                    },
                    tk_kw_type => {
                        collect_type_decl_facts(ref tokens, mutref cursor, mutref diags, file);
                    },
                    tk_kw_enum => {
                        collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref variants, mutref variant_payloads);
                    },
                    _ => {
                        push_diag(mutref diags, file, next, "expected fn, type, or enum after pub");
                        advance(mutref cursor);
                    },
                }
            },
            tk_kw_fn => {
                collect_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref functions, mutref function_params, mutref calls, mutref patterns);
            },
            tk_kw_type => {
                collect_type_decl_facts(ref tokens, mutref cursor, mutref diags, file);
            },
            tk_kw_enum => {
                collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref variants, mutref variant_payloads);
            },
            _ => {
                push_diag(mutref diags, file, current, "expected top-level item");
                advance(mutref cursor);
            },
        }
    }
}

fn next_value_scope_id(next_scope_id: mutref i32) -> i32 {
    let scope_id = next_scope_id;
    next_scope_id = next_scope_id + 1;
    return scope_id;
}

fn type_starts_with_borrow(tokens: ref list<token>, cursor: i32) -> bool {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_ref => {
            return true;
        },
        tk_kw_mutref => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn normalized_expr_start(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut current_start = start;
    while current_start < end {
        let current = token_at(ref tokens, current_start);
        match current.kind {
            tk_eq => {
                current_start = current_start + 1;
            },
            _ => {
                return current_start;
            },
        }
    }
    return current_start;
}

fn expr_has_root_compare(tokens: ref list<token>, start: i32, end: i32) -> bool {
    let mut index = start;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                paren_depth = paren_depth + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_eqeq => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_noteq => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_lt => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_gt => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_lte => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_gte => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn expr_has_root_logic(tokens: ref list<token>, start: i32, end: i32) -> bool {
    let mut index = start;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                paren_depth = paren_depth + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_kw_and => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_kw_or => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn expr_has_root_arithmetic(tokens: ref list<token>, start: i32, end: i32) -> bool {
    let mut index = start;
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                paren_depth = paren_depth + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_plus => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_minus => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_star => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            tk_slash => {
                if paren_depth == 0 and brace_depth == 0 {
                    return true;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn classify_expr_kind(tokens: ref list<token>, start: i32, end: i32) -> expr_fact_kind {
    let expr_start = normalized_expr_start(ref tokens, start, end);
    if expr_start >= end {
        return expr_unit;
    }
    if expr_has_root_logic(ref tokens, expr_start, end) or expr_has_root_compare(ref tokens, expr_start, end) {
        return expr_bool;
    }
    let current = token_at(ref tokens, expr_start);
    match current.kind {
        tk_kw_not => {
            return expr_bool;
        },
        tk_kw_true => {
            return expr_bool;
        },
        tk_kw_false => {
            return expr_bool;
        },
        tk_int_lit => {
            return expr_i32;
        },
        tk_string_lit => {
            return expr_str;
        },
        tk_ident => {
            let next = token_at(ref tokens, expr_start + 1);
            if is_dot_token(next) {
                let member = token_at(ref tokens, expr_start + 2);
                if is_ident_token(member) and expr_start + 3 == end {
                    return expr_field;
                }
            }
            if is_lparen_token(next) {
                return expr_call;
            }
            if is_lbrace_token(next) and expr_start + 1 < end {
                return expr_struct;
            }
            if expr_start + 1 == end {
                return expr_name;
            }
        },
        _ => {
        },
    }
    if expr_has_root_arithmetic(ref tokens, expr_start, end) {
        return expr_i32;
    }
    return expr_unknown;
}

fn classify_expr_name(tokens: ref list<token>, start: i32, end: i32) -> str {
    let expr_start = normalized_expr_start(ref tokens, start, end);
    if expr_start >= end {
        return "";
    }
    let current = token_at(ref tokens, expr_start);
    match current.kind {
        tk_ident => {
            return current.text;
        },
        _ => {
            return "";
        },
    }
}

fn classify_expr_member_name(tokens: ref list<token>, start: i32, end: i32) -> str {
    let expr_start = normalized_expr_start(ref tokens, start, end);
    if expr_start + 2 >= end {
        return "";
    }
    let current = token_at(ref tokens, expr_start);
    let next = token_at(ref tokens, expr_start + 1);
    let member = token_at(ref tokens, expr_start + 2);
    match current.kind {
        tk_ident => {
            if is_dot_token(next) and is_ident_token(member) and expr_start + 3 == end {
                return member.text;
            }
        },
        _ => {
        },
    }
    return "";
}

fn collect_value_match_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, match_at: i32, next_scope_id: mutref i32, typed_bindings: mutref list<typed_binding_fact>, match_arms: mutref list<match_arm_fact>, locals: mutref list<local_init_fact>, returns: mutref list<return_expr_fact>, conditions: mutref list<condition_fact>, assignments: mutref list<assignment_fact>) -> unit {
    advance(mutref cursor);
    let scrutinee_start = cursor;
    skip_until_block(ref tokens, mutref cursor);
    let scrutinee_end = cursor;
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after match expression");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated match block");
                return;
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                let arm_scope_id = next_value_scope_id(mutref next_scope_id);
                let pattern_token = token_at(ref tokens, pattern_start);
                list_push(mutref match_arms, make_match_arm_fact(file, function_name, arm_scope_id, pattern_token.start, match_at, scrutinee_start, scrutinee_end, pattern_start, cursor));
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, arrow, "expected `=>` in match arm");
                        return;
                    },
                }
                collect_value_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, arm_scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_value_stmt_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, next_scope_id: mutref i32, typed_bindings: mutref list<typed_binding_fact>, match_arms: mutref list<match_arm_fact>, locals: mutref list<local_init_fact>, returns: mutref list<return_expr_fact>, conditions: mutref list<condition_fact>, assignments: mutref list<assignment_fact>) -> unit {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_let => {
            advance(mutref cursor);
            let maybe_mut = token_at(ref tokens, cursor);
            match maybe_mut.kind {
                tk_kw_mut => {
                    advance(mutref cursor);
                },
                _ => {
                },
            }
            let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
            let mut local_name = "";
            let mut local_at = 0;
            match name.kind {
                tk_ident => {
                    local_name = name.text;
                    local_at = name.start;
                },
                _ => {
                },
            }
            let mut expected_type_name = "";
            let mut expected_is_borrow = false;
            let maybe_colon = token_at(ref tokens, cursor);
            match maybe_colon.kind {
                tk_colon => {
                    advance(mutref cursor);
                    expected_is_borrow = type_starts_with_borrow(ref tokens, cursor);
                    let expected_type = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                    expected_type_name = expected_type.head;
                    if local_name != "" and expected_type_name != "" {
                        list_push(mutref typed_bindings, make_typed_binding_fact(file, function_name, scope_id, local_name, local_at, expected_type_name, expected_type.arg1_name, expected_type.arg2_name, expected_is_borrow));
                    }
                },
                _ => {
                },
            }
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            if local_name != "" {
                list_push(mutref locals, make_local_init_fact(file, function_name, scope_id, local_name, local_at, expected_type_name, expected_is_borrow, expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1)));
            }
        },
        tk_kw_if => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            list_push(mutref conditions, make_condition_fact(file, function_name, scope_id, current.start, condition_if, condition_start, cursor, classify_expr_kind(ref tokens, condition_start, cursor), classify_expr_name(ref tokens, condition_start, cursor), classify_expr_member_name(ref tokens, condition_start, cursor)));
            let then_scope_id = next_value_scope_id(mutref next_scope_id);
            collect_value_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, then_scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
            let maybe_else = token_at(ref tokens, cursor);
            match maybe_else.kind {
                tk_kw_else => {
                    advance(mutref cursor);
                    let else_scope_id = next_value_scope_id(mutref next_scope_id);
                    collect_value_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, else_scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
                },
                _ => {
                },
            }
        },
        tk_kw_while => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            list_push(mutref conditions, make_condition_fact(file, function_name, scope_id, current.start, condition_while, condition_start, cursor, classify_expr_kind(ref tokens, condition_start, cursor), classify_expr_name(ref tokens, condition_start, cursor), classify_expr_member_name(ref tokens, condition_start, cursor)));
            let body_scope_id = next_value_scope_id(mutref next_scope_id);
            collect_value_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, body_scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
        },
        tk_kw_match => {
            collect_value_match_facts(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, current.start, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
        },
        tk_kw_return => {
            advance(mutref cursor);
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            list_push(mutref returns, make_return_expr_fact(file, function_name, scope_id, current.start, expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1)));
        },
        _ => {
            let next = token_at(ref tokens, cursor + 1);
            if is_ident_token(current) and is_eq_token(next) {
                let expr_start = cursor + 2;
                skip_until_semi(ref tokens, mutref cursor);
                list_push(mutref assignments, make_assignment_fact(file, function_name, scope_id, current.text, current.start, expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1)));
            } else {
                skip_until_semi(ref tokens, mutref cursor);
            }
        },
    }
}

fn collect_value_block_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, next_scope_id: mutref i32, typed_bindings: mutref list<typed_binding_fact>, match_arms: mutref list<match_arm_fact>, locals: mutref list<local_init_fact>, returns: mutref list<return_expr_fact>, conditions: mutref list<condition_fact>, assignments: mutref list<assignment_fact>) -> unit {
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected block");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated block");
                return;
            },
            _ => {
                collect_value_stmt_facts(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
            },
        }
    }
}

fn collect_value_function_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, typed_bindings: mutref list<typed_binding_fact>, match_arms: mutref list<match_arm_fact>, locals: mutref list<local_init_fact>, returns: mutref list<return_expr_fact>, conditions: mutref list<condition_fact>, assignments: mutref list<assignment_fact>) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut function_name = "";
    match name.kind {
        tk_ident => {
            function_name = name.text;
        },
        _ => {
        },
    }
    let mut next_scope_id = 1;
    let root_scope_id = next_value_scope_id(mutref next_scope_id);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lparen => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `(` after function name");
            return;
        },
    }
    let mut scanning_params = true;
    while scanning_params {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rparen => {
                advance(mutref cursor);
                scanning_params = false;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated parameter list");
                return;
            },
            tk_ident => {
                let param_name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let mut param_text = "";
                let mut param_at = 0;
                match param_name.kind {
                    tk_ident => {
                        param_text = param_name.text;
                        param_at = param_name.start;
                    },
                    _ => {
                    },
                }
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after parameter name");
                    },
                }
                let is_borrow = type_starts_with_borrow(ref tokens, cursor);
                let type_shape = consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                let type_name = type_shape.head;
                if param_text != "" and type_name != "" {
                    list_push(mutref typed_bindings, make_typed_binding_fact(file, function_name, root_scope_id, param_text, param_at, type_name, type_shape.arg1_name, type_shape.arg2_name, is_borrow));
                }
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
            _ => {
                push_diag(mutref diags, file, current, "expected parameter or `)`");
                advance(mutref cursor);
            },
        }
    }
    let arrow = token_at(ref tokens, cursor);
    match arrow.kind {
        tk_arrow => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, arrow, "expected `->` after parameter list");
        },
    }
    consume_type_name(ref tokens, mutref cursor, mutref diags, file);
    parse_audit(ref tokens, mutref cursor, mutref diags, file);
    collect_value_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, root_scope_id, mutref next_scope_id, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
}

pub fn collect_value_type_facts(file: str, tokens: ref list<token>, typed_bindings: mutref list<typed_binding_fact>, field_facts: mutref list<field_fact>, match_arms: mutref list<match_arm_fact>, locals: mutref list<local_init_fact>, returns: mutref list<return_expr_fact>, conditions: mutref list<condition_fact>, assignments: mutref list<assignment_fact>, diags: mutref list<diag>) -> value_typecheck_summary
audit {
    intent("Collect flat binding, local, return, condition, and assignment facts for the next selfhost type-checker slice");
    mutates(typed_bindings, field_facts, match_arms, locals, returns, conditions, assignments, diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let start_typed_binding_count = list_len(ref typed_bindings);
    let start_local_count = list_len(ref locals);
    let start_return_count = list_len(ref returns);
    let start_condition_count = list_len(ref conditions);
    let start_assignment_count = list_len(ref assignments);
    let mut cursor = 0;
    let mut scanning_uses = true;
    let mut ignored_variants: list<variant_fact> = list();
    let mut ignored_payloads: list<variant_payload_fact> = list();

    while scanning_uses {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_kw_use => {
                advance(mutref cursor);
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let semi = token_at(ref tokens, cursor);
                match semi.kind {
                    tk_semi => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, semi, "expected `;` after use declaration");
                    },
                }
            },
            _ => {
                scanning_uses = false;
            },
        }
    }

    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return make_value_typecheck_summary(
                    list_len(ref typed_bindings) - start_typed_binding_count,
                    list_len(ref locals) - start_local_count,
                    list_len(ref returns) - start_return_count,
                    list_len(ref conditions) - start_condition_count,
                    list_len(ref assignments) - start_assignment_count,
                    list_len(ref diags) - start_diag_count
                );
            },
            tk_kw_pub => {
                advance(mutref cursor);
                let next = token_at(ref tokens, cursor);
                match next.kind {
                    tk_kw_fn => {
                        collect_value_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
                    },
                    tk_kw_type => {
                        collect_value_type_decl_facts(ref tokens, mutref cursor, mutref diags, file, mutref field_facts);
                    },
                    tk_kw_enum => {
                        collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_variants, mutref ignored_payloads);
                    },
                    _ => {
                        push_diag(mutref diags, file, next, "expected fn, type, or enum after pub");
                        advance(mutref cursor);
                    },
                }
            },
            tk_kw_fn => {
                collect_value_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref typed_bindings, mutref match_arms, mutref locals, mutref returns, mutref conditions, mutref assignments);
            },
            tk_kw_type => {
                collect_value_type_decl_facts(ref tokens, mutref cursor, mutref diags, file, mutref field_facts);
            },
            tk_kw_enum => {
                collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_variants, mutref ignored_payloads);
            },
            _ => {
                push_diag(mutref diags, file, current, "expected top-level item");
                advance(mutref cursor);
            },
        }
    }
}

fn collect_stmt_match_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, match_at: i32, next_scope_id: mutref i32, statements: mutref list<stmt_fact>) -> unit {
    advance(mutref cursor);
    let scrutinee_start = cursor;
    skip_until_block(ref tokens, mutref cursor);
    let scrutinee_end = cursor;
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `{` after match expression");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, match_at, stmt_match, "", scrutinee_start, scrutinee_end, classify_expr_kind(ref tokens, scrutinee_start, scrutinee_end), classify_expr_name(ref tokens, scrutinee_start, scrutinee_end), classify_expr_member_name(ref tokens, scrutinee_start, scrutinee_end), -1, -1));
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated match block");
                return;
            },
            _ => {
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, arrow, "expected `=>` in match arm");
                        return;
                    },
                }
                let arm_scope_id = next_value_scope_id(mutref next_scope_id);
                collect_stmt_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, arm_scope_id, mutref next_scope_id, mutref statements);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
        }
    }
}

fn collect_stmt_stmt_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, next_scope_id: mutref i32, statements: mutref list<stmt_fact>) -> unit {
    let current = token_at(ref tokens, cursor);
    match current.kind {
        tk_kw_let => {
            advance(mutref cursor);
            let maybe_mut = token_at(ref tokens, cursor);
            match maybe_mut.kind {
                tk_kw_mut => {
                    advance(mutref cursor);
                },
                _ => {
                },
            }
            let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
            let mut local_name = "";
            match name.kind {
                tk_ident => {
                    local_name = name.text;
                },
                _ => {
                },
            }
            let maybe_colon = token_at(ref tokens, cursor);
            match maybe_colon.kind {
                tk_colon => {
                    advance(mutref cursor);
                    consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                },
                _ => {
                },
            }
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_local, local_name, expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1), -1, -1));
        },
        tk_kw_if => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            let condition_end = cursor;
            let then_scope_id = next_value_scope_id(mutref next_scope_id);
            collect_stmt_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, then_scope_id, mutref next_scope_id, mutref statements);
            let maybe_else = token_at(ref tokens, cursor);
            let mut else_scope_id = -1;
            match maybe_else.kind {
                tk_kw_else => {
                    advance(mutref cursor);
                    else_scope_id = next_value_scope_id(mutref next_scope_id);
                    collect_stmt_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, else_scope_id, mutref next_scope_id, mutref statements);
                },
                _ => {
                },
            }
            list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_if, "", condition_start, condition_end, classify_expr_kind(ref tokens, condition_start, condition_end), classify_expr_name(ref tokens, condition_start, condition_end), classify_expr_member_name(ref tokens, condition_start, condition_end), then_scope_id, else_scope_id));
        },
        tk_kw_while => {
            advance(mutref cursor);
            let condition_start = cursor;
            skip_until_block(ref tokens, mutref cursor);
            let condition_end = cursor;
            let body_scope_id = next_value_scope_id(mutref next_scope_id);
            collect_stmt_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, body_scope_id, mutref next_scope_id, mutref statements);
            list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_while, "", condition_start, condition_end, classify_expr_kind(ref tokens, condition_start, condition_end), classify_expr_name(ref tokens, condition_start, condition_end), classify_expr_member_name(ref tokens, condition_start, condition_end), body_scope_id, -1));
        },
        tk_kw_match => {
            collect_stmt_match_facts(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, current.start, mutref next_scope_id, mutref statements);
        },
        tk_kw_return => {
            advance(mutref cursor);
            let expr_start = cursor;
            skip_until_semi(ref tokens, mutref cursor);
            list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_return, "", expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1), -1, -1));
        },
        _ => {
            let next = token_at(ref tokens, cursor + 1);
            if is_ident_token(current) and is_eq_token(next) {
                let expr_start = cursor + 2;
                skip_until_semi(ref tokens, mutref cursor);
                list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_assign, current.text, expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1), -1, -1));
            } else {
                let expr_start = cursor;
                skip_until_semi(ref tokens, mutref cursor);
                list_push(mutref statements, make_stmt_fact(file, function_name, scope_id, current.start, stmt_expr, "", expr_start, cursor - 1, classify_expr_kind(ref tokens, expr_start, cursor - 1), classify_expr_name(ref tokens, expr_start, cursor - 1), classify_expr_member_name(ref tokens, expr_start, cursor - 1), -1, -1));
            }
        },
    }
}

fn collect_stmt_block_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, function_name: str, scope_id: i32, next_scope_id: mutref i32, statements: mutref list<stmt_fact>) -> unit {
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected block");
            return;
        },
    }
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                advance(mutref cursor);
                return;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated block");
                return;
            },
            _ => {
                collect_stmt_stmt_facts(ref tokens, mutref cursor, mutref diags, file, function_name, scope_id, mutref next_scope_id, mutref statements);
            },
        }
    }
}

fn collect_stmt_function_facts(tokens: ref list<token>, cursor: mutref i32, diags: mutref list<diag>, file: str, statements: mutref list<stmt_fact>) -> unit {
    advance(mutref cursor);
    let name = consume_ident(ref tokens, mutref cursor, mutref diags, file);
    let mut function_name = "";
    match name.kind {
        tk_ident => {
            function_name = name.text;
        },
        _ => {
        },
    }
    let mut next_scope_id = 1;
    let root_scope_id = next_value_scope_id(mutref next_scope_id);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lparen => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, open, "expected `(` after function name");
            return;
        },
    }
    let mut scanning_params = true;
    while scanning_params {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rparen => {
                advance(mutref cursor);
                scanning_params = false;
            },
            tk_eof => {
                push_diag(mutref diags, file, current, "unterminated parameter list");
                return;
            },
            tk_ident => {
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let colon = token_at(ref tokens, cursor);
                match colon.kind {
                    tk_colon => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, colon, "expected `:` after parameter name");
                    },
                }
                consume_type_shape(ref tokens, mutref cursor, mutref diags, file);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        advance(mutref cursor);
                    },
                    _ => {
                    },
                }
            },
            _ => {
                push_diag(mutref diags, file, current, "expected parameter or `)`");
                advance(mutref cursor);
            },
        }
    }
    let arrow = token_at(ref tokens, cursor);
    match arrow.kind {
        tk_arrow => {
            advance(mutref cursor);
        },
        _ => {
            push_diag(mutref diags, file, arrow, "expected `->` after parameter list");
        },
    }
    consume_type_name(ref tokens, mutref cursor, mutref diags, file);
    parse_audit(ref tokens, mutref cursor, mutref diags, file);
    collect_stmt_block_facts(ref tokens, mutref cursor, mutref diags, file, function_name, root_scope_id, mutref next_scope_id, mutref statements);
}

pub fn collect_stmt_facts(file: str, tokens: ref list<token>, statements: mutref list<stmt_fact>, diags: mutref list<diag>) -> stmt_fact_summary
audit {
    intent("Collect flat statement and control-flow facts for the structured checked handoff");
    mutates(statements, diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let start_stmt_count = list_len(ref statements);
    let mut cursor = 0;
    let mut scanning_uses = true;
    let mut ignored_fields: list<field_fact> = list();
    let mut ignored_variants: list<variant_fact> = list();
    let mut ignored_payloads: list<variant_payload_fact> = list();

    while scanning_uses {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_kw_use => {
                advance(mutref cursor);
                consume_ident(ref tokens, mutref cursor, mutref diags, file);
                let semi = token_at(ref tokens, cursor);
                match semi.kind {
                    tk_semi => {
                        advance(mutref cursor);
                    },
                    _ => {
                        push_diag(mutref diags, file, semi, "expected `;` after use declaration");
                    },
                }
            },
            _ => {
                scanning_uses = false;
            },
        }
    }

    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return make_stmt_fact_summary(list_len(ref statements) - start_stmt_count, list_len(ref diags) - start_diag_count);
            },
            tk_kw_pub => {
                advance(mutref cursor);
                let next = token_at(ref tokens, cursor);
                match next.kind {
                    tk_kw_fn => {
                        collect_stmt_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref statements);
                    },
                    tk_kw_type => {
                        collect_value_type_decl_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_fields);
                    },
                    tk_kw_enum => {
                        collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_variants, mutref ignored_payloads);
                    },
                    _ => {
                        push_diag(mutref diags, file, next, "expected fn, type, or enum after pub");
                        advance(mutref cursor);
                    },
                }
            },
            tk_kw_fn => {
                collect_stmt_function_facts(ref tokens, mutref cursor, mutref diags, file, mutref statements);
            },
            tk_kw_type => {
                collect_value_type_decl_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_fields);
            },
            tk_kw_enum => {
                collect_enum_facts(ref tokens, mutref cursor, mutref diags, file, mutref ignored_variants, mutref ignored_payloads);
            },
            _ => {
                push_diag(mutref diags, file, current, "expected top-level item");
                advance(mutref cursor);
            },
        }
    }
}
