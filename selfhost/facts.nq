}

fn type_ref_kind_text(kind: type_ref_kind) -> str {
    match kind {
        type_return => {
            return "return_type";
        },
        type_param => {
            return "param_type";
        },
        type_local_annotation => {
            return "local_annotation";
        },
        type_field => {
            return "field_type";
        },
        type_enum_payload => {
