    match kind {
        item_fn => {
            return "function";
        },
        item_type => {
            return "type";
        },
        item_enum => {
            return "enum";
        },
        item_variant => {
            return "variant";
        },
        item_const => {
            return "const";
        },
    }
}

fn binding_kind_text(kind: body_binding_kind) -> str {
    match kind {
        bind_param => {
            return "param";
        },
        bind_let => {
            return "local";
        },
        bind_pattern => {
            return "pattern";
        },
    }
}

fn name_ref_kind_text(kind: name_ref_kind) -> str {
    match kind {
