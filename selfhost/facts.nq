fn append_definitions(lines: mutref list<str>, items: ref list<top_item>, uses: ref list<module_use>, variants: ref list<variant_fact>, fields: ref list<field_fact>, bindings: ref list<body_binding>) -> unit {
    let total = definition_count(ref items, ref uses, ref fields, ref bindings);
    let mut emitted = 0;
    list_push(mutref lines, "  \"definitions\": [");
    let mut item_index = 0;
    while item_index < list_len(ref items) {
        let entry = list_get(ref items, item_index);
        match entry {
            Some(value) => {
                emitted = emitted + 1;
                append_top_item_definition(mutref lines, value, ref variants, emitted < total);
            },
            None => {
            },
        }
        item_index = item_index + 1;
    }
    let mut field_index = 0;
    while field_index < list_len(ref fields) {
        let entry = list_get(ref fields, field_index);
        match entry {
            Some(value) => {
                emitted = emitted + 1;
                append_field_definition(mutref lines, value, emitted < total);
            },
            None => {
            },
        }
        field_index = field_index + 1;
    }
    let mut binding_index = 0;
    while binding_index < list_len(ref bindings) {
        let entry = list_get(ref bindings, binding_index);
        match entry {
            Some(value) => {
                if binding_creates_local(value, ref items, ref uses) {
                    emitted = emitted + 1;
                    append_binding_definition(mutref lines, value, emitted < total);
                }
            },
            None => {
            },
        }
        binding_index = binding_index + 1;
    }
    list_push(mutref lines, "  ],");
    return;
}

