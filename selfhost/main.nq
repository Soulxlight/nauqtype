    if list_len(ref diags) > 0 {
        return false;
    }
    if checked_summary.function_count < 1 or borrow_summary.function_count < checked_summary.function_count {
        list_push(mutref diags, make_diag(entry_module, 0, "stage1 internal error: tooling facts safety pass skipped checked functions"));
        return false;
    }
    return true;
}

fn run_refactor_rename(workspace_root: str, entry_module: str, entry_path: str, target_id: str, new_name: str) -> i32 {
    let mut loaded: list<str> = list();
    let mut sources: list<source_file> = list();
    let mut items: list<top_item> = list();
    let mut uses: list<module_use> = list();
    let mut scopes: list<body_scope> = list();
    let mut bindings: list<body_binding> = list();
    let mut refs: list<name_ref> = list();
    let mut type_refs: list<type_ref> = list();
    let mut variant_facts: list<variant_fact> = list();
    let mut field_facts: list<field_fact> = list();
    let mut call_facts: list<call_fact> = list();
    let mut diags: list<diag> = list();
    if not collect_facts_ready_project(workspace_root, entry_module, entry_path, mutref loaded, mutref sources, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref variant_facts, mutref field_facts, mutref call_facts, mutref diags) {
        emit_all(ref diags);
        return 1;
    }
    return emit_refactor_rename_plan(workspace_root, entry_module, entry_path, ref items, ref uses, ref scopes, ref bindings, ref refs, ref type_refs, ref variant_facts, ref field_facts, target_id, new_name);
}

