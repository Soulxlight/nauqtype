    typecheck_value_facts(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref typed_bindings, ref field_facts, ref match_arms, ref local_inits, ref return_facts, ref condition_facts, ref assignment_facts, ref uses, ref items, ref sources, mutref diags);
    collect_resolved_binding_facts(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref typed_bindings, ref field_facts, ref match_arms, ref local_inits, ref uses, ref items, ref sources, mutref resolved_bindings, mutref pattern_bindings, mutref diags);
    let checked_summary = build_checked_handoff(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref resolved_bindings, ref field_facts, ref match_arms, ref pattern_bindings, ref stmt_facts, ref uses, ref items, ref sources, mutref checked_modules, mutref checked_functions, mutref checked_bindings, mutref checked_params, mutref checked_consts, mutref checked_type_shapes, mutref checked_type_decls, mutref checked_field_decls, mutref checked_enum_decls, mutref checked_variant_decls, mutref checked_variant_payload_decls, mutref checked_blocks, mutref checked_statements, mutref checked_match_arms, mutref checked_patterns, mutref checked_pattern_children, mutref checked_pattern_bindings, mutref checked_expressions, mutref checked_expr_children, mutref checked_struct_fields, mutref diags);
    let borrow_summary = check_checked_handoff_borrows(ref checked_functions, ref checked_bindings, ref checked_params, ref checked_type_decls, ref checked_field_decls, ref checked_enum_decls, ref checked_variant_decls, ref checked_variant_payload_decls, ref checked_blocks, ref checked_statements, ref checked_match_arms, ref checked_pattern_bindings, ref checked_expressions, ref checked_expr_children, ref checked_struct_fields, mutref diags);

    if list_len(ref diags) > 0 {
        return false;
    }
    if checked_summary.function_count < 1 or borrow_summary.function_count < checked_summary.function_count {
        list_push(mutref diags, make_diag(entry_module, 0, "stage1 internal error: review safety pass skipped checked functions"));
        return false;
    }
    return true;
}

fn run_review(workspace_root: str, entry_module: str, entry_path: str, use_v2: bool) -> i32 {
    let mut seen: list<str> = list();
    let mut loaded: list<str> = list();
    let mut sources: list<source_file> = list();
    let mut items: list<top_item> = list();
    let mut uses: list<module_use> = list();
    let mut scopes: list<body_scope> = list();
    let mut bindings: list<body_binding> = list();
    let mut refs: list<name_ref> = list();
    let mut type_refs: list<type_ref> = list();
    let mut function_facts: list<function_fact> = list();
    let mut function_param_facts: list<function_param_fact> = list();
    let mut variant_facts: list<variant_fact> = list();
    let mut variant_payload_facts: list<variant_payload_fact> = list();
    let mut const_facts: list<const_fact> = list();
    let mut call_facts: list<call_fact> = list();
    let mut pattern_facts: list<pattern_ctor_fact> = list();
    let mut typed_bindings: list<typed_binding_fact> = list();
    let mut field_facts: list<field_fact> = list();
    let mut match_arms: list<match_arm_fact> = list();
    let mut local_inits: list<local_init_fact> = list();
    let mut return_facts: list<return_expr_fact> = list();
    let mut condition_facts: list<condition_fact> = list();
    let mut assignment_facts: list<assignment_fact> = list();
    let mut stmt_facts: list<stmt_fact> = list();
    let mut resolved_bindings: list<typed_binding_fact> = list();
    let mut pattern_bindings: list<pattern_binding_fact> = list();
    let mut checked_modules: list<checked_module> = list();
    let mut checked_functions: list<checked_function> = list();
    let mut checked_bindings: list<checked_binding> = list();
    let mut checked_params: list<checked_param> = list();
    let mut checked_consts: list<checked_const_decl> = list();
    let mut checked_type_shapes: list<checked_type_shape> = list();
    let mut checked_type_decls: list<checked_type_decl> = list();
    let mut checked_field_decls: list<checked_field_decl> = list();
    let mut checked_enum_decls: list<checked_enum_decl> = list();
    let mut checked_variant_decls: list<checked_variant_decl> = list();
    let mut checked_variant_payload_decls: list<checked_variant_payload_decl> = list();
    let mut checked_blocks: list<checked_block> = list();
    let mut checked_statements: list<checked_stmt> = list();
    let mut checked_match_arms: list<checked_match_arm> = list();
    let mut checked_patterns: list<checked_pattern> = list();
    let mut checked_pattern_children: list<checked_pattern_child> = list();
    let mut checked_pattern_bindings: list<checked_pattern_binding> = list();
    let mut checked_expressions: list<checked_expr> = list();
    let mut checked_expr_children: list<checked_expr_child> = list();
    let mut checked_struct_fields: list<checked_struct_field_init> = list();
    let mut diags: list<diag> = list();
    load_module_graph(entry_module, workspace_root, entry_module, entry_path, "", mutref seen, mutref loaded, mutref sources, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref function_facts, mutref function_param_facts, mutref variant_facts, mutref variant_payload_facts, mutref const_facts, mutref call_facts, mutref pattern_facts, mutref typed_bindings, mutref field_facts, mutref match_arms, mutref local_inits, mutref return_facts, mutref condition_facts, mutref assignment_facts, mutref stmt_facts, mutref diags);

    resolve_modules(ref loaded, ref uses, ref items, mutref diags);
    resolve_types(ref type_refs, ref uses, ref items, mutref diags);
    resolve_bodies(ref scopes, ref bindings, ref refs, ref uses, ref items, mutref diags);
    typecheck_modules_for_entry(ref function_facts, ref variant_facts, ref call_facts, ref pattern_facts, ref uses, ref items, entry_module, false, mutref diags);
    typecheck_const_facts(ref const_facts, ref sources, mutref diags);
    typecheck_value_facts(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref typed_bindings, ref field_facts, ref match_arms, ref local_inits, ref return_facts, ref condition_facts, ref assignment_facts, ref uses, ref items, ref sources, mutref diags);
    collect_resolved_binding_facts(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref typed_bindings, ref field_facts, ref match_arms, ref local_inits, ref uses, ref items, ref sources, mutref resolved_bindings, mutref pattern_bindings, mutref diags);
    let checked_summary = build_checked_handoff(ref function_facts, ref function_param_facts, ref variant_facts, ref variant_payload_facts, ref const_facts, ref scopes, ref resolved_bindings, ref field_facts, ref match_arms, ref pattern_bindings, ref stmt_facts, ref uses, ref items, ref sources, mutref checked_modules, mutref checked_functions, mutref checked_bindings, mutref checked_params, mutref checked_consts, mutref checked_type_shapes, mutref checked_type_decls, mutref checked_field_decls, mutref checked_enum_decls, mutref checked_variant_decls, mutref checked_variant_payload_decls, mutref checked_blocks, mutref checked_statements, mutref checked_match_arms, mutref checked_patterns, mutref checked_pattern_children, mutref checked_pattern_bindings, mutref checked_expressions, mutref checked_expr_children, mutref checked_struct_fields, mutref diags);
    let borrow_summary = check_checked_handoff_borrows(ref checked_functions, ref checked_bindings, ref checked_params, ref checked_type_decls, ref checked_field_decls, ref checked_enum_decls, ref checked_variant_decls, ref checked_variant_payload_decls, ref checked_blocks, ref checked_statements, ref checked_match_arms, ref checked_pattern_bindings, ref checked_expressions, ref checked_expr_children, ref checked_struct_fields, mutref diags);

    if list_len(ref diags) > 0 {
        emit_all(ref diags);
        return 1;
    }
    if checked_summary.function_count < 1 or borrow_summary.function_count < checked_summary.function_count {
        eprint_line("stage1 internal error: review safety pass skipped checked functions");
        return 1;
    }

    let mut review_summary = make_review_summary(0, 0, 0, 1);
    if use_v2 {
        review_summary = emit_review_v2(entry_module, ref sources, ref uses, ref function_param_facts, ref assignment_facts, ref call_facts);
    } else {
        review_summary = emit_review(entry_module, ref sources, ref uses, ref function_param_facts, ref assignment_facts, ref call_facts);
    }
    if review_summary.error_count > 0 {
        return 1;
    }
    return 0;
}

fn run_review_diff(before_path: str, after_path: str, use_v2: bool) -> i32 {
    let before_module = path_stem(before_path);
    let before_workspace = path_dir(before_path);
    let after_module = path_stem(after_path);
    let after_workspace = path_dir(after_path);

    let mut before_sources: list<source_file> = list();
    let mut before_uses: list<module_use> = list();
    let mut before_params: list<function_param_fact> = list();
    let mut before_assignments: list<assignment_fact> = list();
    let mut before_calls: list<call_fact> = list();
    let mut before_diags: list<diag> = list();
    let mut after_sources: list<source_file> = list();
    let mut after_uses: list<module_use> = list();
    let mut after_params: list<function_param_fact> = list();
    let mut after_assignments: list<assignment_fact> = list();
    let mut after_calls: list<call_fact> = list();
    let mut after_diags: list<diag> = list();

    let before_ok = collect_review_ready_project(before_workspace, before_module, before_path, mutref before_sources, mutref before_uses, mutref before_params, mutref before_assignments, mutref before_calls, mutref before_diags);
    let after_ok = collect_review_ready_project(after_workspace, after_module, after_path, mutref after_sources, mutref after_uses, mutref after_params, mutref after_assignments, mutref after_calls, mutref after_diags);
    if not before_ok or not after_ok {
        emit_all(ref before_diags);
        emit_all(ref after_diags);
        return 1;
    }

    let summary = emit_review_diff_format(before_module, ref before_sources, ref before_uses, ref before_params, ref before_assignments, ref before_calls, after_module, ref after_sources, ref after_uses, ref after_params, ref after_assignments, ref after_calls, use_v2);
    if summary.error_count > 0 {
        return 1;
    }
    return 0;
}

fn emit_text_output(text: str, to_stderr: bool) -> unit {
    let mut start = 0;
    let mut index = 0;
    while index < str_len(text) {
        let entry = str_get(text, index);
        match entry {
            Some(value) => {
                if value == 10 {
                    let line = slice_text_without_trailing_cr(text, start, index);
                    if to_stderr {
                        eprint_line(line);
                    } else {
                        print_line(line);
                    }
                    start = index + 1;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    if start < str_len(text) {
        let tail = slice_text_without_trailing_cr(text, start, str_len(text));
        if to_stderr {
            eprint_line(tail);
        } else {
            print_line(tail);
        }
    }
    return;
}

fn emit_process_output(result: process_result) -> unit {
    if result.stdout != "" {
        emit_text_output(result.stdout, false);
    }
    if result.stderr != "" {
        emit_text_output(result.stderr, true);
    }
    return;
}

fn compile_emitted_c(c_path: str, exe_path: str) -> result<process_result, io_err> {
    let ensure_result = ensure_parent_dir(exe_path);
    match ensure_result {
        Ok(_) => {
        },
        Err(err) => {
            return Err(err);
        },
    }

    let mut args: list<str> = list();
    list_push(mutref args, "cc");
    list_push(mutref args, "-std=c11");
    list_push(mutref args, "-Istdlib");
    list_push(mutref args, c_path);
    list_push(mutref args, "stdlib/runtime.c");
    list_push(mutref args, "-o");
    list_push(mutref args, exe_path);
    return run_process(".deps/ziglang/zig.exe", ref args, ".");
}

fn run_build_command(request: driver_request, execute_program: bool) -> i32 {
    let c_path = build_c_output_path(request.entry_path, request.output_path);
    let exe_path = build_exe_output_path(request.entry_path, request.output_path);
    let emit_code = run_pipeline(request.workspace_root, request.entry_module, request.entry_path, c_path, true, "");
    if emit_code != 0 {
        return emit_code;
    }

    let compile_result = compile_emitted_c(c_path, exe_path);
    match compile_result {
        Ok(compile_status) => {
            if compile_status.exit_code != 0 {
                emit_process_output(compile_status);
                return compile_status.exit_code;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    if not execute_program {
        return 0;
    }

    let empty_args: list<str> = list();
    let run_result = run_process(exe_path, ref empty_args, path_dir(request.entry_path));
    match run_result {
        Ok(run_status) => {
            emit_process_output(run_status);
            return run_status.exit_code;
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }
}

fn main() -> i32 {
    let request = parse_driver_request();
    match request.mode {
        driver_legacy => {
            return run_pipeline(request.workspace_root, request.entry_module, request.entry_path, request.output_path, true, "stage1 front-end ok");
        },
        driver_check => {
            return run_pipeline(request.workspace_root, request.entry_module, request.entry_path, "", false, "");
        },
        driver_emit_c => {
            return run_pipeline(request.workspace_root, request.entry_module, request.entry_path, request.output_path, true, "");
        },
        driver_facts => {
            return run_facts(request.workspace_root, request.entry_module, request.entry_path, 1);
        },
        driver_facts_v2 => {
            return run_facts(request.workspace_root, request.entry_module, request.entry_path, 2);
        },
        driver_review => {
            return run_review(request.workspace_root, request.entry_module, request.entry_path, false);
        },
        driver_review_v2 => {
            return run_review(request.workspace_root, request.entry_module, request.entry_path, true);
        },
        driver_review_diff => {
            return run_review_diff(request.entry_path, request.output_path, false);
        },
        driver_review_diff_v2 => {
            return run_review_diff(request.entry_path, request.output_path, true);
        },
        driver_refactor_rename => {
            return run_refactor_rename(request.workspace_root, request.entry_module, request.entry_path, request.output_path, request.extra_text);
        },
        driver_policy_check => {
            return run_policy_check(request.workspace_root, request.entry_module, request.entry_path, request.output_path);
        },
        driver_build => {
            return run_build_command(request, false);
        },
        driver_run => {
            return run_build_command(request, true);
        },
        driver_prove => {
            return run_all_proofs(request.entry_path);
        },
        driver_prove_selfhost => {
            return run_selfhost_proof(request.entry_path);
        },
        driver_prove_corpus => {
            return run_example_corpus(request.entry_path);
        },
        driver_invalid => {
            print_line(request.error_message);
            return 1;
        },
    }
}
