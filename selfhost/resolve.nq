fn is_pattern_binding(binding: body_binding) -> bool {
    match binding.kind {
        bind_pattern => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn binding_creates_local(binding: body_binding, items: ref list<top_item>, uses: ref list<module_use>) -> bool {
    if is_pattern_binding(binding) and module_has_visible_variant_name(ref items, ref uses, binding.module, binding.name) {
        return false;
    }
    return true;
}

fn parent_scope_id(scopes: ref list<body_scope>, module: str, function_name: str, scope_id: i32) -> i32 {
    let mut index = list_len(ref scopes) - 1;
    while index >= 0 {
        let entry = list_get(ref scopes, index);
        match entry {
            Some(value) => {
                if value.module == module and value.function_name == function_name and value.scope_id == scope_id {
                    return value.parent_scope_id;
                }
            },
            None => {
            },
        }
        index = index - 1;
    }
    return -1;
}

fn binding_visible_in_scope(bindings: ref list<body_binding>, items: ref list<top_item>, uses: ref list<module_use>, module: str, function_name: str, scope_id: i32, name: str, at: i32) -> bool {
    let mut index = list_len(ref bindings) - 1;
    while index >= 0 {
        let entry = list_get(ref bindings, index);
        match entry {
            Some(value) => {
                if binding_creates_local(value, ref items, ref uses) and value.module == module and value.function_name == function_name and value.scope_id == scope_id and value.name == name and value.at < at {
                    return true;
                }
            },
            None => {
            },
        }
        index = index - 1;
    }
    return false;
}

fn scope_is_visible(scopes: ref list<body_scope>, module: str, function_name: str, current_scope_id: i32, candidate_scope_id: i32) -> bool {
    let mut scope_cursor = current_scope_id;
    while scope_cursor >= 0 {
        if scope_cursor == candidate_scope_id {
            return true;
        }
        scope_cursor = parent_scope_id(ref scopes, module, function_name, scope_cursor);
    }
    return false;
}

fn has_visible_binding(bindings: ref list<body_binding>, scopes: ref list<body_scope>, items: ref list<top_item>, uses: ref list<module_use>, module: str, function_name: str, scope_id: i32, name: str, at: i32) -> bool {
    let mut index = list_len(ref bindings) - 1;
    while index >= 0 {
        let entry = list_get(ref bindings, index);
        match entry {
            Some(value) => {
                if binding_creates_local(value, ref items, ref uses) and value.module == module and value.function_name == function_name and value.name == name and value.at < at {
                    if scope_is_visible(ref scopes, module, function_name, scope_id, value.scope_id) {
                        return true;
                    }
                }
            },
            None => {
            },
        }
        index = index - 1;
    }
    return false;
}

fn copy_scopes_for_function(source: ref list<body_scope>, module: str, function_name: str) -> list<body_scope> {
    let mut copied: list<body_scope> = list();
    let mut index = 0;
    while index < list_len(ref source) {
        let entry = list_get(ref source, index);
        match entry {
            Some(value) => {
                if value.module == module and value.function_name == function_name {
                    list_push(mutref copied, value);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return copied;
}

fn copy_bindings_for_function(source: ref list<body_binding>, module: str, function_name: str) -> list<body_binding> {
