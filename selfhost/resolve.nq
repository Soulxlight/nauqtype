            None => {
            },
        }
        index = index + 1;
    }
    return copied;
}

fn count_root_function_scopes(scopes: ref list<body_scope>) -> i32 {
    let mut count = 0;
    let mut index = 0;
    while index < list_len(ref scopes) {
        let entry = list_get(ref scopes, index);
        match entry {
            Some(value) => {
                if value.parent_scope_id < 0 {
                    count = count + 1;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return count;
}

fn resolve_duplicate_bindings(bindings: ref list<body_binding>, items: ref list<top_item>, uses: ref list<module_use>, diags: mutref list<diag>) -> unit {
    let mut binding_index = 0;
    while binding_index < list_len(ref bindings) {
        let entry = list_get(ref bindings, binding_index);
        match entry {
            Some(current) => {
                let current_creates_local = binding_creates_local(current, ref items, ref uses);
                if current_creates_local {
                    let mut prev_index = binding_index - 1;
                    while prev_index >= 0 {
                        let previous = list_get(ref bindings, prev_index);
                        match previous {
                            Some(value) => {
                                if value.scope_id == current.scope_id and value.name == current.name and binding_creates_local(value, ref items, ref uses) {
                                    push_diag(mutref diags, current.module, current.at, "duplicate local binding in one scope");
                                    prev_index = -1;
                                } else {
                                    prev_index = prev_index - 1;
                                }
                            },
                            None => {
                                prev_index = prev_index - 1;
                            },
                        }
                    }
                }
            },
            None => {
            },
        }
        binding_index = binding_index + 1;
    }
    return;
}

fn resolve_function_refs(scopes: ref list<body_scope>, bindings: ref list<body_binding>, refs: ref list<name_ref>, uses: ref list<module_use>, items: ref list<top_item>, diags: mutref list<diag>) -> unit {
    let mut ref_index = 0;
    while ref_index < list_len(ref refs) {
        let entry = list_get(ref refs, ref_index);
        match entry {
            Some(current) => {
                let has_local = has_visible_binding(ref bindings, ref scopes, ref items, ref uses, current.module, current.function_name, current.scope_id, current.name, current.at);
                match current.kind {
                    ref_assign_target => {
                        if not has_local {
                            push_diag(mutref diags, current.module, current.at, "unknown assignment target in function body");
                        }
                    },
                    ref_borrow_target => {
                        if not has_local {
                            push_diag(mutref diags, current.module, current.at, "cannot borrow unknown local name");
                        }
                    },
                    ref_call => {
                        if has_local {
                            push_diag(mutref diags, current.module, current.at, "local name cannot be called in function body");
                        } else {
                            if module_has_visible_expression_name(ref items, ref uses, current.module, current.name) {
                            } else {
                                if module_has_hidden_imported_expression_name(ref items, ref uses, current.module, current.name) {
                                    push_diag(mutref diags, current.module, current.at, "name exists in an imported module but is not `pub`");
                                } else {
                                    push_diag(mutref diags, current.module, current.at, "unknown call target in function body");
                                }
                            }
                        }
                    },
                    ref_value => {
                        if not has_local {
                            if module_has_visible_variant_name(ref items, ref uses, current.module, current.name) {
                            } else {
                                if module_has_visible_const_name(ref items, ref uses, current.module, current.name) {
                                } else {
                                    if module_has_visible_function_name(ref items, ref uses, current.module, current.name) {
                                        push_diag(mutref diags, current.module, current.at, "function name cannot be used as a plain value in function body");
                                    } else {
                                        if module_has_hidden_imported_expression_name(ref items, ref uses, current.module, current.name) or module_has_hidden_imported_const_name(ref items, ref uses, current.module, current.name) {
                                            push_diag(mutref diags, current.module, current.at, "name exists in an imported module but is not `pub`");
                                        } else {
                                            push_diag(mutref diags, current.module, current.at, "unknown name in function body");
                                        }
                                    }
                                }
                            }
                        }
                    },
                    ref_struct_type => {
                        if module_has_visible_type_name(ref items, ref uses, current.module, current.name) {
                        } else {
                            if module_has_hidden_imported_type_name(ref items, ref uses, current.module, current.name) {
                                push_diag(mutref diags, current.module, current.at, "type exists in an imported module but is not `pub`");
                            } else {
                                push_diag(mutref diags, current.module, current.at, "unknown struct literal type in function body");
                            }
                        }
                    },
                    ref_pattern_ctor => {
                        if module_has_visible_variant_name(ref items, ref uses, current.module, current.name) {
                        } else {
                            if module_has_hidden_imported_variant_name(ref items, ref uses, current.module, current.name) {
                                push_diag(mutref diags, current.module, current.at, "pattern constructor exists in an imported module but is not `pub`");
                            } else {
                                push_diag(mutref diags, current.module, current.at, "unknown pattern constructor in function body");
                            }
                        }
                    },
                }
            },
            None => {
            },
        }
        ref_index = ref_index + 1;
    }
    return;
}

pub fn resolve_modules(modules: ref list<str>, uses: ref list<module_use>, items: ref list<top_item>, diags: mutref list<diag>) -> resolve_summary
audit {
    intent("Resolve flat top-level item and import visibility facts for the current selfhost module graph");
    mutates(diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);

    let mut item_index = 0;
    while item_index < list_len(ref items) {
        let entry = list_get(ref items, item_index);
        match entry {
            Some(current) => {
                let mut prev_index = 0;
                while prev_index < item_index {
                    let previous = list_get(ref items, prev_index);
                    match previous {
                        Some(value) => {
                            if value.module == current.module and value.name == current.name {
                                push_diag(mutref diags, current.module, current.at, "duplicate top-level item name in one module");
                            }
                        },
                        None => {
                        },
                    }
                    prev_index = prev_index + 1;
                }
            },
            None => {
            },
        }
        item_index = item_index + 1;
    }

    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(current_use) => {
                if not list_contains(ref modules, current_use.name) {
                    push_diag(mutref diags, current_use.module, current_use.at, "imported module could not be loaded");
                } else {
                    let mut item_cursor = 0;
                    while item_cursor < list_len(ref items) {
                        let imported = list_get(ref items, item_cursor);
                        match imported {
                            Some(value) => {
                                if value.module == current_use.name and value.is_public {
                                    if module_has_local_name(ref items, current_use.module, value.name) {
                                        push_diag(mutref diags, current_use.module, current_use.at, "import collides with an existing local top-level name");
                                    } else {
                                        if imported_name_visible_before(ref uses, ref items, current_use.module, use_index, current_use.name, value.name) {
                                            push_diag(mutref diags, current_use.module, current_use.at, "duplicate imported public name");
                                        }
                                    }
                                }
                            },
                            None => {
                            },
                        }
                        item_cursor = item_cursor + 1;
                    }
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }

    return make_resolve_summary(list_len(ref modules), list_len(ref items), list_len(ref diags) - start_diag_count);
}

pub fn resolve_types(type_refs: ref list<type_ref>, uses: ref list<module_use>, items: ref list<top_item>, diags: mutref list<diag>) -> type_resolve_summary
audit {
    intent("Resolve flat type references for the current selfhost module graph");
    mutates(diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);

    let mut ref_index = 0;
    while ref_index < list_len(ref type_refs) {
        let entry = list_get(ref type_refs, ref_index);
        match entry {
            Some(current) => {
                if module_has_visible_type_name(ref items, ref uses, current.module, current.name) {
                } else {
                    if module_has_hidden_imported_type_name(ref items, ref uses, current.module, current.name) {
                        push_diag(mutref diags, current.module, current.at, "type exists in an imported module but is not `pub`");
                    } else {
                        push_diag(mutref diags, current.module, current.at, "unknown type in declaration");
                    }
                }
            },
            None => {
            },
        }
        ref_index = ref_index + 1;
    }

    return make_type_resolve_summary(list_len(ref type_refs), list_len(ref diags) - start_diag_count);
}

pub fn resolve_bodies(scopes: ref list<body_scope>, bindings: ref list<body_binding>, refs: ref list<name_ref>, uses: ref list<module_use>, items: ref list<top_item>, diags: mutref list<diag>) -> body_resolve_summary
audit {
    intent("Resolve flat function-body bindings and name references for the current selfhost graph");
    mutates(diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let mut scope_index = 0;
    while scope_index < list_len(ref scopes) {
        let entry = list_get(ref scopes, scope_index);
        match entry {
            Some(current) => {
                if current.parent_scope_id < 0 {
                    let function_scopes = copy_scopes_for_function(ref scopes, current.module, current.function_name);
                    let function_bindings = copy_bindings_for_function(ref bindings, current.module, current.function_name);
                    let function_refs = copy_refs_for_function(ref refs, current.module, current.function_name);
                    resolve_duplicate_bindings(ref function_bindings, ref items, ref uses, mutref diags);
                    resolve_function_refs(ref function_scopes, ref function_bindings, ref function_refs, ref uses, ref items, mutref diags);
                }
            },
            None => {
            },
        }
        scope_index = scope_index + 1;
    }

    return make_body_resolve_summary(count_root_function_scopes(ref scopes), list_len(ref refs), list_len(ref diags) - start_diag_count);
}

