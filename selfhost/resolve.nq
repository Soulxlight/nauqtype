fn module_has_visible_expression_name(items: ref list<top_item>, uses: ref list<module_use>, module: str, name: str) -> bool {
    if module_has_visible_function_name(ref items, ref uses, module, name) {
        return true;
    }
    if module_has_visible_variant_name(ref items, ref uses, module, name) {
        return true;
    }
    return false;
}

