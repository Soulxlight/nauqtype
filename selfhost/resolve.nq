fn imported_name_visible_before(uses: ref list<module_use>, items: ref list<top_item>, module: str, before_index: i32, imported_module: str, name: str) -> bool {
    let mut use_index = 0;
    while use_index < before_index {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and value.name != imported_module and module_exports_name(ref items, value.name, name) {
                    return true;
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return false;
}

fn is_builtin_name(name: str) -> bool {
    if name == "print_line" or name == "eprint_line" or name == "read_file" or name == "write_file" or name == "arg_count" or name == "arg_get" or name == "create_dir_all" or name == "run_process" or name == "io_err_text" {
        return true;
    }
    if name == "str_len" or name == "str_get" or name == "str_slice" or name == "str_concat" {
        return true;
    }
    if name == "list" or name == "list_push" or name == "list_len" or name == "list_get" {
        return true;
    }
    if name == "Some" or name == "None" or name == "Ok" or name == "Err" {
        return true;
    }
    return false;
}

fn is_builtin_type_name(name: str) -> bool {
    if name == "bool" or name == "int" or name == "i32" or name == "i64" {
        return true;
    }
    if name == "u32" or name == "u64" or name == "f32" or name == "f64" {
        return true;
    }
    if name == "char" or name == "str" or name == "unit" {
        return true;
    }
    if name == "option" or name == "result" or name == "list" or name == "io_err" or name == "process_result" {
        return true;
    }
    return false;
}

fn is_builtin_variant_name(name: str) -> bool {
    return name == "Some" or name == "None" or name == "Ok" or name == "Err";
}

fn module_has_visible_variant_name(items: ref list<top_item>, uses: ref list<module_use>, module: str, name: str) -> bool {
    if is_builtin_variant_name(name) {
        return true;
    }
    if module_has_local_variant_name(ref items, module, name) {
        return true;
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_variant(ref items, value.name, name) {
                    return true;
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return false;
}

fn module_has_hidden_imported_variant_name(items: ref list<top_item>, uses: ref list<module_use>, module: str, name: str) -> bool {
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_contains_variant(ref items, value.name, name) and not module_exports_variant(ref items, value.name, name) {
                    return true;
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return false;
}

