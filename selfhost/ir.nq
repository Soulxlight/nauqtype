pub fn ir_has_root_block(functions: ref list<ir_function>, blocks: ref list<ir_block>, internal_name: str) -> bool
audit {
    intent("Check whether a lowered IR function root block id points at an actual root block");
    mutates();
    effects();
}
{
    let function_id = ir_lookup_function_id(ref functions, internal_name);
    if function_id < 0 {
        return false;
    }
    let mut root_block_id = -1;
    let mut function_index = 0;
    while function_index < list_len(ref functions) {
        let function_entry = list_get(ref functions, function_index);
        match function_entry {
            Some(value) => {
                if value.id == function_id {
                    root_block_id = value.root_block_id;
                }
            },
            None => {
            },
        }
        function_index = function_index + 1;
    }
    if root_block_id < 0 {
        return false;
    }
    let mut block_index = 0;
    while block_index < list_len(ref blocks) {
        let block_entry = list_get(ref blocks, block_index);
        match block_entry {
            Some(value) => {
                if value.id == root_block_id and value.function_id == function_id and value.parent_block_id < 0 {
                    return true;
                }
            },
            None => {
            },
        }
        block_index = block_index + 1;
    }
    return false;
}

