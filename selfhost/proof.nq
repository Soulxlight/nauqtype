use files;

type norm_mapping {
    original: str,
    replacement: str,
}

type norm_token {
    text: str,
    next_index: i32,
}

type corpus_case {
    name: str,
    source_path: str,
    expected_exit_code: i32,
    expected_stdout: str,
}

fn make_norm_mapping(original: str, replacement: str) -> norm_mapping {
    return norm_mapping {
        original: original,
        replacement: replacement,
    };
}

fn make_corpus_case(name: str, source_path: str, expected_exit_code: i32, expected_stdout: str) -> corpus_case {
    return corpus_case {
        name: name,
        source_path: source_path,
        expected_exit_code: expected_exit_code,
        expected_stdout: expected_stdout,
    };
}

fn make_norm_token(text: str, next_index: i32) -> norm_token {
    return norm_token {
        text: text,
        next_index: next_index,
    };
}

fn no_norm_token() -> norm_token {
    return make_norm_token("", -1);
}

fn concat3(a: str, b: str, c: str) -> str {
    return str_concat(str_concat(a, b), c);
}

fn concat4(a: str, b: str, c: str, d: str) -> str {
    return str_concat(str_concat(a, b), str_concat(c, d));
}

fn digit_text(value: i32) -> str {
    if value == 0 {
        return "0";
    }
    if value == 1 {
        return "1";
    }
    if value == 2 {
        return "2";
    }
    if value == 3 {
        return "3";
    }
    if value == 4 {
        return "4";
    }
    if value == 5 {
        return "5";
    }
    if value == 6 {
        return "6";
    }
    if value == 7 {
        return "7";
    }
    if value == 8 {
        return "8";
    }
    return "9";
}

fn i32_to_str(value: i32) -> str {
    if value == 0 {
        return "0";
    }
    let mut remaining = value;
    let mut negative = false;
    if remaining < 0 {
        negative = true;
        remaining = 0 - remaining;
    }
    let mut reversed: list<str> = list();
    while remaining > 0 {
        let digit = remaining - ((remaining / 10) * 10);
        list_push(mutref reversed, digit_text(digit));
        remaining = remaining / 10;
    }
    let mut text = "";
    if negative {
        text = "-";
    }
    let mut index = list_len(ref reversed) - 1;
    while index >= 0 {
        let entry = list_get(ref reversed, index);
        match entry {
            Some(value_text) => {
                text = str_concat(text, value_text);
            },
            None => {
            },
        }
        index = index - 1;
    }
    return text;
}

fn slice_text(text: str, start: i32, end: i32) -> str {
    let entry = str_slice(text, start, end);
    match entry {
        Some(value) => {
            return value;
        },
        None => {
            return "";
        },
    }
}

fn char_at(text: str, index: i32) -> i32 {
    let entry = str_get(text, index);
    match entry {
        Some(value) => {
            return value;
        },
        None => {
            return -1;
        },
    }
}

fn is_ws(ch: i32) -> bool {
    return ch == 32 or ch == 9 or ch == 10 or ch == 13;
}

fn is_digit(ch: i32) -> bool {
    return ch >= 48 and ch <= 57;
}

fn is_ident_char(ch: i32) -> bool {
    if ch >= 48 and ch <= 57 {
        return true;
    }
    if ch >= 65 and ch <= 90 {
        return true;
    }
    if ch >= 97 and ch <= 122 {
        return true;
    }
    return ch == 95;
}

fn starts_with_at(text: str, index: i32, pattern: str) -> bool {
    if index < 0 {
        return false;
    }
    if index + str_len(pattern) > str_len(text) {
        return false;
    }
    let mut offset = 0;
    while offset < str_len(pattern) {
        if char_at(text, index + offset) != char_at(pattern, offset) {
            return false;
        }
        offset = offset + 1;
    }
    return true;
}

fn text_contains(text: str, pattern: str) -> bool {
    if pattern == "" {
        return true;
    }
    let text_len = str_len(text);
    let pattern_len = str_len(pattern);
    if pattern_len > text_len {
        return false;
    }
    let mut start = 0;
    while start <= text_len - pattern_len {
        if starts_with_at(text, start, pattern) {
            return true;
        }
        start = start + 1;
    }
    return false;
}

fn trim_slice(text: str, start: i32, end: i32) -> str {
    let mut left = start;
    let mut right = end;
    while left < right and is_ws(char_at(text, left)) {
        left = left + 1;
    }
    while right > left and is_ws(char_at(text, right - 1)) {
        right = right - 1;
    }
    return slice_text(text, left, right);
}

fn mapping_lookup(mappings: ref list<norm_mapping>, original: str) -> option<str> {
    let mut index = 0;
    while index < list_len(ref mappings) {
        let entry = list_get(ref mappings, index);
        match entry {
            Some(value) => {
                if value.original == original {
                    return Some(value.replacement);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return None;
}

fn mapping_get_or_add(mappings: mutref list<norm_mapping>, original: str) -> str {
    let found = mapping_lookup(ref mappings, original);
    match found {
        Some(value) => {
            return value;
        },
        None => {
            let replacement = i32_to_str(list_len(ref mappings) + 1);
            list_push(mutref mappings, make_norm_mapping(original, replacement));
            return replacement;
        },
    }
}

fn scan_digits(text: str, index: i32) -> i32 {
    let mut cursor = index;
    while cursor < str_len(text) and is_digit(char_at(text, cursor)) {
        cursor = cursor + 1;
    }
    return cursor;
}

fn scan_ident(text: str, index: i32) -> i32 {
    let mut cursor = index;
    while cursor < str_len(text) and is_ident_char(char_at(text, cursor)) {
        cursor = cursor + 1;
    }
    return cursor;
}

fn normalize_binding_at(line: str, index: i32, mappings: mutref list<norm_mapping>) -> norm_token {
    if not starts_with_at(line, index, "nqv_") {
        return no_norm_token();
    }
    let digit_start = index + 4;
    let digit_end = scan_digits(line, digit_start);
    if digit_end == digit_start {
        return no_norm_token();
    }
    if digit_end >= str_len(line) or char_at(line, digit_end) != 95 {
        return no_norm_token();
    }
    let name_start = digit_end + 1;
    let name_end = scan_ident(line, name_start);
    if name_end == name_start {
        return no_norm_token();
    }
    let original = slice_text(line, digit_start, digit_end);
    let replacement = mapping_get_or_add(mutref mappings, original);
    let name = slice_text(line, name_start, name_end);
    return make_norm_token(concat4("nqv_", replacement, "_", name), name_end);
}

fn normalize_tmp_at(line: str, index: i32, mappings: mutref list<norm_mapping>) -> norm_token {
    if not starts_with_at(line, index, "nq_tmp_") {
        return no_norm_token();
    }
    let digit_start = index + 7;
    let digit_end = scan_digits(line, digit_start);
    if digit_end == digit_start {
        return no_norm_token();
    }
    let original = slice_text(line, digit_start, digit_end);
    let replacement = mapping_get_or_add(mutref mappings, original);
    return make_norm_token(str_concat("nq_tmp_", replacement), digit_end);
}

fn normalize_line(line: str, binding_mappings: mutref list<norm_mapping>, tmp_mappings: mutref list<norm_mapping>) -> str {
    let mut out = "";
    let mut index = 0;
    while index < str_len(line) {
        let mut matched = false;
        let binding = normalize_binding_at(line, index, mutref binding_mappings);
        if binding.next_index >= 0 {
            out = str_concat(out, binding.text);
            index = binding.next_index;
            matched = true;
        }
        if not matched {
            let tmp = normalize_tmp_at(line, index, mutref tmp_mappings);
            if tmp.next_index >= 0 {
                out = str_concat(out, tmp.text);
                index = tmp.next_index;
                matched = true;
            }
        }
        if not matched {
            out = str_concat(out, slice_text(line, index, index + 1));
            index = index + 1;
        }
    }
    return out;
}

fn normalize_structural_c(text: str) -> str {
    let mut binding_mappings: list<norm_mapping> = list();
    let mut tmp_mappings: list<norm_mapping> = list();
    let mut out = "";
    let mut start = 0;
    let mut index = 0;
    while index < str_len(text) {
        if char_at(text, index) == 10 {
            let line = trim_slice(text, start, index);
            if line != "" {
                let normalized = normalize_line(line, mutref binding_mappings, mutref tmp_mappings);
                if out == "" {
                    out = normalized;
                } else {
                    out = concat3(out, "\n", normalized);
                }
            }
            start = index + 1;
        }
        index = index + 1;
    }
    if start < str_len(text) {
        let line = trim_slice(text, start, str_len(text));
        if line != "" {
            let normalized = normalize_line(line, mutref binding_mappings, mutref tmp_mappings);
            if out == "" {
                out = normalized;
            } else {
                out = concat3(out, "\n", normalized);
            }
        }
    }
    return out;
}

fn normalize_newlines(text: str) -> str {
    let mut out = "";
    let mut index = 0;
    while index < str_len(text) {
        let ch = char_at(text, index);
        if ch != 13 {
            out = str_concat(out, slice_text(text, index, index + 1));
        }
        index = index + 1;
    }
    return out;
}

fn output_matches(actual: str, expected: str) -> bool {
    return normalize_newlines(actual) == normalize_newlines(expected);
}

fn copy_file_text(source_path: str, dest_path: str) -> result<unit, io_err> {
    let ensure_result = ensure_parent_dir(dest_path);
    match ensure_result {
        Ok(_) => {
        },
        Err(err) => {
            return Err(err);
        },
    }
    let data = read_file(source_path);
    match data {
        Ok(text) => {
            return write_file(dest_path, text);
        },
        Err(err) => {
            return Err(err);
        },
    }
}

fn copy_selfhost_module(proof_dir: str, module_name: str) -> result<unit, io_err> {
    let file_name = str_concat(module_name, ".nq");
    return copy_file_text(join_path("selfhost", file_name), join_path(proof_dir, file_name));
}

fn push_selfhost_modules(modules: mutref list<str>) -> unit {
    list_push(mutref modules, "ast");
    list_push(mutref modules, "borrow");
    list_push(mutref modules, "c_emit");
    list_push(mutref modules, "diag");
    list_push(mutref modules, "facts");
    list_push(mutref modules, "files");
    list_push(mutref modules, "handoff");
    list_push(mutref modules, "ir");
    list_push(mutref modules, "lexer");
    list_push(mutref modules, "main");
    list_push(mutref modules, "parser");
    list_push(mutref modules, "proof");
    list_push(mutref modules, "resolve");
    list_push(mutref modules, "review");
    list_push(mutref modules, "source");
    list_push(mutref modules, "token");
    list_push(mutref modules, "typecheck");
    return;
}

fn copy_selfhost_workspace(proof_dir: str) -> result<unit, io_err> {
    let dir_result = create_dir_all(proof_dir);
    match dir_result {
        Ok(_) => {
        },
        Err(err) => {
            return Err(err);
        },
    }
    let mut modules: list<str> = list();
    push_selfhost_modules(mutref modules);
    let mut index = 0;
    while index < list_len(ref modules) {
        let entry = list_get(ref modules, index);
        match entry {
            Some(name) => {
                let copied = copy_selfhost_module(proof_dir, name);
                match copied {
                    Ok(_) => {
                    },
                    Err(err) => {
                        return Err(err);
                    },
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return create_dir_all(proof_dir);
}

fn emit_process_output(result: process_result) -> unit {
    if result.stdout != "" {
        print_line(result.stdout);
    }
    if result.stderr != "" {
        eprint_line(result.stderr);
    }
    return;
}

fn stage1_ok_output(text: str) -> bool {
    if text == "stage1 front-end ok\n" {
        return true;
    }
    let expected = "stage1 front-end ok";
    if str_len(text) == str_len(expected) + 2 {
        if slice_text(text, 0, str_len(expected)) == expected and char_at(text, str_len(expected)) == 13 and char_at(text, str_len(expected) + 1) == 10 {
            return true;
        }
    }
    return false;
}

fn run_driver_build(driver_path: str, entry_path: str) -> result<process_result, io_err> {
    let mut args: list<str> = list();
    list_push(mutref args, "build");
    list_push(mutref args, entry_path);
    return run_process(driver_path, ref args, ".");
}

fn run_driver_emit_c(driver_path: str, entry_path: str, output_path: str) -> result<process_result, io_err> {
    let mut args: list<str> = list();
    list_push(mutref args, "emit-c");
    list_push(mutref args, entry_path);
    list_push(mutref args, "-o");
    list_push(mutref args, output_path);
    return run_process(driver_path, ref args, ".");
}

fn run_driver_run(driver_path: str, entry_path: str) -> result<process_result, io_err> {
    let mut args: list<str> = list();
    list_push(mutref args, "run");
    list_push(mutref args, entry_path);
    return run_process(driver_path, ref args, ".");
}

fn run_stage2(stage2_path: str, proof_dir: str) -> result<process_result, io_err> {
    let args: list<str> = list();
    return run_process(stage2_path, ref args, proof_dir);
}

fn default_build_c_path(source_path: str) -> str {
    return join_path(join_path(path_dir(source_path), "build"), str_concat(path_stem(source_path), ".c"));
}

fn corpus_emit_c_path(case_name: str) -> str {
    return join_path(join_path("build/corpus", case_name), "emit.c");
}

fn has_stage1_failure_text(status: process_result) -> bool {
    if text_contains(status.stdout, "stage1 limitation") or text_contains(status.stderr, "stage1 limitation") {
        return true;
    }
    if text_contains(status.stdout, "stage1 c error") or text_contains(status.stderr, "stage1 c error") {
        return true;
    }
    return false;
}

fn driver_step_ok(step_name: str, status: process_result) -> bool {
    if status.exit_code != 0 {
        eprint_line(str_concat(step_name, " failed"));
        emit_process_output(status);
        return false;
    }
    if has_stage1_failure_text(status) {
        eprint_line(str_concat(step_name, " reported a stage1 failure"));
        emit_process_output(status);
        return false;
    }
    if status.stdout != "" or status.stderr != "" {
        eprint_line(str_concat(step_name, " produced unexpected output"));
        emit_process_output(status);
        return false;
    }
    return true;
}

fn read_text_or_report(path: str, label: str, output: mutref str) -> bool {
    let data = read_file(path);
    match data {
        Ok(text) => {
            output = text;
            return true;
        },
        Err(err) => {
            eprint_line(str_concat(label, str_concat(": ", io_err_text(err))));
            return false;
        },
    }
}

fn push_locked_example_corpus(cases: mutref list<corpus_case>) -> unit {
    list_push(mutref cases, make_corpus_case("enum_match", "examples/enum_match.nq", 1, ""));
    list_push(mutref cases, make_corpus_case("fallible_function", "examples/fallible_function.nq", 7, ""));
    list_push(mutref cases, make_corpus_case("fibonacci", "examples/fibonacci.nq", 55, ""));
    list_push(mutref cases, make_corpus_case("hello", "examples/hello.nq", 0, "Hello, Nauqtype!\n"));
    list_push(mutref cases, make_corpus_case("list_sum", "examples/list_sum.nq", 42, ""));
    list_push(mutref cases, make_corpus_case("multi_file_main", "examples/multi_file_main.nq", 7, ""));
    list_push(mutref cases, make_corpus_case("mutate_counter", "examples/mutate_counter.nq", 42, ""));
    list_push(mutref cases, make_corpus_case("read_file_len", "examples/read_file_len.nq", 6, ""));
    list_push(mutref cases, make_corpus_case("result_handling", "examples/result_handling.nq", 0, ""));
    list_push(mutref cases, make_corpus_case("review_contracts", "examples/review_contracts.nq", 42, "Hello, contracts!\n"));
    list_push(mutref cases, make_corpus_case("simple_add", "examples/simple_add.nq", 42, ""));
    list_push(mutref cases, make_corpus_case("user_record", "examples/user_record.nq", 32, ""));
    list_push(mutref cases, make_corpus_case("while_counter", "examples/while_counter.nq", 5, ""));
    return;
}

fn run_corpus_case(driver_path: str, entry: corpus_case) -> bool {
    let emit_path = corpus_emit_c_path(entry.name);
    let emit_result = run_driver_emit_c(driver_path, entry.source_path, emit_path);
    match emit_result {
        Ok(status) => {
            if not driver_step_ok(str_concat("emit-c ", entry.name), status) {
                return false;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return false;
        },
    }

    let mut emit_c = "";
    if not read_text_or_report(emit_path, str_concat("failed to read emitted C for ", entry.name), mutref emit_c) {
        return false;
    }

    let build_result = run_driver_build(driver_path, entry.source_path);
    match build_result {
        Ok(status) => {
            if not driver_step_ok(str_concat("build ", entry.name), status) {
                return false;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return false;
        },
    }

    let build_c_path = default_build_c_path(entry.source_path);
    let mut build_c = "";
    if not read_text_or_report(build_c_path, str_concat("failed to read build C for ", entry.name), mutref build_c) {
        return false;
    }
    if normalize_structural_c(emit_c) != normalize_structural_c(build_c) {
        eprint_line(str_concat("corpus proof failed: emit/build C changed for ", entry.name));
        return false;
    }

    let run_result = run_driver_run(driver_path, entry.source_path);
    match run_result {
        Ok(status) => {
            if status.exit_code != entry.expected_exit_code {
                eprint_line(str_concat("corpus proof failed: unexpected exit code for ", entry.name));
                emit_process_output(status);
                return false;
            }
            if not output_matches(status.stdout, entry.expected_stdout) or status.stderr != "" {
                eprint_line(str_concat("corpus proof failed: unexpected stdout/stderr for ", entry.name));
                emit_process_output(status);
                return false;
            }
            if has_stage1_failure_text(status) {
                eprint_line(str_concat("corpus proof failed: stage1 diagnostic text for ", entry.name));
                emit_process_output(status);
                return false;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return false;
        },
    }

    let mut run_c = "";
    if not read_text_or_report(build_c_path, str_concat("failed to read run C for ", entry.name), mutref run_c) {
        return false;
    }
    if normalize_structural_c(emit_c) != normalize_structural_c(run_c) {
        eprint_line(str_concat("corpus proof failed: emit/run C changed for ", entry.name));
        return false;
    }

    return true;
}

pub fn run_example_corpus(driver_path: str) -> i32
audit {
    intent("Run the stage1-owned locked example corpus gate");
    mutates();
    effects(print);
}
{
    let mut cases: list<corpus_case> = list();
    push_locked_example_corpus(mutref cases);
    let mut index = 0;
    while index < list_len(ref cases) {
        let entry = list_get(ref cases, index);
        match entry {
            Some(value) => {
                if not run_corpus_case(driver_path, value) {
                    return 1;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    print_line("example corpus ok");
    return 0;
}

pub fn run_selfhost_proof(driver_path: str) -> i32
audit {
    intent("Run the stage1-owned copied-selfhost proof gate");
    mutates();
    effects(print);
}
{
    let proof_dir = "build/proof/selfhost";
    let copied = copy_selfhost_workspace(proof_dir);
    match copied {
        Ok(_) => {
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    let entry_path = join_path(proof_dir, "main.nq");
    let stage1_result = run_driver_build(driver_path, entry_path);
    match stage1_result {
        Ok(status) => {
            if status.exit_code != 0 {
                emit_process_output(status);
                return status.exit_code;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    let c_path = join_path(join_path(proof_dir, "build"), "main.c");
    let stage1_c_result = read_file(c_path);
    let mut stage1_c = "";
    match stage1_c_result {
        Ok(text) => {
            stage1_c = text;
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    let stage2_path = join_path(join_path(proof_dir, "build"), "main.exe");
    let stage2_result = run_stage2(stage2_path, proof_dir);
    match stage2_result {
        Ok(status) => {
            if status.exit_code != 0 {
                emit_process_output(status);
                return status.exit_code;
            }
            if not stage1_ok_output(status.stdout) or status.stderr != "" {
                emit_process_output(status);
                eprint_line("selfhost proof failed: stage2 smoke output changed");
                return 1;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    let stage2_c_result = read_file(c_path);
    match stage2_c_result {
        Ok(stage2_c) => {
            let normalized_stage1 = normalize_structural_c(stage1_c);
            let normalized_stage2 = normalize_structural_c(stage2_c);
            if normalized_stage1 != normalized_stage2 {
                eprint_line("selfhost proof failed: normalized structural C changed between stage1 and stage2");
                return 1;
            }
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }

    print_line("selfhost proof ok");
    return 0;
}

pub fn run_all_proofs(driver_path: str) -> i32
audit {
    intent("Run the stage1-owned transition proof and corpus gates");
    mutates();
    effects(print);
}
{
    let selfhost_result = run_selfhost_proof(driver_path);
    if selfhost_result != 0 {
        return selfhost_result;
    }
    let corpus_result = run_example_corpus(driver_path);
    if corpus_result != 0 {
        return corpus_result;
    }
    print_line("nauqtype proof ok");
    return 0;
}
