pub enum top_item_kind {
    item_fn,
    item_type,
    item_enum,
    item_variant,
}

pub type top_item {
    module: str,
    name: str,
    kind: top_item_kind,
    is_public: bool,
    at: i32,
}

pub fn make_top_item(module: str, name: str, kind: top_item_kind, is_public: bool, at: i32) -> top_item
audit {
    intent("Build a flat top-level item summary record");
    mutates();
    effects();
}
{
    return top_item {
        module: module,
        name: name,
        kind: kind,
        is_public: is_public,
        at: at,
    };
}

pub type module_use {
    module: str,
