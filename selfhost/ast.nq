pub enum name_ref_kind {
    ref_value,
    ref_call,
    ref_assign_target,
    ref_borrow_target,
}

pub type name_ref {
    module: str,
    function_name: str,
    scope_id: i32,
    name: str,
    at: i32,
    kind: name_ref_kind,
}

pub fn make_name_ref(module: str, function_name: str, scope_id: i32, name: str, at: i32, kind: name_ref_kind) -> name_ref
audit {
    intent("Build a flat name-reference record for selfhost resolver work");
    mutates();
    effects();
}
{
    return name_ref {
        module: module,
        function_name: function_name,
        scope_id: scope_id,
        name: name,
        at: at,
        kind: kind,
    };
}

