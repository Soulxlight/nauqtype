}

pub type parse_summary {
    item_count: i32,
    use_count: i32,
    diag_count: i32,
}

pub fn make_parse_summary(item_count: i32, use_count: i32, diag_count: i32) -> parse_summary
audit {
    intent("Build a shallow parse summary record");
    mutates();
    effects();
}
{
    return parse_summary {
        item_count: item_count,
        use_count: use_count,
        diag_count: diag_count,
    };
}

pub type resolve_summary {
    module_count: i32,
