use diag;
use handoff;

pub type borrow_summary {
    function_count: i32,
    diag_count: i32,
}

pub fn make_borrow_summary(function_count: i32, diag_count: i32) -> borrow_summary
audit {
    intent("Build a stage1 borrow-check summary record");
    mutates();
    effects();
}
{
    return borrow_summary {
        function_count: function_count,
        diag_count: diag_count,
    };
}

type move_binding_state {
    binding_id: i32,
    moved: bool,
}

type call_borrow_state {
    binding_id: i32,
    kind: str,
}

fn push_diag(diags: mutref list<diag>, file: str, at: i32, message: str) -> unit {
    list_push(mutref diags, make_diag(file, at, message));
    return;
}

fn push_borrow_limitation(diags: mutref list<diag>, file: str, at: i32, detail: str) -> unit {
    let prefix = "stage1 limitation: checked borrow pass ";
    push_diag(mutref diags, file, at, str_concat(prefix, detail));
    return;
}

fn list_contains_i32(items: ref list<i32>, target: i32) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value == target {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn list_contains_str(items: ref list<str>, target: str) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value == target {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn clone_string_list(items: ref list<str>) -> list<str> {
    let mut cloned: list<str> = list();
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                list_push(mutref cloned, value);
            },
            None => {
            },
        }
        index = index + 1;
    }
    return cloned;
}

fn clone_move_state(items: ref list<move_binding_state>) -> list<move_binding_state> {
    let mut cloned: list<move_binding_state> = list();
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                list_push(mutref cloned, value);
            },
            None => {
            },
        }
        index = index + 1;
    }
    return cloned;
}

fn replace_move_state_entry(items: ref list<move_binding_state>, target_index: i32, replacement: move_binding_state) -> list<move_binding_state> {
    let mut rebuilt: list<move_binding_state> = list();
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if index == target_index {
                    list_push(mutref rebuilt, replacement);
                } else {
                    list_push(mutref rebuilt, value);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return rebuilt;
}

fn replace_call_borrow_state_entry(items: ref list<call_borrow_state>, target_index: i32, replacement: call_borrow_state) -> list<call_borrow_state> {
    let mut rebuilt: list<call_borrow_state> = list();
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if index == target_index {
                    list_push(mutref rebuilt, replacement);
                } else {
                    list_push(mutref rebuilt, value);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return rebuilt;
}

