use ast;
use diag;
use lexer;
use parser;
use resolve;

fn main() -> i32 {
    let mut modules: list<str> = list();
    let mut items: list<top_item> = list();
    let mut uses: list<module_use> = list();
    let mut scopes: list<body_scope> = list();
    let mut bindings: list<body_binding> = list();
    let mut refs: list<name_ref> = list();
    let mut type_refs: list<type_ref> = list();
    let mut diags: list<diag> = list();

    let a_tokens = lex("pub fn helper() -> i32 { return 1; }");
    let b_tokens = lex("pub fn helper() -> i32 { return 2; }");
    let main_tokens = lex("use a; use b; fn main() -> i32 { return 0; }");

    list_push(mutref modules, "a");
    list_push(mutref modules, "b");
    list_push(mutref modules, "main");

    parse_file("a", ref a_tokens, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref diags);
    parse_file("b", ref b_tokens, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref diags);
    parse_file("main", ref main_tokens, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref diags);

    resolve_modules(ref modules, ref uses, ref items, mutref diags);
    if list_len(ref diags) == 0 {
        return 1;
    }
    return 0;
}

