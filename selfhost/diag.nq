pub type diag {
    file: str,
    at: i32,
    message: str,
}

pub fn make_diag(file: str, at: i32, message: str) -> diag
audit {
    intent("Build an immutable diagnostic record");
    mutates();
    effects();
}
{
    return diag {
        file: file,
        at: at,
        message: message,
    };
}

pub fn emit_diag(entry: diag) -> unit
audit {
    intent("Print a simple deterministic diagnostic message");
    mutates();
    effects(print);
}
{
    print_line(entry.file);
    print_line(entry.message);
    return;
}
