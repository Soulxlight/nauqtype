use ast;
use diag;
use lexer;
use parser;
use resolve;
use typecheck;

fn main() -> i32 {
    let mut modules: list<str> = list();
    let mut items: list<top_item> = list();
    let mut uses: list<module_use> = list();
    let mut scopes: list<body_scope> = list();
    let mut bindings: list<body_binding> = list();
    let mut refs: list<name_ref> = list();
    let mut type_refs: list<type_ref> = list();
    let mut function_facts: list<function_fact> = list();
    let mut variant_facts: list<variant_fact> = list();
    let mut call_facts: list<call_fact> = list();
    let mut pattern_facts: list<pattern_ctor_fact> = list();
    let mut typed_bindings: list<typed_binding_fact> = list();
    let mut field_facts: list<field_fact> = list();
    let mut local_inits: list<local_init_fact> = list();
    let mut return_facts: list<return_expr_fact> = list();
    let mut condition_facts: list<condition_fact> = list();
    let mut assignment_facts: list<assignment_fact> = list();
    let mut diags: list<diag> = list();

    let tokens = lex("type pair { left: i32, right: i32, } fn pick_right(pair_value: pair) -> i32 { let left_value = pair_value.left; return pair_value.right; } fn main() -> i32 { return pick_right(pair { left: 1, right: 2, }); }");

    list_push(mutref modules, "main");

    parse_file("main", ref tokens, mutref items, mutref uses, mutref scopes, mutref bindings, mutref refs, mutref type_refs, mutref diags);
    collect_typecheck_facts("main", ref tokens, mutref function_facts, mutref variant_facts, mutref call_facts, mutref pattern_facts, mutref diags);
    let collect_summary = collect_value_type_facts("main", ref tokens, mutref typed_bindings, mutref field_facts, mutref local_inits, mutref return_facts, mutref condition_facts, mutref assignment_facts, mutref diags);

    resolve_modules(ref modules, ref uses, ref items, mutref diags);
    resolve_types(ref type_refs, ref uses, ref items, mutref diags);
    resolve_bodies(ref scopes, ref bindings, ref refs, ref uses, ref items, mutref diags);
    typecheck_modules(ref function_facts, ref variant_facts, ref call_facts, ref pattern_facts, ref uses, ref items, mutref diags);
    let summary = typecheck_value_facts(ref function_facts, ref variant_facts, ref scopes, ref typed_bindings, ref field_facts, ref local_inits, ref return_facts, ref condition_facts, ref assignment_facts, ref uses, ref items, mutref diags);

    if collect_summary.diag_count != 0 {
        return 1;
    }
    if collect_summary.typed_binding_count != 1 {
        return 2;
    }
    if collect_summary.local_count != 1 {
        return 3;
    }
    if collect_summary.return_count != 2 {
        return 4;
    }
    if list_len(ref field_facts) != 2 {
        return 5;
    }
    if summary.diag_count != 0 {
        return 6;
    }
    if summary.typed_binding_count != 2 {
        return 7;
    }
    return 0;
}
