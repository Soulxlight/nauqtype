        }
        while arg_start < arg_end_limit {
            let segment_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
            let mut arg_expected_ctx = empty_expected_type_ctx();
            match target_kind {
                checked_target_function => {
                    arg_expected_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, target_origin, head.text, arg_index);
                },
                checked_target_builtin_function => {
                    arg_expected_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module_name, head.text, arg_index);
                },
                checked_target_constructor => {
                    arg_expected_ctx = visible_variant_payload_ctx(ref variant_payloads, ref uses, ref items, module_name, head.text, arg_index);
                },
                checked_target_builtin_constructor => {
                    arg_expected_ctx = build_expected_variant_payload_ctx(head.text, expected_ctx, arg_index);
                },
                _ => {
                },
            }
            let child_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, module_name, function_name, scope_id, ref tokens, segment_value_start(ref tokens, arg_start, segment_end), segment_end, head.start, arg_expected_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
            if child_id < 0 {
                return consume_handoff_limitation_detail(mutref diags, module_name, head.start, str_concat("missing exported call argument expression for call: ", head.text));
            }
            push_expr_child(mutref expr_children, expr_id, arg_index, child_id);
            arg_index = arg_index + 1;
            arg_start = segment_end + 1;
        }
        return expr_id;
    }

    if span_is_struct_expr(ref tokens, expr_start, expr_end) {
        let type_token = token_at(ref tokens, expr_start);
        let type_origin = visible_type_origin_module(ref uses, ref items, module_name, type_token.text);
        let expr_id = push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_struct, exported_ctx, false, false, -1, type_token.text, checked_target_none, "", type_origin, type_token.text, "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        let mut field_start = expr_start + 2;
        let field_end_limit = expr_end - 1;
        let mut field_index = 0;
        while field_start < field_end_limit {
            let segment_end = next_top_level_comma(ref tokens, field_start, field_end_limit);
            let colon_index = find_top_level_colon(ref tokens, field_start, segment_end);
            if colon_index >= 0 {
                let field_token = token_at(ref tokens, field_start);
                if token_is_ident(field_token) {
                    let field_expected_ctx = lookup_field_ctx(ref field_facts, type_origin, type_token.text, field_token.text);
                    let value_expr_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, module_name, function_name, scope_id, ref tokens, colon_index + 1, segment_end, field_token.start, field_expected_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
                    if value_expr_id < 0 {
                        return consume_handoff_limitation_detail(mutref diags, module_name, field_token.start, str_concat("missing exported struct field value expression: ", field_token.text));
                    }
                    list_push(mutref struct_fields, checked_struct_field_init {
                        expr_id: expr_id,
                        index: field_index,
                        field_name: field_token.text,
                        field_owner_module: type_origin,
                        field_owner_type: type_token.text,
                        value_expr_id: value_expr_id,
                    });
                }
            }
            field_index = field_index + 1;
            field_start = segment_end + 1;
        }
        return expr_id;
    }

    match current.kind {
        tk_kw_true => {
            return build_literal_expr(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_bool, "bool", "true", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        },
        tk_kw_false => {
            return build_literal_expr(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_bool, "bool", "false", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        },
        tk_int_lit => {
            return build_literal_expr(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_i32, exported_ctx.head, current.text, ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        },
        tk_string_lit => {
            return build_literal_expr(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_str, "str", current.text, ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        },
        tk_ident => {
            if expr_start + 1 == expr_end {
                let binding_id = visible_binding_id(ref bindings, ref scopes, module_name, function_name, scope_id, current.text, current.start + 1);
                if binding_id >= 0 {
                    return push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_name, exported_ctx, lookup_binding_is_borrow(ref bindings, binding_id), lookup_binding_borrow_mutable(ref bindings, binding_id), binding_id, current.text, checked_target_none, "", "", "", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
                }
                let const_ctx = visible_const_ctx(ref consts, ref uses, ref items, module_name, current.text);
                if const_ctx.head != "" {
                    let origin = visible_const_origin_module(ref uses, ref items, module_name, current.text);
                    return push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_const, const_ctx, false, false, -1, current.text, checked_target_const, origin, "", "", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
                }
                let zero_enum = visible_variant_enum_name(ref variants, ref uses, ref items, module_name, current.text);
                if zero_enum != "" {
                    let origin = visible_variant_origin_module(ref variants, ref uses, ref items, module_name, current.text);
                    let mut target_kind = checked_target_constructor;
                    if origin == "__builtin__" {
                        target_kind = checked_target_builtin_constructor;
                    }
                    return push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_zero_variant, exported_ctx, false, false, -1, current.text, target_kind, origin, "", "", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
                }
                return consume_handoff_limitation_detail(mutref diags, module_name, current.start, str_concat("missing resolved binding id for checked name expression: ", current.text));
            }
        },
        _ => {
        },
    }

    return consume_handoff_limitation_detail(mutref diags, module_name, at, "unsupported checked handoff expression shape");
}

fn append_modules_from_sources(sources: ref list<source_file>, modules: mutref list<checked_module>) -> unit {
    let mut index = 0;
    while index < list_len(ref sources) {
        let entry = list_get(ref sources, index);
        match entry {
            Some(value) => {
                list_push(mutref modules, checked_module {
                    id: list_len(ref modules) + 1,
                    name: value.name,
                });
            },
            None => {
            },
        }
        index = index + 1;
    }
    return;
}

fn append_functions(function_facts: ref list<function_fact>, scopes: ref list<body_scope>, modules: ref list<checked_module>, uses: ref list<module_use>, items: ref list<top_item>, type_shapes: mutref list<checked_type_shape>, functions: mutref list<checked_function>, diags: mutref list<diag>) -> unit {
    let mut index = 0;
    while index < list_len(ref function_facts) {
        let entry = list_get(ref function_facts, index);
        match entry {
            Some(value) => {
                let function_id = list_len(ref functions) + 1;
                let module_id = lookup_module_id(ref modules, value.module);
                let root_scope_id = lookup_root_scope_id(ref scopes, value.module, value.name);
                let return_type_id = intern_checked_type_id(value.return_name, value.return_arg1_name, value.return_arg2_name, value.return_is_borrow, value.return_borrow_mutable, value.module, ref uses, ref items, mutref type_shapes, mutref diags, value.at);
                list_push(mutref functions, checked_function {
                    id: function_id,
                    module_id: module_id,
                    module_name: value.module,
                    name: value.name,
                    at: value.at,
                    root_scope_id: root_scope_id,
                    return_name: value.return_name,
                    return_arg1_name: value.return_arg1_name,
                    return_arg2_name: value.return_arg2_name,
                    return_is_borrow: value.return_is_borrow,
                    return_borrow_mutable: value.return_borrow_mutable,
                    return_type_id: return_type_id,
                });
            },
            None => {
            },
        }
        index = index + 1;
    }
    return;
}

fn append_type_decls(items: ref list<top_item>, uses: ref list<module_use>, field_facts: ref list<field_fact>, modules: ref list<checked_module>, type_shapes: mutref list<checked_type_shape>, type_decls: mutref list<checked_type_decl>, field_decls: mutref list<checked_field_decl>, diags: mutref list<diag>) -> unit {
    let mut item_index = 0;
    while item_index < list_len(ref items) {
        let item_entry = list_get(ref items, item_index);
        match item_entry {
            Some(value) => {
                match value.kind {
                    item_type => {
                        let type_id = list_len(ref type_decls) + 1;
                        list_push(mutref type_decls, checked_type_decl {
                            id: type_id,
                            module_id: lookup_module_id(ref modules, value.module),
                            module_name: value.module,
                            name: value.name,
                            at: value.at,
                        });
                        let mut field_index = 0;
                        let mut ordinal = 0;
                        while field_index < list_len(ref field_facts) {
                            let field_entry = list_get(ref field_facts, field_index);
                            match field_entry {
                                Some(field) => {
                                    if field.module == value.module and field.type_name == value.name {
                                        let field_type_id = intern_checked_type_id(field.field_type_name, field.field_type_arg1_name, field.field_type_arg2_name, field.field_is_borrow, field.field_borrow_mutable, field.module, ref uses, ref items, mutref type_shapes, mutref diags, field.at);
                                        list_push(mutref field_decls, checked_field_decl {
                                            type_id: type_id,
                                            index: ordinal,
                                            module_name: field.module,
                                            type_name: field.type_name,
                                            name: field.name,
                                            at: field.at,
                                            field_type_name: field.field_type_name,
                                            field_type_arg1_name: field.field_type_arg1_name,
                                            field_type_arg2_name: field.field_type_arg2_name,
                                            field_is_borrow: field.field_is_borrow,
                                            field_borrow_mutable: field.field_borrow_mutable,
                                            field_type_id: field_type_id,
                                        });
                                        ordinal = ordinal + 1;
                                    }
                                },
                                None => {
                                },
                            }
                            field_index = field_index + 1;
                        }
                    },
                    _ => {
                    },
                }
            },
            None => {
            },
        }
        item_index = item_index + 1;
    }
    return;
}

fn append_enum_decls(variant_facts: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, uses: ref list<module_use>, items: ref list<top_item>, modules: ref list<checked_module>, type_shapes: mutref list<checked_type_shape>, enum_decls: mutref list<checked_enum_decl>, variant_decls: mutref list<checked_variant_decl>, variant_payload_decls: mutref list<checked_variant_payload_decl>, diags: mutref list<diag>) -> unit {
    let mut variant_index = 0;
    while variant_index < list_len(ref variant_facts) {
        let variant_entry = list_get(ref variant_facts, variant_index);
        match variant_entry {
            Some(value) => {
                let mut enum_id = lookup_enum_decl_id(ref enum_decls, value.module, value.enum_name);
                if enum_id < 0 {
                    enum_id = list_len(ref enum_decls) + 1;
                    list_push(mutref enum_decls, checked_enum_decl {
                        id: enum_id,
                        module_id: lookup_module_id(ref modules, value.module),
                        module_name: value.module,
                        name: value.enum_name,
                        at: value.at,
                    });
                }
                let variant_id = list_len(ref variant_decls) + 1;
                list_push(mutref variant_decls, checked_variant_decl {
                    id: variant_id,
                    enum_id: enum_id,
                    module_name: value.module,
                    enum_name: value.enum_name,
                    name: value.name,
                    at: value.at,
                    payload_count: value.payload_count,
                });
                let mut payload_index = 0;
                while payload_index < list_len(ref variant_payloads) {
                    let payload_entry = list_get(ref variant_payloads, payload_index);
                    match payload_entry {
                        Some(payload) => {
                            if payload.module == value.module and payload.variant_name == value.name {
                                let payload_type_id = intern_checked_type_id(payload.type_name, payload.type_arg1_name, payload.type_arg2_name, payload.is_borrow, payload.borrow_mutable, payload.module, ref uses, ref items, mutref type_shapes, mutref diags, payload.at);
                                list_push(mutref variant_payload_decls, checked_variant_payload_decl {
                                    variant_id: variant_id,
                                    index: payload.index,
                                    type_name: payload.type_name,
                                    type_arg1_name: payload.type_arg1_name,
                                    type_arg2_name: payload.type_arg2_name,
                                    is_borrow: payload.is_borrow,
                                    borrow_mutable: payload.borrow_mutable,
                                    type_id: payload_type_id,
                                });
                            }
                        },
                        None => {
                        },
                    }
                    payload_index = payload_index + 1;
                }
            },
            None => {
            },
        }
        variant_index = variant_index + 1;
    }
    return;
}

fn append_const_decls(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, bindings: ref list<checked_binding>, resolved_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, sources: ref list<source_file>, modules: ref list<checked_module>, type_shapes: mutref list<checked_type_shape>, const_decls: mutref list<checked_const_decl>, expressions: mutref list<checked_expr>, expr_children: mutref list<checked_expr_child>, struct_fields: mutref list<checked_struct_field_init>, diags: mutref list<diag>) -> unit {
    let mut index = 0;
    while index < list_len(ref consts) {
        let entry = list_get(ref consts, index);
        match entry {
            Some(value) => {
                let text = module_source_text(ref sources, value.module);
                let tokens = lex(text);
                let type_id = intern_checked_type_id(value.type_name, value.type_arg1_name, value.type_arg2_name, value.is_borrow, value.borrow_mutable, value.module, ref uses, ref items, mutref type_shapes, mutref diags, value.at);
                let expected_ctx = make_expected_type_ctx(value.type_name, value.type_arg1_name, value.type_arg2_name);
                let expr_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, 0, value.module, "", 0, ref tokens, value.expr_start, value.expr_end, value.at, expected_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
                if expr_id < 0 {
                    push_handoff_limitation_detail(mutref diags, value.module, value.at, str_concat("missing checked const initializer for: ", value.name));
                }
                list_push(mutref const_decls, checked_const_decl {
                    id: list_len(ref const_decls) + 1,
                    module_id: lookup_module_id(ref modules, value.module),
                    module_name: value.module,
                    name: value.name,
                    at: value.at,
                    type_name: value.type_name,
                    type_arg1_name: value.type_arg1_name,
                    type_arg2_name: value.type_arg2_name,
                    is_borrow: value.is_borrow,
                    borrow_mutable: value.borrow_mutable,
                    type_id: type_id,
                    expr_id: expr_id,
                });
            },
            None => {
            },
        }
        index = index + 1;
    }
    return;
}

fn build_predicted_stmt_ids(stmt_facts: ref list<stmt_fact>, sources: ref list<source_file>, functions: ref list<checked_function>) -> list<predicted_stmt_id> {
    let mut predicted: list<predicted_stmt_id> = list();
    let mut source_index = 0;
    while source_index < list_len(ref sources) {
        let source_entry = list_get(ref sources, source_index);
        match source_entry {
            Some(source_value) => {
                let mut stmt_index = 0;
                while stmt_index < list_len(ref stmt_facts) {
                    let stmt_entry = list_get(ref stmt_facts, stmt_index);
                    match stmt_entry {
                        Some(current) => {
                            if current.module == source_value.name and lookup_function_id(ref functions, current.module, current.function_name) >= 0 {
                                list_push(mutref predicted, predicted_stmt_id {
                                    id: list_len(ref predicted) + 1,
                                    module_name: current.module,
                                    function_name: current.function_name,
                                    scope_id: current.scope_id,
                                    at: current.at,
                                    kind: current.kind,
                                    name: current.name,
                                });
                            }
                        },
                        None => {
                        },
                    }
                    stmt_index = stmt_index + 1;
                }
            },
            None => {
            },
        }
        source_index = source_index + 1;
    }
    return predicted;
}

fn build_predicted_arm_ids(match_arms: ref list<match_arm_fact>, sources: ref list<source_file>) -> list<predicted_arm_id> {
    let mut predicted: list<predicted_arm_id> = list();
    let mut source_index = 0;
    while source_index < list_len(ref sources) {
        let source_entry = list_get(ref sources, source_index);
        match source_entry {
            Some(source_value) => {
                let mut arm_index = 0;
                while arm_index < list_len(ref match_arms) {
                    let arm_entry = list_get(ref match_arms, arm_index);
                    match arm_entry {
                        Some(current) => {
                            if current.module == source_value.name {
                                list_push(mutref predicted, predicted_arm_id {
                                    id: list_len(ref predicted) + 1,
                                    module_name: current.module,
                                    function_name: current.function_name,
                                    scope_id: current.scope_id,
                                    at: current.at,
                                    match_at: current.match_at,
                                });
                            }
                        },
                        None => {
                        },
                    }
                    arm_index = arm_index + 1;
                }
            },
            None => {
            },
        }
        source_index = source_index + 1;
    }
    return predicted;
}

fn lookup_predicted_stmt_id(predicted: ref list<predicted_stmt_id>, module_name: str, function_name: str, scope_id: i32, at: i32, kind: stmt_fact_kind, name: str) -> i32 {
    let mut index = 0;
    while index < list_len(ref predicted) {
        let entry = list_get(ref predicted, index);
        match entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and value.scope_id == scope_id and value.at == at and value.name == name {
                    match value.kind {
                        stmt_local => {
                            match kind {
                                stmt_local => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_expr => {
                            match kind {
                                stmt_expr => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_assign => {
                            match kind {
                                stmt_assign => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_return => {
                            match kind {
                                stmt_return => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_if => {
                            match kind {
                                stmt_if => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_while => {
                            match kind {
                                stmt_while => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_match => {
                            match kind {
                                stmt_match => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_let_else => {
                            match kind {
                                stmt_let_else => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_break => {
                            match kind {
                                stmt_break => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                        stmt_continue => {
                            match kind {
                                stmt_continue => {
                                    return value.id;
                                },
                                _ => {
                                },
                            }
                        },
                    }
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn lookup_predicted_arm_id(predicted: ref list<predicted_arm_id>, module_name: str, function_name: str, scope_id: i32) -> i32 {
    let mut index = 0;
    while index < list_len(ref predicted) {
        let entry = list_get(ref predicted, index);
        match entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and value.scope_id == scope_id {
                    return value.id;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn append_bindings(function_params: ref list<function_param_fact>, stmt_facts: ref list<stmt_fact>, pattern_binding_facts: ref list<pattern_binding_fact>, scopes: ref list<body_scope>, resolved_bindings: ref list<typed_binding_fact>, predicted_stmt_ids: ref list<predicted_stmt_id>, predicted_arm_ids: ref list<predicted_arm_id>, functions: ref list<checked_function>, uses: ref list<module_use>, items: ref list<top_item>, type_shapes: mutref list<checked_type_shape>, bindings: mutref list<checked_binding>, diags: mutref list<diag>) -> unit {
    let mut param_index = 0;
    while param_index < list_len(ref function_params) {
        let param_entry = list_get(ref function_params, param_index);
        match param_entry {
            Some(param) => {
                let function_id = lookup_function_id(ref functions, param.module, param.function_name);
                if function_id >= 0 {
                    let type_id = intern_checked_type_id(param.type_name, param.type_arg1_name, param.type_arg2_name, param.is_borrow, param.borrow_mutable, param.module, ref uses, ref items, mutref type_shapes, mutref diags, param.at);
                    list_push(mutref bindings, checked_binding {
                        id: list_len(ref bindings) + 1,
                        function_id: function_id,
                        module_name: param.module,
                        function_name: param.function_name,
                        scope_id: lookup_function_root_scope_id(ref functions, param.module, param.function_name),
                        name: param.name,
                        at: param.at,
                        kind: checked_binding_param,
                        type_name: param.type_name,
                        type_arg1_name: param.type_arg1_name,
                        type_arg2_name: param.type_arg2_name,
                        is_borrow: param.is_borrow,
                        borrow_mutable: param.borrow_mutable,
                        type_id: type_id,
                        origin_stmt_id: -1,
                        origin_arm_id: -1,
                        param_index: param.index,
                    });
                }
            },
            None => {
            },
        }
        param_index = param_index + 1;
    }

    let mut stmt_index = 0;
    while stmt_index < list_len(ref stmt_facts) {
        let stmt_entry = list_get(ref stmt_facts, stmt_index);
        match stmt_entry {
            Some(current) => {
                let mut is_local_binding_stmt = false;
                match current.kind {
                    stmt_local => {
                        is_local_binding_stmt = true;
                    },
                    stmt_let_else => {
                        is_local_binding_stmt = true;
                    },
                    _ => {
                    },
                }
                if is_local_binding_stmt {
                    let function_id = lookup_function_id(ref functions, current.module, current.function_name);
                    if function_id >= 0 {
                        let mut ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, current.expr_end + 1);
                        if ctx.head == "" and current.name != "" {
                            ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, 2147483647);
                        }
                        if ctx.head == "" {
                            push_handoff_limitation_detail(mutref diags, current.module, current.at, str_concat("missing resolved local binding type for checked handoff: ", current.name));
                        }
                        let mut binding_is_borrow = exact_resolved_binding_is_borrow(ref resolved_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                        if not binding_is_borrow and current.name != "" {
                            binding_is_borrow = visible_resolved_binding_is_borrow(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, 2147483647);
                        }
                        let mut binding_borrow_mutable = exact_resolved_binding_borrow_mutable(ref resolved_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                        if not binding_borrow_mutable and current.name != "" {
                            binding_borrow_mutable = visible_resolved_binding_borrow_mutable(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, 2147483647);
                        }
                        let type_id = intern_checked_type_id(ctx.head, ctx.arg1_name, ctx.arg2_name, binding_is_borrow, binding_borrow_mutable, current.module, ref uses, ref items, mutref type_shapes, mutref diags, current.at);
                        list_push(mutref bindings, checked_binding {
                            id: list_len(ref bindings) + 1,
                            function_id: function_id,
                            module_name: current.module,
                            function_name: current.function_name,
                            scope_id: current.scope_id,
                            name: current.name,
                            at: current.at,
                            kind: checked_binding_local,
                            type_name: ctx.head,
                            type_arg1_name: ctx.arg1_name,
                            type_arg2_name: ctx.arg2_name,
                            is_borrow: binding_is_borrow,
                            borrow_mutable: binding_borrow_mutable,
                            type_id: type_id,
                            origin_stmt_id: lookup_predicted_stmt_id(ref predicted_stmt_ids, current.module, current.function_name, current.scope_id, current.at, current.kind, current.name),
                            origin_arm_id: -1,
                            param_index: -1,
                        });
                    }
                }
            },
            None => {
            },
        }
        stmt_index = stmt_index + 1;
    }

    let mut pattern_index = 0;
    while pattern_index < list_len(ref pattern_binding_facts) {
        let pattern_entry = list_get(ref pattern_binding_facts, pattern_index);
        match pattern_entry {
            Some(current) => {
                let function_id = lookup_function_id(ref functions, current.module, current.function_name);
                if function_id >= 0 {
                    let resolved_ctx = exact_resolved_binding_ctx(ref resolved_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                    if resolved_ctx.head == "" {
                        push_handoff_limitation_detail(mutref diags, current.module, current.at, str_concat("missing resolved pattern binding type for checked handoff: ", current.name));
                    }
                    let binding_is_borrow = current.is_borrow;
                    let type_id = intern_checked_type_id(current.type_name, current.type_arg1_name, current.type_arg2_name, binding_is_borrow, current.borrow_mutable, current.module, ref uses, ref items, mutref type_shapes, mutref diags, current.at);
                    list_push(mutref bindings, checked_binding {
                        id: list_len(ref bindings) + 1,
                        function_id: function_id,
                        module_name: current.module,
                        function_name: current.function_name,
                        scope_id: current.scope_id,
                        name: current.name,
                        at: current.at,
                        kind: checked_binding_pattern,
                        type_name: current.type_name,
                        type_arg1_name: current.type_arg1_name,
                        type_arg2_name: current.type_arg2_name,
                        is_borrow: binding_is_borrow,
                        borrow_mutable: current.borrow_mutable,
                        type_id: type_id,
                        origin_stmt_id: -1,
                        origin_arm_id: lookup_predicted_arm_id(ref predicted_arm_ids, current.module, current.function_name, current.scope_id),
                        param_index: -1,
                    });
                }
            },
            None => {
            },
        }
        pattern_index = pattern_index + 1;
    }
    return;
}

fn append_params(function_params: ref list<function_param_fact>, functions: ref list<checked_function>, bindings: ref list<checked_binding>, params: mutref list<checked_param>, diags: mutref list<diag>) -> unit {
    let mut param_index = 0;
    while param_index < list_len(ref function_params) {
        let param_entry = list_get(ref function_params, param_index);
        match param_entry {
            Some(param) => {
                let function_id = lookup_function_id(ref functions, param.module, param.function_name);
                if function_id >= 0 {
                    let binding_id = exact_binding_id(ref bindings, param.module, param.function_name, lookup_function_root_scope_id(ref functions, param.module, param.function_name), param.name, param.at);
                    if binding_id < 0 {
                        push_handoff_limitation_detail(mutref diags, param.module, param.at, str_concat("missing parameter binding id in checked handoff: ", param.name));
                    }
                    list_push(mutref params, checked_param {
                        function_id: function_id,
                        binding_id: binding_id,
                        module_name: param.module,
                        function_name: param.function_name,
                        index: param.index,
                        name: param.name,
                        at: param.at,
                        type_name: param.type_name,
                        type_arg1_name: param.type_arg1_name,
                        type_arg2_name: param.type_arg2_name,
                        is_borrow: param.is_borrow,
                        borrow_mutable: param.borrow_mutable,
                        type_id: lookup_binding_type_id(ref bindings, binding_id),
                    });
                }
            },
            None => {
            },
        }
        param_index = param_index + 1;
    }
    return;
}

fn append_blocks(scopes: ref list<body_scope>, functions: ref list<checked_function>, blocks: mutref list<checked_block>) -> unit {
    let mut index = 0;
    while index < list_len(ref scopes) {
        let entry = list_get(ref scopes, index);
        match entry {
            Some(value) => {
                let function_id = lookup_function_id(ref functions, value.module, value.function_name);
                let parent_block_id = lookup_block_id(ref blocks, value.module, value.function_name, value.parent_scope_id);
                if function_id >= 0 {
                    list_push(mutref blocks, checked_block {
                        id: list_len(ref blocks) + 1,
                        function_id: function_id,
                        module_name: value.module,
                        function_name: value.function_name,
                        scope_id: value.scope_id,
                        parent_block_id: parent_block_id,
                        depth: value.depth,
                    });
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return;
}

fn append_statements_for_source(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, checked_bindings: ref list<checked_binding>, resolved_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, stmt_facts: ref list<stmt_fact>, uses: ref list<module_use>, items: ref list<top_item>, module_name: str, tokens: ref list<token>, checked_functions: ref list<checked_function>, blocks: ref list<checked_block>, type_shapes: mutref list<checked_type_shape>, statements: mutref list<checked_stmt>, expressions: mutref list<checked_expr>, expr_children: mutref list<checked_expr_child>, struct_fields: mutref list<checked_struct_field_init>, diags: mutref list<diag>) -> unit {
    let mut stmt_index = 0;
    while stmt_index < list_len(ref stmt_facts) {
        let entry = list_get(ref stmt_facts, stmt_index);
        match entry {
            Some(current) => {
                if current.module == module_name {
                    let function_id = lookup_function_id(ref checked_functions, current.module, current.function_name);
                    let block_id = lookup_block_id(ref blocks, current.module, current.function_name, current.scope_id);
                    let mut expr_start = current.expr_start;
                    match current.kind {
                        stmt_local => {
                            let eq_token = token_at(ref tokens, expr_start);
                            match eq_token.kind {
                                tk_eq => {
                                    expr_start = expr_start + 1;
                                },
                                _ => {
                                },
                            }
                        },
                        _ => {
                        },
                    }
                    let mut stmt_type_ctx = empty_expected_type_ctx();
                    let mut stmt_is_borrow = false;
                    let mut stmt_borrow_mutable = false;
                    let mut target_binding_id = -1;
                    match current.kind {
                        stmt_local => {
                            stmt_type_ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, current.expr_end + 1);
                            if stmt_type_ctx.head == "" and current.name != "" {
                                stmt_type_ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, 2147483647);
                            }
                            target_binding_id = exact_binding_id(ref checked_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                            stmt_is_borrow = lookup_binding_is_borrow(ref checked_bindings, target_binding_id);
                            stmt_borrow_mutable = lookup_binding_borrow_mutable(ref checked_bindings, target_binding_id);
                        },
                        stmt_let_else => {
                            stmt_type_ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, current.expr_end + 1);
                            if stmt_type_ctx.head == "" and current.name != "" {
                                stmt_type_ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, 2147483647);
                            }
                            target_binding_id = exact_binding_id(ref checked_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                            stmt_is_borrow = lookup_binding_is_borrow(ref checked_bindings, target_binding_id);
                            stmt_borrow_mutable = lookup_binding_borrow_mutable(ref checked_bindings, target_binding_id);
                        },
                        stmt_assign => {
                            stmt_type_ctx = visible_resolved_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, current.at);
                            target_binding_id = visible_binding_id(ref checked_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.name, current.at);
                            stmt_is_borrow = lookup_binding_is_borrow(ref checked_bindings, target_binding_id);
                            stmt_borrow_mutable = lookup_binding_borrow_mutable(ref checked_bindings, target_binding_id);
                        },
                        stmt_return => {
                            let function_id_lookup = lookup_function_id(ref checked_functions, current.module, current.function_name);
                            let function_index = function_id_lookup - 1;
                            let function_entry = list_get(ref checked_functions, function_index);
                            match function_entry {
                                Some(value) => {
                                    stmt_type_ctx = make_expected_type_ctx(value.return_name, value.return_arg1_name, value.return_arg2_name);
                                    stmt_is_borrow = value.return_is_borrow;
                                    stmt_borrow_mutable = value.return_borrow_mutable;
                                },
                                None => {
                                },
                            }
                        },
                        _ => {
                        },
                    }
                    let mut statement_has_expr = true;
                    match current.kind {
                        stmt_break => {
                            statement_has_expr = false;
                        },
                        stmt_continue => {
                            statement_has_expr = false;
                        },
                        _ => {
                        },
                    }
                    let mut final_expr_id = 0;
                    if statement_has_expr {
                        let expr_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref checked_bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, current.module, current.function_name, current.scope_id, ref tokens, expr_start, current.expr_end, current.at, stmt_type_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
                        final_expr_id = expr_id;
                        if final_expr_id < 0 {
                            final_expr_id = consume_handoff_limitation_detail(mutref diags, current.module, current.at, "missing exported statement expression in checked handoff");
                        }
                    }
                    match current.kind {
                        stmt_local => {
                            if target_binding_id < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, str_concat("missing local target binding id in checked handoff: ", current.name));
                            }
                        },
                        stmt_let_else => {
                            if target_binding_id < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, str_concat("missing let-else target binding id in checked handoff: ", current.name));
                            }
                            if lookup_block_id(ref blocks, current.module, current.function_name, current.child_scope_id) < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing else block id for checked let-else statement");
                            }
                        },
                        stmt_assign => {
                            if target_binding_id < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, str_concat("missing assignment target binding id in checked handoff: ", current.name));
                            }
                        },
                        stmt_if => {
                            if lookup_block_id(ref blocks, current.module, current.function_name, current.child_scope_id) < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing child block id for checked if statement");
                            }
                            if current.alt_scope_id >= 0 and lookup_block_id(ref blocks, current.module, current.function_name, current.alt_scope_id) < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing alternate block id for checked if statement");
                            }
                        },
                        stmt_while => {
                            if lookup_block_id(ref blocks, current.module, current.function_name, current.child_scope_id) < 0 {
                                push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing child block id for checked while statement");
                            }
                        },
                        _ => {
                        },
                    }
                    let child_block_id = lookup_block_id(ref blocks, current.module, current.function_name, current.child_scope_id);
                    let alt_block_id = lookup_block_id(ref blocks, current.module, current.function_name, current.alt_scope_id);
                    if stmt_type_ctx.head == "" {
                        stmt_type_ctx = make_expected_type_ctx("unit", "", "");
                        stmt_is_borrow = false;
                        stmt_borrow_mutable = false;
                    }
                    let stmt_type_id = intern_checked_type_id(stmt_type_ctx.head, stmt_type_ctx.arg1_name, stmt_type_ctx.arg2_name, stmt_is_borrow, stmt_borrow_mutable, current.module, ref uses, ref items, mutref type_shapes, mutref diags, current.at);
                    let mut checked_kind = checked_stmt_expr;
                    match current.kind {
                        stmt_local => {
                            checked_kind = checked_stmt_local;
                        },
                        stmt_expr => {
                            checked_kind = checked_stmt_expr;
                        },
                        stmt_assign => {
                            checked_kind = checked_stmt_assign;
                        },
                        stmt_return => {
                            checked_kind = checked_stmt_return;
                        },
                        stmt_if => {
                            checked_kind = checked_stmt_if;
                        },
                        stmt_while => {
                            checked_kind = checked_stmt_while;
                        },
                        stmt_match => {
                            checked_kind = checked_stmt_match;
                        },
                        stmt_let_else => {
                            checked_kind = checked_stmt_let_else;
                        },
                        stmt_break => {
                            checked_kind = checked_stmt_break;
                        },
                        stmt_continue => {
                            checked_kind = checked_stmt_continue;
                        },
                    }
                    list_push(mutref statements, checked_stmt {
                        id: list_len(ref statements) + 1,
                        function_id: function_id,
                        module_name: current.module,
                        function_name: current.function_name,
                        block_id: block_id,
                        scope_id: current.scope_id,
                        at: current.at,
                        kind: checked_kind,
                        name: current.name,
                        type_name: stmt_type_ctx.head,
                        type_arg1_name: stmt_type_ctx.arg1_name,
                        type_arg2_name: stmt_type_ctx.arg2_name,
                        is_borrow: stmt_is_borrow,
                        borrow_mutable: stmt_borrow_mutable,
                        type_id: stmt_type_id,
                        target_binding_id: target_binding_id,
                        expr_id: final_expr_id,
                        child_block_id: child_block_id,
                        alt_block_id: alt_block_id,
                    });
                }
            },
            None => {
            },
        }
        stmt_index = stmt_index + 1;
    }
    return;
}

fn next_pattern_id(patterns: ref list<checked_pattern>) -> i32 {
    return list_len(ref patterns) + 1;
}

fn push_pattern_child(pattern_children: mutref list<checked_pattern_child>, parent_pattern_id: i32, index: i32, child_pattern_id: i32) -> unit {
    list_push(mutref pattern_children, checked_pattern_child {
        parent_pattern_id: parent_pattern_id,
        index: index,
        child_pattern_id: child_pattern_id,
    });
    return;
}

fn build_checked_pattern_tree(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, checked_bindings: ref list<checked_binding>, arm_id: i32, function_id: i32, module_name: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, patterns: mutref list<checked_pattern>, pattern_children: mutref list<checked_pattern_child>, diags: mutref list<diag>) -> i32 {
    let mut pattern_start = start;
    let mut pattern_end = end;
    while span_is_wrapped_in_parens(ref tokens, pattern_start, pattern_end) {
        pattern_start = pattern_start + 1;
        pattern_end = pattern_end - 1;
    }
    if pattern_start >= pattern_end {
        return consume_handoff_limitation_detail(mutref diags, module_name, start, "missing checked pattern span");
    }
    let current = token_at(ref tokens, pattern_start);
    match current.kind {
        tk_ident => {
            if current.text == "_" and pattern_start + 1 == pattern_end {
                let pattern_id = next_pattern_id(ref patterns);
                list_push(mutref patterns, checked_pattern {
                    id: pattern_id,
                    arm_id: arm_id,
                    function_id: function_id,
                    module_name: module_name,
                    function_name: function_name,
                    scope_id: scope_id,
                    at: current.start,
                    start: pattern_start,
                    end: pattern_end,
                    kind: checked_pattern_wildcard,
                    binding_id: -1,
                    name: "",
                    constructor_origin_module: "",
                    constructor_enum_name: "",
                });
                return pattern_id;
            }
            if span_is_call_expr(ref tokens, pattern_start, pattern_end) {
                let ctor_enum_name = visible_variant_enum_name(ref variants, ref uses, ref items, module_name, current.text);
                if ctor_enum_name == "" {
                    return consume_handoff_limitation_detail(mutref diags, module_name, current.start, str_concat("missing resolved constructor for checked pattern: ", current.text));
                }
                let ctor_origin = visible_variant_origin_module(ref variants, ref uses, ref items, module_name, current.text);
                let pattern_id = next_pattern_id(ref patterns);
                list_push(mutref patterns, checked_pattern {
                    id: pattern_id,
                    arm_id: arm_id,
                    function_id: function_id,
                    module_name: module_name,
                    function_name: function_name,
                    scope_id: scope_id,
                    at: current.start,
                    start: pattern_start,
                    end: pattern_end,
                    kind: checked_pattern_variant,
                    binding_id: -1,
                    name: current.text,
                    constructor_origin_module: ctor_origin,
                    constructor_enum_name: ctor_enum_name,
                });
                let mut arg_start = pattern_start + 2;
                let arg_end_limit = pattern_end - 1;
                let mut arg_index = 0;
                while arg_start < arg_end_limit {
                    let segment_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
                    let child_id = build_checked_pattern_tree(ref variants, ref uses, ref items, ref checked_bindings, arm_id, function_id, module_name, function_name, scope_id, ref tokens, arg_start, segment_end, mutref patterns, mutref pattern_children, mutref diags);
                    if child_id < 0 {
                        return consume_handoff_limitation_detail(mutref diags, module_name, current.start, str_concat("missing checked child pattern for constructor: ", current.text));
                    }
                    push_pattern_child(mutref pattern_children, pattern_id, arg_index, child_id);
                    arg_index = arg_index + 1;
                    arg_start = segment_end + 1;
                }
                return pattern_id;
            }
            if pattern_start + 1 == pattern_end {
                let zero_enum_name = visible_variant_enum_name(ref variants, ref uses, ref items, module_name, current.text);
                if zero_enum_name != "" {
                    let zero_origin = visible_variant_origin_module(ref variants, ref uses, ref items, module_name, current.text);
                    let pattern_id = next_pattern_id(ref patterns);
                    list_push(mutref patterns, checked_pattern {
                        id: pattern_id,
                        arm_id: arm_id,
                        function_id: function_id,
                        module_name: module_name,
                        function_name: function_name,
                        scope_id: scope_id,
                        at: current.start,
                        start: pattern_start,
                        end: pattern_end,
                        kind: checked_pattern_variant,
                        binding_id: -1,
                        name: current.text,
                        constructor_origin_module: zero_origin,
                        constructor_enum_name: zero_enum_name,
                    });
                    return pattern_id;
                }
                let binding_id = exact_binding_id(ref checked_bindings, module_name, function_name, scope_id, current.text, current.start);
                if binding_id < 0 {
                    return consume_handoff_limitation_detail(mutref diags, module_name, current.start, str_concat("missing checked binding id for pattern binding: ", current.text));
                }
                let pattern_id = next_pattern_id(ref patterns);
                list_push(mutref patterns, checked_pattern {
                    id: pattern_id,
                    arm_id: arm_id,
                    function_id: function_id,
                    module_name: module_name,
                    function_name: function_name,
                    scope_id: scope_id,
                    at: current.start,
                    start: pattern_start,
                    end: pattern_end,
                    kind: checked_pattern_bind,
                    binding_id: binding_id,
                    name: current.text,
                    constructor_origin_module: "",
                    constructor_enum_name: "",
                });
                return pattern_id;
            }
        },
        _ => {
        },
    }
    return consume_handoff_limitation_detail(mutref diags, module_name, current.start, "unsupported checked pattern shape");
}

fn append_match_arms_for_source(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, match_arms: ref list<match_arm_fact>, pattern_bindings: ref list<pattern_binding_fact>, checked_bindings: ref list<checked_binding>, resolved_bindings: ref list<typed_binding_fact>, module_name: str, tokens: ref list<token>, statements: ref list<checked_stmt>, checked_functions: ref list<checked_function>, blocks: ref list<checked_block>, type_shapes: mutref list<checked_type_shape>, expressions: mutref list<checked_expr>, expr_children: mutref list<checked_expr_child>, struct_fields: mutref list<checked_struct_field_init>, checked_match_arms: mutref list<checked_match_arm>, checked_pattern_bindings: mutref list<checked_pattern_binding>, checked_patterns: mutref list<checked_pattern>, checked_pattern_children: mutref list<checked_pattern_child>, diags: mutref list<diag>) -> unit {
    let mut arm_index = 0;
    while arm_index < list_len(ref match_arms) {
        let arm_entry = list_get(ref match_arms, arm_index);
        match arm_entry {
            Some(current) => {
                if current.module == module_name {
                    let mut owner_stmt_id = -1;
                    let mut statement_index = 0;
                    while statement_index < list_len(ref statements) {
                        let stmt_entry = list_get(ref statements, statement_index);
                        match stmt_entry {
                            Some(value) => {
                                if value.module_name == current.module and value.function_name == current.function_name and checked_stmt_kind_matches(value.kind, checked_stmt_match) and value.at == current.match_at {
                                    owner_stmt_id = value.id;
                                }
                                if current.is_expression and value.module_name == current.module and value.function_name == current.function_name and value.expr_id > 0 {
                                    let expr_entry = list_get(ref expressions, value.expr_id - 1);
                                    match expr_entry {
                                        Some(expr_value) => {
                                            let expr_token = token_at(ref tokens, expr_value.start);
                                            if checked_expr_kind_matches(expr_value.kind, checked_expr_match) and expr_token.start == current.match_at {
                                                owner_stmt_id = value.id;
                                            }
                                        },
                                        None => {
                                        },
                                    }
                                }
                            },
                            None => {
                            },
                        }
                        statement_index = statement_index + 1;
                    }
                    let mut constructor_name = "";
                    let mut constructor_origin_module = "";
                    let mut constructor_enum_name = "";
                    let mut is_wildcard = false;
                    let mut pattern_start = current.pattern_start;
                    let mut pattern_end = current.pattern_end;
                    while span_is_wrapped_in_parens(ref tokens, pattern_start, pattern_end) {
                        pattern_start = pattern_start + 1;
                        pattern_end = pattern_end - 1;
                    }
                    let head = token_at(ref tokens, pattern_start);
                    if token_is_ident(head) {
                        if head.text == "_" and pattern_start + 1 == pattern_end {
                            is_wildcard = true;
                        } else {
                            if span_is_call_expr(ref tokens, pattern_start, pattern_end) or pattern_start + 1 == pattern_end {
                                let enum_name = visible_variant_enum_name(ref variants, ref uses, ref items, current.module, head.text);
                                if enum_name != "" {
                                    constructor_name = head.text;
                                    constructor_origin_module = visible_variant_origin_module(ref variants, ref uses, ref items, current.module, head.text);
                                    constructor_enum_name = enum_name;
                                }
                            }
                        }
                    }
                    let function_id = lookup_function_id(ref checked_functions, current.module, current.function_name);
                    let block_id = lookup_block_id(ref blocks, current.module, current.function_name, current.scope_id);
                    let mut result_expr_id = -1;
                    if current.is_expression {
                        let mut result_expected_ctx = empty_expected_type_ctx();
                        let mut owner_lookup_index = 0;
                        while owner_lookup_index < list_len(ref statements) {
                            let owner_entry = list_get(ref statements, owner_lookup_index);
                            match owner_entry {
                                Some(owner_stmt) => {
                                    if owner_stmt.id == owner_stmt_id {
                                        result_expected_ctx = make_expected_type_ctx(owner_stmt.type_name, owner_stmt.type_arg1_name, owner_stmt.type_arg2_name);
                                    }
                                },
                                None => {
                                },
                            }
                            owner_lookup_index = owner_lookup_index + 1;
                        }
                        result_expr_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref checked_bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, current.module, current.function_name, current.scope_id, ref tokens, current.body_start, current.body_end, current.at, result_expected_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
                    }
                    let pattern_id = build_checked_pattern_tree(ref variants, ref uses, ref items, ref checked_bindings, list_len(ref checked_match_arms) + 1, function_id, current.module, current.function_name, current.scope_id, ref tokens, current.pattern_start, current.pattern_end, mutref checked_patterns, mutref checked_pattern_children, mutref diags);
                    if owner_stmt_id < 0 or function_id < 0 or block_id < 0 {
                        push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing checked match arm owner ids");
                    }
                    if current.is_expression and result_expr_id < 0 {
                        push_handoff_limitation_detail(mutref diags, current.module, current.at, "missing match-expression arm result expression");
                    }
                    list_push(mutref checked_match_arms, checked_match_arm {
                        id: list_len(ref checked_match_arms) + 1,
                        stmt_id: owner_stmt_id,
                        function_id: function_id,
                        module_name: current.module,
                        function_name: current.function_name,
                        block_id: block_id,
                        scope_id: current.scope_id,
                        at: current.at,
                        constructor_name: constructor_name,
                        constructor_origin_module: constructor_origin_module,
                        constructor_enum_name: constructor_enum_name,
                        is_wildcard: is_wildcard,
                        pattern_id: pattern_id,
                        result_expr_id: result_expr_id,
                    });
                    let new_arm_id = list_len(ref checked_match_arms);
                    let mut binding_index = 0;
                    while binding_index < list_len(ref pattern_bindings) {
                        let binding_entry = list_get(ref pattern_bindings, binding_index);
                        match binding_entry {
                            Some(value) => {
                                if value.module == current.module and value.function_name == current.function_name and value.scope_id == current.scope_id {
                                    let binding_id = exact_binding_id(ref checked_bindings, value.module, value.function_name, value.scope_id, value.name, value.at);
                                    if binding_id < 0 {
                                        push_handoff_limitation_detail(mutref diags, value.module, value.at, "missing checked pattern binding id");
                                    }
                                    list_push(mutref checked_pattern_bindings, checked_pattern_binding {
                                        arm_id: new_arm_id,
                                        binding_id: binding_id,
                                        function_id: function_id,
                                        module_name: value.module,
                                        function_name: value.function_name,
                                        scope_id: value.scope_id,
                                        name: value.name,
                                        at: value.at,
                                        type_name: value.type_name,
                                        type_arg1_name: value.type_arg1_name,
                                        type_arg2_name: value.type_arg2_name,
                                        is_borrow: exact_resolved_binding_is_borrow(ref resolved_bindings, value.module, value.function_name, value.scope_id, value.name, value.at),
                                        borrow_mutable: exact_resolved_binding_borrow_mutable(ref resolved_bindings, value.module, value.function_name, value.scope_id, value.name, value.at),
                                        type_id: lookup_binding_type_id(ref checked_bindings, binding_id),
                                    });
                                }
                            },
                            None => {
                            },
                        }
                        binding_index = binding_index + 1;
                    }
                }
            },
            None => {
            },
        }
        arm_index = arm_index + 1;
    }
    return;
}

pub fn build_checked_handoff(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, resolved_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, match_arms: ref list<match_arm_fact>, pattern_bindings: ref list<pattern_binding_fact>, stmt_facts: ref list<stmt_fact>, uses: ref list<module_use>, items: ref list<top_item>, sources: ref list<source_file>, modules_out: mutref list<checked_module>, functions_out: mutref list<checked_function>, bindings_out: mutref list<checked_binding>, params_out: mutref list<checked_param>, consts_out: mutref list<checked_const_decl>, type_shapes_out: mutref list<checked_type_shape>, type_decls_out: mutref list<checked_type_decl>, field_decls_out: mutref list<checked_field_decl>, enum_decls_out: mutref list<checked_enum_decl>, variant_decls_out: mutref list<checked_variant_decl>, variant_payload_decls_out: mutref list<checked_variant_payload_decl>, blocks_out: mutref list<checked_block>, statements_out: mutref list<checked_stmt>, match_arms_out: mutref list<checked_match_arm>, patterns_out: mutref list<checked_pattern>, pattern_children_out: mutref list<checked_pattern_child>, pattern_bindings_out: mutref list<checked_pattern_binding>, expressions_out: mutref list<checked_expr>, expr_children_out: mutref list<checked_expr_child>, struct_fields_out: mutref list<checked_struct_field_init>, diags: mutref list<diag>) -> checked_handoff_summary
audit {
    intent("Build the structured checked handoff from trusted selfhost semantic outputs");
    mutates(modules_out, functions_out, bindings_out, params_out, consts_out, type_shapes_out, type_decls_out, field_decls_out, enum_decls_out, variant_decls_out, variant_payload_decls_out, blocks_out, statements_out, match_arms_out, patterns_out, pattern_children_out, pattern_bindings_out, expressions_out, expr_children_out, struct_fields_out, diags);
    effects();
}
{
    append_modules_from_sources(ref sources, mutref modules_out);
    append_functions(ref functions, ref scopes, ref modules_out, ref uses, ref items, mutref type_shapes_out, mutref functions_out, mutref diags);
    append_type_decls(ref items, ref uses, ref field_facts, ref modules_out, mutref type_shapes_out, mutref type_decls_out, mutref field_decls_out, mutref diags);
    append_enum_decls(ref variants, ref variant_payloads, ref uses, ref items, ref modules_out, mutref type_shapes_out, mutref enum_decls_out, mutref variant_decls_out, mutref variant_payload_decls_out, mutref diags);
    append_blocks(ref scopes, ref functions_out, mutref blocks_out);
    let predicted_stmt_ids = build_predicted_stmt_ids(ref stmt_facts, ref sources, ref functions_out);
    let predicted_arm_ids = build_predicted_arm_ids(ref match_arms, ref sources);
    append_bindings(ref function_params, ref stmt_facts, ref pattern_bindings, ref scopes, ref resolved_bindings, ref predicted_stmt_ids, ref predicted_arm_ids, ref functions_out, ref uses, ref items, mutref type_shapes_out, mutref bindings_out, mutref diags);
    append_params(ref function_params, ref functions_out, ref bindings_out, mutref params_out, mutref diags);
    append_const_decls(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings_out, ref resolved_bindings, ref field_facts, ref uses, ref items, ref sources, ref modules_out, mutref type_shapes_out, mutref consts_out, mutref expressions_out, mutref expr_children_out, mutref struct_fields_out, mutref diags);

    let mut source_index = 0;
    while source_index < list_len(ref sources) {
        let source_entry = list_get(ref sources, source_index);
        match source_entry {
            Some(current_source) => {
                let tokens = lex(current_source.text);
                append_statements_for_source(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings_out, ref resolved_bindings, ref field_facts, ref stmt_facts, ref uses, ref items, current_source.name, ref tokens, ref functions_out, ref blocks_out, mutref type_shapes_out, mutref statements_out, mutref expressions_out, mutref expr_children_out, mutref struct_fields_out, mutref diags);
                append_match_arms_for_source(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref field_facts, ref uses, ref items, ref match_arms, ref pattern_bindings, ref bindings_out, ref resolved_bindings, current_source.name, ref tokens, ref statements_out, ref functions_out, ref blocks_out, mutref type_shapes_out, mutref expressions_out, mutref expr_children_out, mutref struct_fields_out, mutref match_arms_out, mutref pattern_bindings_out, mutref patterns_out, mutref pattern_children_out, mutref diags);
            },
            None => {
            },
        }
        source_index = source_index + 1;
    }

    return checked_handoff_summary {
        module_count: list_len(ref modules_out),
        function_count: list_len(ref functions_out),
        const_count: list_len(ref consts_out),
        binding_count: list_len(ref bindings_out),
        block_count: list_len(ref blocks_out),
        statement_count: list_len(ref statements_out),
        arm_count: list_len(ref match_arms_out),
        pattern_count: list_len(ref patterns_out),
        pattern_binding_count: list_len(ref pattern_bindings_out),
        expression_count: list_len(ref expressions_out),
        type_shape_count: list_len(ref type_shapes_out),
        type_decl_count: list_len(ref type_decls_out),
        enum_decl_count: list_len(ref enum_decls_out),
        variant_decl_count: list_len(ref variant_decls_out),
        diag_count: list_len(ref diags),
    };
}

pub fn summarize_checked_handoff(modules: ref list<checked_module>, functions: ref list<checked_function>, bindings: ref list<checked_binding>, blocks: ref list<checked_block>, statements: ref list<checked_stmt>, match_arms: ref list<checked_match_arm>, patterns: ref list<checked_pattern>, pattern_bindings: ref list<checked_pattern_binding>, expressions: ref list<checked_expr>, type_shapes: ref list<checked_type_shape>, type_decls: ref list<checked_type_decl>, enum_decls: ref list<checked_enum_decl>, variant_decls: ref list<checked_variant_decl>, diag_count: i32) -> checked_handoff_summary
audit {
    intent("Summarize the structured checked handoff for probes and tests");
    mutates();
    effects();
}
{
    return checked_handoff_summary {
        module_count: list_len(ref modules),
        function_count: list_len(ref functions),
        const_count: 0,
        binding_count: list_len(ref bindings),
        block_count: list_len(ref blocks),
        statement_count: list_len(ref statements),
        arm_count: list_len(ref match_arms),
        pattern_count: list_len(ref patterns),
        pattern_binding_count: list_len(ref pattern_bindings),
        expression_count: list_len(ref expressions),
        type_shape_count: list_len(ref type_shapes),
        type_decl_count: list_len(ref type_decls),
        enum_decl_count: list_len(ref enum_decls),
        variant_decl_count: list_len(ref variant_decls),
        diag_count: diag_count,
    };
}

pub fn handoff_has_stmt_kind(statements: ref list<checked_stmt>, module_name: str, function_name: str, kind: checked_stmt_kind) -> bool
audit {
    intent("Check whether a checked handoff contains a statement kind in one function");
    mutates();
    effects();
}
{
    let mut index = 0;
    while index < list_len(ref statements) {
        let entry = list_get(ref statements, index);
        match entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and checked_stmt_kind_matches(value.kind, kind) {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

