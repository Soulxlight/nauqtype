            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_star => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            tk_slash => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_field_dot(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    let mut found = -1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_dot => {
                if depth == 0 and brace_depth == 0 {
                    found = index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return found;
}

fn span_is_call_expr(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 3 {
        return false;
    }
    let head = token_at(ref tokens, start);
    let open = token_at(ref tokens, start + 1);
    match head.kind {
        tk_ident => {
        },
        _ => {
            return false;
        },
    }
    match open.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start + 1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

