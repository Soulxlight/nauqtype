fn qualified_function_origin_module(uses: ref list<module_use>, items: ref list<top_item>, module_name: str, qualifier: str, function_name: str) -> str {
    if handoff_module_directly_imports(ref uses, module_name, qualifier) and handoff_module_exports_function(ref items, qualifier, function_name) {
        return qualifier;
    }
    return "";
}

fn handoff_builtin_function_param_name(function_name: str, index: i32) -> str {
    if function_name == "print_line" or function_name == "eprint_line" {
        if index == 0 {
            return "text";
        }
    }
    if function_name == "read_file" or function_name == "create_dir_all" {
        if index == 0 {
            return "path";
        }
    }
    if function_name == "arg_get" {
        if index == 0 {
            return "index";
        }
    }
    if function_name == "write_file" {
        if index == 0 {
            return "path";
        }
        if index == 1 {
            return "text";
        }
    }
    if function_name == "io_err_text" {
        if index == 0 {
            return "err";
        }
    }
    if function_name == "run_process" {
        if index == 0 {
            return "program";
        }
        if index == 1 {
            return "args";
        }
        if index == 2 {
            return "cwd";
        }
    }
    if function_name == "str_len" {
        if index == 0 {
            return "text";
        }
    }
    if function_name == "str_concat" {
        if index == 0 {
            return "left";
        }
        if index == 1 {
            return "right";
        }
    }
    if function_name == "str_get" {
        if index == 0 {
            return "text";
        }
        if index == 1 {
            return "index";
        }
    }
    if function_name == "str_slice" {
        if index == 0 {
            return "text";
        }
        if index == 1 {
            return "start";
        }
        if index == 2 {
            return "end";
        }
    }
    if function_name == "list_push" {
        if index == 0 {
            return "items";
        }
        if index == 1 {
            return "value";
        }
    }
    if function_name == "list_len" {
        if index == 0 {
            return "items";
        }
    }
    if function_name == "list_get" {
        if index == 0 {
            return "items";
        }
        if index == 1 {
            return "index";
        }
    }
    return "";
}

fn handoff_builtin_function_param_count(function_name: str) -> i32 {
    if function_name == "list" or function_name == "arg_count" {
        return 0;
    }
    if function_name == "print_line" or function_name == "eprint_line" or function_name == "read_file" or function_name == "arg_get" or function_name == "create_dir_all" or function_name == "io_err_text" or function_name == "str_len" or function_name == "list_len" {
        return 1;
    }
    if function_name == "write_file" or function_name == "str_concat" or function_name == "str_get" or function_name == "list_push" or function_name == "list_get" {
        return 2;
    }
    if function_name == "run_process" or function_name == "str_slice" {
        return 3;
    }
    return -1;
}

fn lookup_function_param_count(functions: ref list<function_fact>, module_name: str, function_name: str) -> i32 {
    let mut index = 0;
    while index < list_len(ref functions) {
        let entry = list_get(ref functions, index);
        match entry {
            Some(value) => {
                if value.module == module_name and value.name == function_name {
                    return value.param_count;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn lookup_function_param_name(function_params: ref list<function_param_fact>, module_name: str, function_name: str, index: i32) -> str {
    let mut cursor = 0;
    while cursor < list_len(ref function_params) {
        let entry = list_get(ref function_params, cursor);
        match entry {
            Some(value) => {
                if value.module == module_name and value.function_name == function_name and value.index == index {
                    return value.name;
                }
            },
            None => {
            },
        }
        cursor = cursor + 1;
    }
    return "";
}

fn handoff_function_param_count(functions: ref list<function_fact>, function_name: str, origin_module: str) -> i32 {
    if origin_module == "__builtin__" {
        return handoff_builtin_function_param_count(function_name);
    }
    if origin_module != "" {
        return lookup_function_param_count(ref functions, origin_module, function_name);
    }
    return -1;
}

fn handoff_function_param_name(function_params: ref list<function_param_fact>, uses: ref list<module_use>, items: ref list<top_item>, module_name: str, qualifier: str, function_name: str, origin_module: str, index: i32) -> str {
    if qualifier == "" {
        let builtin_name = handoff_builtin_function_param_name(function_name, index);
        if builtin_name != "" {
            return builtin_name;
        }
    }
    if origin_module != "" and origin_module != "__builtin__" {
        return lookup_function_param_name(ref function_params, origin_module, function_name, index);
    }
    return "";
}

