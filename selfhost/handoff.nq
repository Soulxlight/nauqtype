fn token_can_end_expr(tok: token) -> bool {
    match tok.kind {
        tk_ident => {
            return true;
        },
        tk_int_lit => {
            return true;
        },
        tk_string_lit => {
            return true;
        },
        tk_kw_true => {
            return true;
        },
        tk_kw_false => {
            return true;
        },
        tk_rparen => {
            return true;
        },
        tk_rbrace => {
            return true;
        },
        tk_rbracket => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn skip_until_match_block(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    let mut bracket_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                cursor = cursor + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
                cursor = cursor + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbrace => {
                if paren_depth == 0 and bracket_depth == 0 {
                    return;
                }
                cursor = cursor + 1;
            },
            _ => {
                cursor = cursor + 1;
            },
        }
    }
}

fn span_is_wrapped_in_parens(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 2 {
        return false;
    }
    let first = token_at(ref tokens, start);
    let last = token_at(ref tokens, end - 1);
    match first.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    match last.kind {
        tk_rparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 and index + 1 < end {
                    return false;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return depth == 0;
}

fn is_binary_operator_position(tokens: ref list<token>, start: i32, index: i32) -> bool {
    if index <= start {
        return false;
    }
    let previous = token_at(ref tokens, index - 1);
    return token_can_end_expr(previous);
}

fn find_root_or_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
            },
            tk_kw_or => {
                if depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_and_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
