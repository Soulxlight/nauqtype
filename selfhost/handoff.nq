fn handoff_module_exports_function(items: ref list<top_item>, module_name: str, function_name: str) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value.module == module_name and value.name == function_name and value.is_public {
                    match value.kind {
                        item_fn => {
                            return true;
