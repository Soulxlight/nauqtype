}

fn visible_binding_id(bindings: ref list<checked_binding>, scopes: ref list<body_scope>, module_name: str, function_name: str, scope_id: i32, name: str, at: i32) -> i32 {
    let mut index = list_len(ref bindings) - 1;
    while index >= 0 {
        let entry = list_get(ref bindings, index);
        match entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and value.name == name and value.at < at {
                    if scope_is_visible(ref scopes, module_name, function_name, scope_id, value.scope_id) {
                        return value.id;
                    }
                }
            },
            None => {
            },
        }
        index = index - 1;
    }
    return -1;
}

