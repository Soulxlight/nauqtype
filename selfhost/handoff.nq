    if span_is_call_expr(ref tokens, expr_start, expr_end) {
        let name_index = span_call_name_index(ref tokens, expr_start, expr_end);
        let open_index = span_call_open_index(ref tokens, expr_start, expr_end);
        let head = token_at(ref tokens, name_index);
        let qualifier = span_call_qualifier(ref tokens, expr_start, expr_end);
        let mut function_origin = visible_function_origin_module(ref uses, ref items, module_name, head.text);
        if qualifier != "" {
            function_origin = qualified_function_origin_module(ref uses, ref items, module_name, qualifier, head.text);
        }
        let mut variant_origin = visible_variant_origin_module(ref variants, ref uses, ref items, module_name, head.text);
        if qualifier != "" {
            variant_origin = "";
        }
        let mut target_kind = checked_target_none;
        let mut target_origin = "";
        if function_origin != "" {
            if function_origin == "__builtin__" {
                target_kind = checked_target_builtin_function;
            } else {
                target_kind = checked_target_function;
            }
            target_origin = function_origin;
        } else {
            if qualifier == "" and visible_variant_enum_name(ref variants, ref uses, ref items, module_name, head.text) != "" {
                if variant_origin == "__builtin__" {
                    target_kind = checked_target_builtin_constructor;
                } else {
                    target_kind = checked_target_constructor;
