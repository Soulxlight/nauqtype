            },
        }
        index = index + 1;
    }
    return false;
}

fn segment_label_colon(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    if start + 2 > end {
        return -1;
    }
    let label = token_at(ref tokens, start);
    let colon = token_at(ref tokens, start + 1);
    match label.kind {
        tk_ident => {
            match colon.kind {
                tk_colon => {
                    return start + 1;
                },
                _ => {
                },
            }
        },
        _ => {
        },
    }
    return -1;
}

fn segment_label_name(tokens: ref list<token>, start: i32, end: i32) -> str {
    if segment_label_colon(ref tokens, start, end) >= 0 {
        let label = token_at(ref tokens, start);
        return label.text;
    }
    return "";
}

fn segment_value_start(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let colon = segment_label_colon(ref tokens, start, end);
    if colon >= 0 {
        return colon + 1;
    }
    return start;
}

fn call_args_are_named(tokens: ref list<token>, arg_start: i32, arg_end_limit: i32) -> bool {
    if arg_start >= arg_end_limit {
        return false;
    }
    let first_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
    return segment_label_colon(ref tokens, arg_start, first_end) >= 0;
}

fn find_named_arg_segment_start(tokens: ref list<token>, arg_start: i32, arg_end_limit: i32, label: str) -> i32 {
    let mut current_start = arg_start;
    while current_start < arg_end_limit {
        let segment_end = next_top_level_comma(ref tokens, current_start, arg_end_limit);
        if segment_label_name(ref tokens, current_start, segment_end) == label {
            return current_start;
        }
        current_start = segment_end + 1;
    }
    return -1;
}

