fn token_can_end_expr(tok: token) -> bool {
    match tok.kind {
        tk_ident => {
            return true;
        },
        tk_int_lit => {
            return true;
        },
        tk_string_lit => {
            return true;
        },
        tk_kw_true => {
            return true;
        },
        tk_kw_false => {
            return true;
        },
        tk_rparen => {
            return true;
        },
        tk_rbrace => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn span_is_wrapped_in_parens(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 2 {
        return false;
    }
    let first = token_at(ref tokens, start);
    let last = token_at(ref tokens, end - 1);
    match first.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    match last.kind {
        tk_rparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 and index + 1 < end {
                    return false;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return depth == 0;
}

fn is_binary_operator_position(tokens: ref list<token>, start: i32, index: i32) -> bool {
    if index <= start {
        return false;
    }
    let previous = token_at(ref tokens, index - 1);
    return token_can_end_expr(previous);
}

fn find_root_or_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_kw_or => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

