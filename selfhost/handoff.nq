                }
            },
            tk_kw_and => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_compare_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
