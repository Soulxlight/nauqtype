            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_eqeq => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_noteq => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_lt => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_gt => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_lte => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_gte => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_additive_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_plus => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            tk_minus => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_multiplicative_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_star => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            tk_slash => {
                if depth == 0 and brace_depth == 0 and is_binary_operator_position(ref tokens, start, index) {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn find_root_field_dot(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    let mut found = -1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_dot => {
                if depth == 0 and brace_depth == 0 {
                    found = index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return found;
}

fn span_is_call_expr(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 3 {
        return false;
    }
    let head = token_at(ref tokens, start);
    let open = token_at(ref tokens, start + 1);
    match head.kind {
        tk_ident => {
        },
        _ => {
            return false;
        },
    }
    match open.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start + 1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn span_is_struct_expr(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 3 {
        return false;
    }
    let head = token_at(ref tokens, start);
    let open = token_at(ref tokens, start + 1);
    match head.kind {
        tk_ident => {
        },
        _ => {
            return false;
        },
    }
    match open.kind {
        tk_lbrace => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start + 1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lbrace => {
                depth = depth + 1;
            },
            tk_rbrace => {
                depth = depth - 1;
                if depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn next_top_level_comma(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_comma => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return end;
}

fn find_top_level_colon(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_colon => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn lookup_module_id(modules: ref list<checked_module>, name: str) -> i32 {
    let mut index = 0;
    while index < list_len(ref modules) {
        let entry = list_get(ref modules, index);
        match entry {
            Some(value) => {
                if value.name == name {
                    return value.id;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

