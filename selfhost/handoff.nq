            let base_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, module_name, function_name, scope_id, ref tokens, expr_start, dot_index, field_token.start, empty_expected_type_ctx(), mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
            let base_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, module_name, function_name, scope_id, ref tokens, expr_start, dot_index, field_token.start, empty_expected_type_ctx(), mutref diags);
            let owner_module = visible_type_origin_module(ref uses, ref items, module_name, base_ctx.head);
            let expr_id = push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_field, exported_ctx, lookup_field_is_borrow(ref field_facts, owner_module, base_ctx.head, field_token.text), lookup_field_borrow_mutable(ref field_facts, owner_module, base_ctx.head, field_token.text), -1, "", checked_target_none, "", owner_module, base_ctx.head, field_token.text, ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
            if base_id < 0 {
