fn next_expr_id(expressions: ref list<checked_expr>) -> i32 {
    return list_len(ref expressions) + 1;
}

fn push_expr_child(expr_children: mutref list<checked_expr_child>, parent_expr_id: i32, index: i32, child_expr_id: i32) -> unit {
    list_push(mutref expr_children, checked_expr_child {
        parent_expr_id: parent_expr_id,
        index: index,
        child_expr_id: child_expr_id,
    });
    return;
}

fn build_literal_expr(function_id: i32, module_name: str, function_name: str, scope_id: i32, at: i32, start: i32, end: i32, kind: checked_expr_kind, type_name: str, name: str, uses: ref list<module_use>, items: ref list<top_item>, type_shapes: mutref list<checked_type_shape>, expressions: mutref list<checked_expr>, diags: mutref list<diag>) -> i32 {
    let expr_id = next_expr_id(ref expressions);
    let type_id = intern_checked_type_id(type_name, "", "", false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
    list_push(mutref expressions, checked_expr {
        id: expr_id,
        function_id: function_id,
        module_name: module_name,
        function_name: function_name,
        scope_id: scope_id,
        at: at,
        start: start,
        end: end,
        kind: kind,
        type_name: type_name,
        type_arg1_name: "",
        type_arg2_name: "",
        is_borrow: false,
        borrow_mutable: false,
        type_id: type_id,
        binding_id: -1,
        name: name,
        target_kind: checked_target_none,
        target_origin_module: "",
        field_owner_module: "",
        field_owner_type: "",
        field_name: "",
    });
    return expr_id;
}

fn push_expr_record(function_id: i32, module_name: str, function_name: str, scope_id: i32, at: i32, start: i32, end: i32, kind: checked_expr_kind, type_ctx: expected_type_ctx, is_borrow: bool, borrow_mutable: bool, binding_id: i32, name: str, target_kind: checked_target_kind, target_origin_module: str, field_owner_module: str, field_owner_type: str, field_name: str, uses: ref list<module_use>, items: ref list<top_item>, type_shapes: mutref list<checked_type_shape>, expressions: mutref list<checked_expr>, diags: mutref list<diag>) -> i32 {
    let expr_id = next_expr_id(ref expressions);
    let type_id = intern_checked_type_id(type_ctx.head, type_ctx.arg1_name, type_ctx.arg2_name, is_borrow, borrow_mutable, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
    list_push(mutref expressions, checked_expr {
        id: expr_id,
        function_id: function_id,
        module_name: module_name,
        function_name: function_name,
        scope_id: scope_id,
        at: at,
        start: start,
        end: end,
        kind: kind,
        type_name: type_ctx.head,
        type_arg1_name: type_ctx.arg1_name,
        type_arg2_name: type_ctx.arg2_name,
        is_borrow: is_borrow,
        borrow_mutable: borrow_mutable,
        type_id: type_id,
        binding_id: binding_id,
        name: name,
        target_kind: target_kind,
        target_origin_module: target_origin_module,
        field_owner_module: field_owner_module,
        field_owner_type: field_owner_type,
        field_name: field_name,
    });
    return expr_id;
}

fn binary_expr_kind(op: token_kind) -> checked_expr_kind {
    match op {
        tk_plus => {
            return checked_expr_add;
        },
        tk_minus => {
            return checked_expr_sub;
        },
        tk_star => {
            return checked_expr_mul;
        },
        tk_slash => {
            return checked_expr_div;
        },
        tk_eqeq => {
            return checked_expr_eq;
        },
        tk_noteq => {
            return checked_expr_ne;
        },
        tk_lt => {
            return checked_expr_lt;
        },
        tk_lte => {
            return checked_expr_lte;
        },
        tk_gt => {
            return checked_expr_gt;
        },
        tk_gte => {
            return checked_expr_gte;
        },
        tk_kw_and => {
            return checked_expr_and;
        },
        _ => {
            return checked_expr_or;
        },
    }
}

fn build_expr_tree(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, bindings: ref list<checked_binding>, resolved_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, function_id: i32, module_name: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, at: i32, expected_ctx: expected_type_ctx, type_shapes: mutref list<checked_type_shape>, expressions: mutref list<checked_expr>, expr_children: mutref list<checked_expr_child>, struct_fields: mutref list<checked_struct_field_init>, diags: mutref list<diag>) -> i32 {
    let diag_count_before = list_len(ref diags);
