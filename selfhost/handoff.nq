            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_eqeq => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_noteq => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_lt => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
            tk_gt => {
                if depth == 0 and brace_depth == 0 {
                    return index;
                }
            },
