        let expr_id = push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_call, exported_ctx, function_return_is_borrow_from_origin(ref functions, target_origin, head.text), function_return_borrow_mutable_from_origin(ref functions, target_origin, head.text), -1, head.text, target_kind, target_origin, "", "", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
        let mut arg_start = open_index + 1;
        let arg_end_limit = expr_end - 1;
        let mut arg_index = 0;
        let named_args = call_args_are_named(ref tokens, arg_start, arg_end_limit);
        if named_args and not (checked_target_kind_matches(target_kind, checked_target_function) or checked_target_kind_matches(target_kind, checked_target_builtin_function)) {
