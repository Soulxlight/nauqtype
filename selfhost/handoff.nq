    }

    let mut expr_start = start;
    let mut expr_end = end;
    while span_is_wrapped_in_parens(ref tokens, expr_start, expr_end) {
        expr_start = expr_start + 1;
        expr_end = expr_end - 1;
    }
    if expr_start >= expr_end {
        return build_literal_expr(function_id, module_name, function_name, scope_id, at, start, end, checked_expr_unit, "unit", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
    }

    let expr_head = token_at(ref tokens, expr_start);
    match expr_head.kind {
        tk_kw_match => {
            let expr_id = push_expr_record(function_id, module_name, function_name, scope_id, at, expr_start, expr_end, checked_expr_match, exported_ctx, false, false, -1, "", checked_target_none, "", "", "", "", ref uses, ref items, mutref type_shapes, mutref expressions, mutref diags);
            let mut scrutinee_end = expr_start + 1;
