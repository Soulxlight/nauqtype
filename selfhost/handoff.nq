        }
        if named_args {
            let param_count = handoff_function_param_count(ref functions, head.text, target_origin);
            while arg_index < param_count {
                let param_name = handoff_function_param_name(ref function_params, ref uses, ref items, module_name, qualifier, head.text, target_origin, arg_index);
                let segment_start = find_named_arg_segment_start(ref tokens, arg_start, arg_end_limit, param_name);
                if segment_start < 0 {
                    return consume_handoff_limitation_detail(mutref diags, module_name, head.start, str_concat("missing exported named call argument: ", param_name));
                }
                let segment_end = next_top_level_comma(ref tokens, segment_start, arg_end_limit);
                let mut arg_expected_ctx = empty_expected_type_ctx();
                if checked_target_kind_matches(target_kind, checked_target_function) {
                    arg_expected_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, target_origin, head.text, arg_index);
                } else {
                    if checked_target_kind_matches(target_kind, checked_target_builtin_function) {
                        arg_expected_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module_name, head.text, arg_index);
                    }
                }
                let child_id = build_expr_tree(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref bindings, ref resolved_bindings, ref field_facts, ref uses, ref items, function_id, module_name, function_name, scope_id, ref tokens, segment_value_start(ref tokens, segment_start, segment_end), segment_end, head.start, arg_expected_ctx, mutref type_shapes, mutref expressions, mutref expr_children, mutref struct_fields, mutref diags);
                if child_id < 0 {
                    return consume_handoff_limitation_detail(mutref diags, module_name, head.start, str_concat("missing exported named call argument expression for call: ", head.text));
                }
                push_expr_child(mutref expr_children, expr_id, arg_index, child_id);
                arg_index = arg_index + 1;
