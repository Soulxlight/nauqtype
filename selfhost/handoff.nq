            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
                if paren_depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

