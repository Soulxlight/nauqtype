    let mut index = 0;
    while index < list_len(ref enums) {
        let entry = list_get(ref enums, index);
        match entry {
            Some(value) => {
                if value.module_name == module_name and value.name == name {
                    return value.id;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

