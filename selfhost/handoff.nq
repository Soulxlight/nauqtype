    effects();
}
{
    let mut binding_id = -1;
    let mut param_index = 0;
    while param_index < list_len(ref params) {
        let param_entry = list_get(ref params, param_index);
        match param_entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and value.name == name and value.binding_id >= 0 {
                    binding_id = value.binding_id;
                }
            },
            None => {
            },
        }
        param_index = param_index + 1;
    }
    if binding_id < 0 {
        return false;
    }
    let mut expr_index = 0;
    while expr_index < list_len(ref expressions) {
        let expr_entry = list_get(ref expressions, expr_index);
        match expr_entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and checked_expr_kind_matches(value.kind, checked_expr_name) and value.name == name and value.binding_id == binding_id {
                    return true;
                }
            },
            None => {
            },
        }
        expr_index = expr_index + 1;
    }
    return false;
}

pub fn handoff_has_local_assignment_name_binding_reuse(statements: ref list<checked_stmt>, expressions: ref list<checked_expr>, module_name: str, function_name: str, name: str) -> bool
audit {
    intent("Check whether a local binding id is reused across declaration, assignment target, and later name expression");
    mutates();
    effects();
}
{
    let mut local_binding_id = -1;
    let mut saw_assignment = false;
    let mut stmt_index = 0;
    while stmt_index < list_len(ref statements) {
        let stmt_entry = list_get(ref statements, stmt_index);
        match stmt_entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and value.name == name {
                    if checked_stmt_kind_matches(value.kind, checked_stmt_local) and value.target_binding_id >= 0 {
                        local_binding_id = value.target_binding_id;
                    }
                    if checked_stmt_kind_matches(value.kind, checked_stmt_assign) and value.target_binding_id >= 0 {
                        if local_binding_id >= 0 and value.target_binding_id == local_binding_id {
                            saw_assignment = true;
                        }
                    }
                }
            },
            None => {
            },
        }
        stmt_index = stmt_index + 1;
    }
    if local_binding_id < 0 or not saw_assignment {
        return false;
    }
    let mut expr_index = 0;
    while expr_index < list_len(ref expressions) {
        let expr_entry = list_get(ref expressions, expr_index);
        match expr_entry {
            Some(value) => {
                if value.module_name == module_name and value.function_name == function_name and checked_expr_kind_matches(value.kind, checked_expr_name) and value.name == name and value.binding_id == local_binding_id {
                    return true;
                }
            },
            None => {
            },
        }
        expr_index = expr_index + 1;
    }
    return false;
}

