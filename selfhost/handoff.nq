fn checked_type_shape_kind_matches(left: checked_type_shape_kind, right: checked_type_shape_kind) -> bool {
    match left {
        checked_type_bool => {
            match right {
                checked_type_bool => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_i32 => {
            match right {
                checked_type_i32 => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_str => {
            match right {
                checked_type_str => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_unit => {
            match right {
                checked_type_unit => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_io_err => {
            match right {
                checked_type_io_err => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_process_result => {
            match right {
                checked_type_process_result => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_named => {
            match right {
                checked_type_named => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_list => {
            match right {
                checked_type_list => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_option => {
            match right {
                checked_type_option => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_result => {
            match right {
                checked_type_result => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
        checked_type_ref => {
            match right {
                checked_type_ref => {
                    return true;
                },
                _ => {
                    return false;
                },
            }
        },
    }
}

fn handoff_is_type_item(item: top_item) -> bool {
    match item.kind {
        item_type => {
            return true;
        },
        item_enum => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn lookup_checked_type_shape_id(type_shapes: ref list<checked_type_shape>, kind: checked_type_shape_kind, name: str, origin_module: str, arg1_id: i32, arg2_id: i32, mutable: bool) -> i32 {
    let mut index = 0;
    while index < list_len(ref type_shapes) {
        let entry = list_get(ref type_shapes, index);
        match entry {
            Some(value) => {
                if checked_type_shape_kind_matches(value.kind, kind) and value.name == name and value.origin_module == origin_module and value.arg1_id == arg1_id and value.arg2_id == arg2_id and value.mutable == mutable {
                    return value.id;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn push_type_shape(type_shapes: mutref list<checked_type_shape>, kind: checked_type_shape_kind, name: str, origin_module: str, arg1_id: i32, arg2_id: i32, mutable: bool) -> i32 {
    let existing = lookup_checked_type_shape_id(ref type_shapes, kind, name, origin_module, arg1_id, arg2_id, mutable);
    if existing >= 0 {
        return existing;
    }
    let next_id = list_len(ref type_shapes) + 1;
    list_push(mutref type_shapes, checked_type_shape {
        id: next_id,
        kind: kind,
        name: name,
        origin_module: origin_module,
        arg1_id: arg1_id,
        arg2_id: arg2_id,
        mutable: mutable,
    });
    return next_id;
}

fn canonical_type_origin_module(uses: ref list<module_use>, items: ref list<top_item>, module_name: str, type_name: str) -> str {
    if type_name == "" or type_name == "bool" or type_name == "i32" or type_name == "str" or type_name == "unit" or type_name == "io_err" or type_name == "list" or type_name == "option" or type_name == "result" {
        return "";
    }
    let origin = visible_type_origin_module(ref uses, ref items, module_name, type_name);
    if origin != "" {
        return origin;
    }
    let mut unique_origin = "";
    let mut found = false;
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value.name == type_name and handoff_is_type_item(value) {
                    if not found {
                        unique_origin = value.module;
                        found = true;
                    } else {
                        if unique_origin != value.module {
                            return module_name;
                        }
                    }
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    if found {
        return unique_origin;
    }
    return module_name;
}

fn intern_checked_type_id(type_name: str, type_arg1_name: str, type_arg2_name: str, is_borrow: bool, borrow_mutable: bool, module_name: str, uses: ref list<module_use>, items: ref list<top_item>, type_shapes: mutref list<checked_type_shape>, diags: mutref list<diag>, at: i32) -> i32 {
    if is_borrow {
        let inner_id = intern_checked_type_id(type_name, type_arg1_name, type_arg2_name, false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
        if inner_id < 0 {
            return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing inner type shape for checked borrow type");
        }
        return push_type_shape(mutref type_shapes, checked_type_ref, "", "", inner_id, -1, borrow_mutable);
    }
    if type_name == "" {
        return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing checked type information");
    }
    if type_name == "bool" {
        return push_type_shape(mutref type_shapes, checked_type_bool, "", "", -1, -1, false);
    }
    if type_name == "i32" {
        return push_type_shape(mutref type_shapes, checked_type_i32, "", "", -1, -1, false);
    }
    if type_name == "str" {
        return push_type_shape(mutref type_shapes, checked_type_str, "", "", -1, -1, false);
    }
    if type_name == "unit" {
        return push_type_shape(mutref type_shapes, checked_type_unit, "", "", -1, -1, false);
    }
    if type_name == "io_err" {
        return push_type_shape(mutref type_shapes, checked_type_io_err, "", "", -1, -1, false);
    }
    if type_name == "process_result" {
        return push_type_shape(mutref type_shapes, checked_type_process_result, "", "", -1, -1, false);
    }
    if type_name == "list" {
        if type_arg1_name == "" {
            return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing list element type in checked handoff");
        }
        let arg1_id = intern_checked_type_id(type_arg1_name, "", "", false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
        if arg1_id < 0 {
            return arg1_id;
        }
        return push_type_shape(mutref type_shapes, checked_type_list, "", "", arg1_id, -1, false);
    }
    if type_name == "option" {
        if type_arg1_name == "" {
            return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing option payload type in checked handoff");
        }
        let arg1_id = intern_checked_type_id(type_arg1_name, "", "", false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
        if arg1_id < 0 {
            return arg1_id;
        }
        return push_type_shape(mutref type_shapes, checked_type_option, "", "", arg1_id, -1, false);
    }
    if type_name == "result" {
        if type_arg1_name == "" or type_arg2_name == "" {
            return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing result payload type in checked handoff");
        }
        let arg1_id = intern_checked_type_id(type_arg1_name, "", "", false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
        let arg2_id = intern_checked_type_id(type_arg2_name, "", "", false, false, module_name, ref uses, ref items, mutref type_shapes, mutref diags, at);
        if arg1_id < 0 or arg2_id < 0 {
            return consume_handoff_limitation_detail(mutref diags, module_name, at, "missing result argument type shapes in checked handoff");
        }
        return push_type_shape(mutref type_shapes, checked_type_result, "", "", arg1_id, arg2_id, false);
    }
    return push_type_shape(mutref type_shapes, checked_type_named, type_name, canonical_type_origin_module(ref uses, ref items, module_name, type_name), -1, -1, false);
}

fn lookup_binding_type_id(bindings: ref list<checked_binding>, binding_id: i32) -> i32 {
    let mut index = 0;
    while index < list_len(ref bindings) {
        let entry = list_get(ref bindings, index);
        match entry {
            Some(value) => {
                if value.id == binding_id {
                    return value.type_id;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn build_expected_variant_payload_ctx(variant_name: str, expected_ctx: expected_type_ctx, payload_index: i32) -> expected_type_ctx {
    if variant_name == "Some" and payload_index == 0 and expected_ctx.head == "option" {
        return make_expected_type_ctx(expected_ctx.arg1_name, "", "");
    }
    if variant_name == "Ok" and payload_index == 0 and expected_ctx.head == "result" {
        return make_expected_type_ctx(expected_ctx.arg1_name, "", "");
    }
    if variant_name == "Err" and payload_index == 0 and expected_ctx.head == "result" {
        return make_expected_type_ctx(expected_ctx.arg2_name, "", "");
    }
    return empty_expected_type_ctx();
}

