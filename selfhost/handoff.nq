fn push_diag(diags: mutref list<diag>, file: str, at: i32, message: str) -> unit {
    list_push(mutref diags, make_diag(file, at, message));
    return;
}

fn push_handoff_limitation(diags: mutref list<diag>, file: str, at: i32) -> unit {
    push_diag(mutref diags, file, at, "stage1 limitation: checked handoff could not export the current expression or binding shape");
    return;
}

fn push_handoff_limitation_detail(diags: mutref list<diag>, file: str, at: i32, detail: str) -> unit {
    let prefix = "stage1 limitation: ";
    push_diag(mutref diags, file, at, str_concat(prefix, detail));
    return;
}

fn consume_handoff_limitation(diags: mutref list<diag>, file: str, at: i32) -> i32 {
    push_handoff_limitation(mutref diags, file, at);
    return -1;
}

fn consume_handoff_limitation_detail(diags: mutref list<diag>, file: str, at: i32, detail: str) -> i32 {
    push_handoff_limitation_detail(mutref diags, file, at, detail);
    return -1;
}

fn token_at(tokens: ref list<token>, index: i32) -> token {
    let found = list_get(ref tokens, index);
    match found {
        Some(value) => {
            return value;
        },
        None => {
            return eof_token(index);
        },
    }
}

fn token_is_ident(tok: token) -> bool {
    match tok.kind {
        tk_ident => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

