pub fn handoff_is_structurally_complete(statements: ref list<checked_stmt>, match_arms: ref list<checked_match_arm>, pattern_bindings: ref list<checked_pattern_binding>, expressions: ref list<checked_expr>, expr_children: ref list<checked_expr_child>, struct_fields: ref list<checked_struct_field_init>) -> bool
audit {
    intent("Check whether checked handoff ids and child links are structurally complete");
    mutates();
    effects();
}
{
    let mut stmt_index = 0;
    while stmt_index < list_len(ref statements) {
        let stmt_entry = list_get(ref statements, stmt_index);
        match stmt_entry {
            Some(value) => {
                if value.expr_id <= 0 {
                    return false;
                }
                let expr_entry = list_get(ref expressions, value.expr_id - 1);
                match expr_entry {
                    Some(expr_value) => {
                        if expr_value.id != value.expr_id {
                            return false;
                        }
                    },
                    None => {
                        return false;
                    },
                }
                match value.kind {
                    checked_stmt_if => {
                        if value.child_block_id <= 0 {
                            return false;
                        }
                    },
                    checked_stmt_while => {
                        if value.child_block_id <= 0 {
                            return false;
                        }
                    },
                    checked_stmt_match => {
                        let mut has_arm = false;
                        let mut arm_search_index = 0;
                        while arm_search_index < list_len(ref match_arms) {
                            let arm_search_entry = list_get(ref match_arms, arm_search_index);
                            match arm_search_entry {
                                Some(arm_value) => {
                                    if arm_value.stmt_id == value.id {
                                        has_arm = true;
                                    }
                                },
                                None => {
                                },
                            }
                            arm_search_index = arm_search_index + 1;
                        }
                        if not has_arm {
                            return false;
                        }
                    },
                    _ => {
                    },
                }
            },
            None => {
            },
        }
        stmt_index = stmt_index + 1;
    }

    let mut arm_index = 0;
    while arm_index < list_len(ref match_arms) {
        let arm_entry = list_get(ref match_arms, arm_index);
        match arm_entry {
            Some(value) => {
                if value.stmt_id <= 0 or value.block_id <= 0 {
                    return false;
                }
            },
            None => {
            },
        }
        arm_index = arm_index + 1;
    }

    let mut pattern_index = 0;
    while pattern_index < list_len(ref pattern_bindings) {
        let pattern_entry = list_get(ref pattern_bindings, pattern_index);
        match pattern_entry {
            Some(value) => {
                if value.arm_id <= 0 or value.binding_id <= 0 {
                    return false;
                }
            },
            None => {
            },
        }
        pattern_index = pattern_index + 1;
    }

    let mut expr_index = 0;
    while expr_index < list_len(ref expressions) {
        let expr_entry = list_get(ref expressions, expr_index);
        match expr_entry {
            Some(value) => {
                match value.kind {
                    checked_expr_name => {
                        if value.binding_id <= 0 {
                            return false;
                        }
                    },
                    checked_expr_ref => {
                        if value.binding_id <= 0 or not value.is_borrow {
                            return false;
                        }
                    },
                    checked_expr_mutref => {
                        if value.binding_id <= 0 or not value.is_borrow {
                            return false;
                        }
                    },
                    _ => {
                    },
                }
            },
            None => {
            },
        }
        expr_index = expr_index + 1;
    }

    let mut child_index = 0;
    while child_index < list_len(ref expr_children) {
        let child_entry = list_get(ref expr_children, child_index);
        match child_entry {
            Some(value) => {
                let parent_entry = list_get(ref expressions, value.parent_expr_id - 1);
                let expr_entry = list_get(ref expressions, value.child_expr_id - 1);
                match parent_entry {
                    Some(parent_value) => {
                        if parent_value.id != value.parent_expr_id {
                            return false;
                        }
                    },
                    None => {
                        return false;
                    },
                }
                match expr_entry {
                    Some(expr_value) => {
                        if expr_value.id != value.child_expr_id {
                            return false;
                        }
                    },
                    None => {
                        return false;
                    },
                }
            },
            None => {
            },
        }
        child_index = child_index + 1;
    }

    let mut field_index = 0;
    while field_index < list_len(ref struct_fields) {
        let field_entry = list_get(ref struct_fields, field_index);
        match field_entry {
            Some(value) => {
                let struct_entry = list_get(ref expressions, value.expr_id - 1);
                let value_entry = list_get(ref expressions, value.value_expr_id - 1);
                match struct_entry {
                    Some(struct_expr) => {
                        if struct_expr.id != value.expr_id {
                            return false;
                        }
                    },
                    None => {
                        return false;
                    },
                }
                match value_entry {
                    Some(field_expr) => {
                        if field_expr.id != value.value_expr_id {
                            return false;
                        }
                    },
                    None => {
                        return false;
                    },
                }
            },
            None => {
            },
        }
        field_index = field_index + 1;
    }

    return true;
}

