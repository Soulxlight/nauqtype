        let scan_entry = list_get(ref field_values, scan_index);
        match scan_entry {
            Some(value) => {
                if value.expr_id == expr_id {
                    count = count + 1;
                }
            },
            None => {
            },
        }
        scan_index = scan_index + 1;
    }
    let mut target_index = 0;
    while target_index < count {
        let mut index = 0;
        while index < list_len(ref field_values) {
            let entry = list_get(ref field_values, index);
            match entry {
                Some(value) => {
                    if value.expr_id == expr_id and value.index == target_index {
