fn lookup_expr_child_ids(expr_children: ref list<ir_expr_child>, parent_expr_id: i32) -> list<i32> {
    let mut ids: list<i32> = list();
    let mut count = 0;
    let mut scan_index = 0;
    while scan_index < list_len(ref expr_children) {
        let scan_entry = list_get(ref expr_children, scan_index);
        match scan_entry {
            Some(value) => {
                if value.parent_expr_id == parent_expr_id {
                    count = count + 1;
                }
            },
            None => {
            },
        }
        scan_index = scan_index + 1;
    }
    let mut target_index = 0;
    while target_index < count {
        let mut index = 0;
        while index < list_len(ref expr_children) {
            let entry = list_get(ref expr_children, index);
            match entry {
                Some(value) => {
                    if value.parent_expr_id == parent_expr_id and value.index == target_index {
                        list_push(mutref ids, value.child_expr_id);
                    }
                },
                None => {
                },
            }
            index = index + 1;
        }
        target_index = target_index + 1;
    }
    return ids;
}

