use diag;
use handoff;
use ir;

pub type c_emit_summary {
    line_count: i32,
    function_count: i32,
    diag_count: i32,
}

type result_generic_entry {
    ok_type_id: i32,
    err_type_id: i32,
}

pub fn make_c_emit_summary(line_count: i32, function_count: i32, diag_count: i32) -> c_emit_summary
audit {
    intent("Build a stage1 C-emission summary record");
    mutates();
    effects();
}
{
    return c_emit_summary {
        line_count: line_count,
        function_count: function_count,
        diag_count: diag_count,
    };
}

fn push_diag(diags: mutref list<diag>, file: str, at: i32, message: str) -> unit {
    list_push(mutref diags, make_diag(file, at, message));
    return;
}

fn push_c_error(diags: mutref list<diag>, file: str, at: i32, detail: str) -> unit {
    push_diag(mutref diags, file, at, str_concat("stage1 c error: ", detail));
    return;
}

fn concat3(a: str, b: str, c: str) -> str {
    return str_concat(str_concat(a, b), c);
}

fn concat4(a: str, b: str, c: str, d: str) -> str {
    return str_concat(str_concat(a, b), str_concat(c, d));
}

fn concat5(a: str, b: str, c: str, d: str, e: str) -> str {
    return str_concat(str_concat(str_concat(a, b), str_concat(c, d)), e);
}

fn concat6(a: str, b: str, c: str, d: str, e: str, f: str) -> str {
    return str_concat(str_concat(str_concat(a, b), str_concat(c, d)), str_concat(e, f));
}

fn concat7(a: str, b: str, c: str, d: str, e: str, f: str, g: str) -> str {
    return str_concat(concat6(a, b, c, d, e, f), g);
}

fn digit_text(value: i32) -> str {
    if value == 0 {
        return "0";
    }
    if value == 1 {
        return "1";
    }
    if value == 2 {
        return "2";
    }
    if value == 3 {
        return "3";
    }
    if value == 4 {
        return "4";
    }
    if value == 5 {
        return "5";
    }
    if value == 6 {
        return "6";
    }
    if value == 7 {
        return "7";
    }
    if value == 8 {
        return "8";
    }
    return "9";
}

fn i32_to_str(value: i32) -> str {
    if value == 0 {
        return "0";
    }
    let mut remaining = value;
    let mut negative = false;
    if remaining < 0 {
        negative = true;
        remaining = 0 - remaining;
    }
    let mut reversed: list<str> = list();
    while remaining > 0 {
        let digit = remaining - ((remaining / 10) * 10);
        list_push(mutref reversed, digit_text(digit));
        remaining = remaining / 10;
    }
    let mut text = "";
    if negative {
        text = "-";
    }
    let mut index = list_len(ref reversed) - 1;
    while index >= 0 {
        let entry = list_get(ref reversed, index);
        match entry {
            Some(value_text) => {
                text = str_concat(text, value_text);
            },
            None => {
            },
        }
        index = index - 1;
    }
    return text;
}

fn str_less(left: str, right: str) -> bool {
    let mut index = 0;
    let left_len = str_len(left);
    let right_len = str_len(right);
    while index < left_len and index < right_len {
        let left_entry = str_get(left, index);
        let right_entry = str_get(right, index);
        match left_entry {
            Some(left_value) => {
                match right_entry {
                    Some(right_value) => {
                        if left_value < right_value {
                            return true;
                        }
                        if left_value > right_value {
                            return false;
                        }
                    },
                    None => {
                    },
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return left_len < right_len;
}

fn indent(level: i32) -> str {
    let mut text = "";
    let mut index = 0;
    while index < level {
        text = str_concat(text, "    ");
        index = index + 1;
    }
    return text;
}

fn append_line(lines: mutref list<str>, text: str) -> unit {
    list_push(mutref lines, text);
    return;
}

fn list_contains_i32(items: ref list<i32>, target: i32) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value == target {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn list_contains_result_entry(items: ref list<result_generic_entry>, ok_type_id: i32, err_type_id: i32) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value.ok_type_id == ok_type_id and value.err_type_id == err_type_id {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

