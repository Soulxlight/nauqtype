pub enum token_kind {
    tk_eof,
    tk_ident,
    tk_int_lit,
    tk_string_lit,
    tk_lparen,
    tk_rparen,
    tk_lbrace,
    tk_rbrace,
    tk_comma,
    tk_semi,
    tk_colon,
    tk_dot,
    tk_eq,
    tk_lt,
    tk_gt,
    tk_plus,
    tk_minus,
    tk_star,
    tk_slash,
    tk_arrow,
    tk_fat_arrow,
    tk_eqeq,
    tk_noteq,
    tk_lte,
    tk_gte,
    tk_kw_and,
    tk_kw_audit,
    tk_kw_const,
    tk_kw_else,
    tk_kw_enum,
    tk_kw_false,
    tk_kw_fn,
    tk_kw_if,
    tk_kw_let,
    tk_kw_match,
    tk_kw_mut,
    tk_kw_mutref,
    tk_kw_not,
    tk_kw_or,
    tk_kw_pub,
    tk_kw_ref,
    tk_kw_return,
    tk_kw_true,
    tk_kw_type,
    tk_kw_use,
    tk_kw_while,
    tk_unknown,
}

pub type token {
    kind: token_kind,
    text: str,
    start: i32,
    end: i32,
}

pub fn make_token(kind: token_kind, text: str, start: i32, end: i32) -> token
audit {
    intent("Build an immutable token record");
    mutates();
    effects();
}
{
    return token {
        kind: kind,
        text: text,
        start: start,
        end: end,
    };
}

pub fn eof_token(position: i32) -> token
audit {
    intent("Build an eof token sentinel");
    mutates();
    effects();
}
{
    return make_token(tk_eof, "", position, position);
}

