pub type fmt_result {
    ok: bool,
    changed: bool,
    text: str,
    error: str,
}

fn make_fmt_result(ok: bool, changed: bool, text: str, error: str) -> fmt_result {
    return fmt_result {
        ok: ok,
        changed: changed,
        text: text,
        error: error,
    };
}

fn slice_text(text: str, start: i32, end: i32) -> str {
    let value = str_slice(text, start, end);
    match value {
        Some(result) => {
            return result;
        },
        None => {
            return "";
        },
    }
}

fn char_at(text: str, index: i32) -> i32 {
    let value = str_get(text, index);
    match value {
        Some(result) => {
            return result;
        },
        None => {
            return -1;
        },
    }
}

fn line_has_tab(text: str) -> bool {
    let mut index = 0;
    while index < str_len(text) {
        if char_at(text, index) == 9 {
            return true;
        }
        index = index + 1;
    }
    return false;
}

fn trim_line(text: str) -> str {
    let mut start = 0;
    let mut end = str_len(text);
    while start < end and char_at(text, start) == 32 {
        start = start + 1;
    }
    while end > start and (char_at(text, end - 1) == 32 or char_at(text, end - 1) == 13) {
        end = end - 1;
    }
    return slice_text(text, start, end);
}

fn starts_with_closing_brace(text: str) -> bool {
    if str_len(text) == 0 {
        return false;
    }
    return char_at(text, 0) == 125;
}

fn indent_text(depth: i32) -> str {
    let mut result = "";
    let mut index = 0;
    while index < depth {
        result = str_concat(result, "    ");
        index = index + 1;
    }
    return result;
}

fn brace_delta(text: str) -> i32 {
    let mut delta = 0;
    let mut in_string = false;
    let mut escaped = false;
    let mut index = 0;
    while index < str_len(text) {
        let ch = char_at(text, index);
        if in_string {
            if escaped {
                escaped = false;
            } else {
                if ch == 92 {
                    escaped = true;
                } else {
                    if ch == 34 {
                        in_string = false;
                    }
                }
            }
        } else {
            if ch == 47 and char_at(text, index + 1) == 47 {
                return delta;
            }
            if ch == 34 {
                in_string = true;
            } else {
                if ch == 123 {
                    delta = delta + 1;
                } else {
                    if ch == 125 {
                        delta = delta - 1;
                    }
                }
            }
        }
        index = index + 1;
    }
    return delta;
}

fn append_formatted_line(output: str, line: str, depth: i32) -> str {
    if line == "" {
        return str_concat(output, "\n");
    }
    return str_concat(output, str_concat(indent_text(depth), str_concat(line, "\n")));
}

fn format_line(output: str, raw_line: str, depth: mutref i32, ok: mutref bool, error: mutref str) -> str {
    if line_has_tab(raw_line) {
        ok = false;
        error = "formatter-lite unsupported: tabs";
        return output;
    }
    let line = trim_line(raw_line);
    let mut indent_depth = depth;
    if starts_with_closing_brace(line) {
        indent_depth = indent_depth - 1;
    }
    if indent_depth < 0 {
        ok = false;
        error = "formatter-lite unsupported: unbalanced closing brace";
        return output;
    }
    let next_output = append_formatted_line(output, line, indent_depth);
    depth = depth + brace_delta(line);
    if depth < 0 {
        ok = false;
        error = "formatter-lite unsupported: unbalanced closing brace";
        return next_output;
    }
    return next_output;
}

pub fn format_text(text: str) -> fmt_result
audit {
    intent("Format trusted-subset Nauqtype source deterministically without mutating files");
    mutates();
    effects();
}
{
    let mut output = "";
    let mut depth = 0;
    let mut ok = true;
    let mut error = "";
    let mut start = 0;
    let mut index = 0;
    while index < str_len(text) and ok {
        if char_at(text, index) == 10 {
            output = format_line(output, slice_text(text, start, index), mutref depth, mutref ok, mutref error);
            start = index + 1;
        }
        index = index + 1;
    }
    if ok and start < str_len(text) {
        output = format_line(output, slice_text(text, start, str_len(text)), mutref depth, mutref ok, mutref error);
    }
    if ok and depth != 0 {
        ok = false;
        error = "formatter-lite unsupported: unbalanced opening brace";
    }
    if not ok {
        return make_fmt_result(false, false, "", error);
    }
    return make_fmt_result(true, output != text, output, "");
}

fn emit_text(text: str) -> unit {
    let mut start = 0;
    let mut index = 0;
    while index < str_len(text) {
        if char_at(text, index) == 10 {
            print_line(slice_text(text, start, index));
            start = index + 1;
        }
        index = index + 1;
    }
    if start < str_len(text) {
        print_line(slice_text(text, start, str_len(text)));
    }
    return;
}

pub fn run_fmt(source_path: str, check_only: bool) -> i32
audit {
    intent("Run formatter-lite in output or check mode");
    mutates();
    effects(print);
}
{
    let loaded = read_file(source_path);
    match loaded {
        Ok(text) => {
            let result = format_text(text);
            if not result.ok {
                eprint_line(result.error);
                return 1;
            }
            if check_only {
                if result.changed {
                    eprint_line(str_concat("fmt check failed: ", source_path));
                    return 1;
                }
                return 0;
            }
            emit_text(result.text);
            return 0;
        },
        Err(err) => {
            eprint_line(io_err_text(err));
            return 1;
        },
    }
}
