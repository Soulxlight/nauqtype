fn builtin_function_param_type_name(function_name: str, index: i32) -> str {
    if function_name == "print_line" or function_name == "eprint_line" or function_name == "read_file" {
        if index == 0 {
            return "str";
        }
    }
    if function_name == "write_file" {
        if index == 0 or index == 1 {
            return "str";
        }
    }
    if function_name == "io_err_text" {
        if index == 0 {
            return "io_err";
        }
    }
    if function_name == "run_process" {
        if index == 0 or index == 2 {
            return "str";
        }
        if index == 1 {
            return "list";
        }
    }
    if function_name == "str_len" {
        if index == 0 {
            return "str";
        }
    }
    if function_name == "str_concat" {
        if index == 0 or index == 1 {
            return "str";
        }
    }
    if function_name == "str_get" {
        if index == 0 {
            return "str";
        }
        if index == 1 {
            return "i32";
        }
    }
    if function_name == "str_slice" {
        if index == 0 {
            return "str";
        }
        if index == 1 or index == 2 {
            return "i32";
        }
    }
    if function_name == "list_push" {
        if index == 0 {
            return "list";
        }
    }
    if function_name == "list_len" {
        if index == 0 {
            return "list";
        }
    }
    if function_name == "list_get" {
        if index == 0 {
            return "list";
        }
        if index == 1 {
            return "i32";
        }
    }
    return "";
}

fn builtin_function_param_ctx(function_name: str, index: i32) -> expected_type_ctx {
    let builtin = builtin_function_param_type_name(function_name, index);
    if builtin == "" {
        return empty_expected_type_ctx();
    }
    if function_name == "run_process" and index == 1 {
        return make_expected_type_ctx("list", "str", "");
    }
    return make_expected_type_ctx(builtin, "", "");
}

fn visible_function_param_type_name(function_params: ref list<function_param_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, index: i32) -> str {
