fn visible_zero_arg_variant_enum_name(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str {
    let builtin = builtin_variant_enum_name(name);
    if builtin != "" and builtin_variant_arity(name) == 0 {
        return builtin;
    }
    let variant_arity = visible_variant_arity(ref variants, ref uses, ref items, module, name);
    if variant_arity == 0 {
        return visible_variant_enum_name(ref variants, ref uses, ref items, module, name);
    }
    return "";
}

fn visible_zero_arg_variant_ctx(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str, expected_ctx: expected_type_ctx) -> expected_type_ctx {
    let enum_name = visible_zero_arg_variant_enum_name(ref variants, ref uses, ref items, module, name);
    if enum_name == "" {
        return empty_expected_type_ctx();
    }
    if builtin_variant_enum_name(name) != "" and expected_ctx.head != "" and type_names_match(enum_name, expected_ctx.head) {
        return expected_ctx;
    }
    return make_expected_type_ctx(enum_name, "", "");
}

