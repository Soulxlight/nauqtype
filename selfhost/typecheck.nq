            },
        }
        index = index + 1;
    }
    return false;
}

fn segment_label_colon(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    if start + 2 > end {
        return -1;
    }
    let label = token_at(ref tokens, start);
    let colon = token_at(ref tokens, start + 1);
    match label.kind {
        tk_ident => {
            match colon.kind {
                tk_colon => {
                    return start + 1;
                },
                _ => {
                },
            }
        },
        _ => {
        },
    }
    return -1;
}

fn segment_label_name(tokens: ref list<token>, start: i32, end: i32) -> str {
    if segment_label_colon(ref tokens, start, end) >= 0 {
        let label = token_at(ref tokens, start);
        return label.text;
    }
    return "";
}

fn segment_value_start(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let colon = segment_label_colon(ref tokens, start, end);
    if colon >= 0 {
        return colon + 1;
    }
    return start;
}

fn call_args_are_named(tokens: ref list<token>, arg_start: i32, arg_end_limit: i32) -> bool {
    if arg_start >= arg_end_limit {
        return false;
    }
    let first_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
    return segment_label_colon(ref tokens, arg_start, first_end) >= 0;
}

fn find_named_arg_segment_start(tokens: ref list<token>, arg_start: i32, arg_end_limit: i32, label: str) -> i32 {
    let mut current_start = arg_start;
    while current_start < arg_end_limit {
        let segment_end = next_top_level_comma(ref tokens, current_start, arg_end_limit);
        if segment_label_name(ref tokens, current_start, segment_end) == label {
            return current_start;
        }
        current_start = segment_end + 1;
    }
    return -1;
}

fn named_arg_label_seen_before(tokens: ref list<token>, arg_start: i32, segment_start: i32, label: str) -> bool {
    let mut current_start = arg_start;
    while current_start < segment_start {
        let segment_end = next_top_level_comma(ref tokens, current_start, segment_start);
        if segment_label_name(ref tokens, current_start, segment_end) == label {
            return true;
        }
        current_start = segment_end + 1;
    }
    return false;
}

fn span_is_list_expr(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 2 {
        return false;
    }
    let first = token_at(ref tokens, start);
    match first.kind {
        tk_lbracket => {
        },
        _ => {
            return false;
        },
    }
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                paren_depth = paren_depth + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
                if paren_depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn next_top_level_comma(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
            },
            tk_comma => {
                if depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return end;
}

fn find_top_level_colon(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
            },
            tk_colon => {
                if depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

fn count_expected_fields(field_facts: ref list<field_fact>, module: str, type_name: str) -> i32 {
    let mut count = 0;
    let mut index = 0;
    while index < list_len(ref field_facts) {
        let entry = list_get(ref field_facts, index);
        match entry {
            Some(value) => {
                if value.module == module and value.type_name == type_name {
                    count = count + 1;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return count;
}

fn struct_literal_has_field(tokens: ref list<token>, start: i32, end: i32, field_name: str) -> bool {
    let mut field_start = start + 2;
    let field_end_limit = end - 1;
    while field_start < field_end_limit {
        let segment_end = next_top_level_comma(ref tokens, field_start, field_end_limit);
        let colon_index = find_top_level_colon(ref tokens, field_start, segment_end);
        if colon_index >= 0 {
            let field_token = token_at(ref tokens, field_start);
            match field_token.kind {
                tk_ident => {
                    if field_token.text == field_name {
                        return true;
                    }
                },
                _ => {
                },
            }
        }
        field_start = segment_end + 1;
    }
    return false;
}

fn push_stage1_limitation(diags: mutref list<diag>, file: str, at: i32) -> unit {
    push_diag(mutref diags, file, at, "stage1 limitation: unsupported expression shape in recursive type checker");
    return;
}

fn builtin_variant_return_ctx(call_name: str, expected_ctx: expected_type_ctx) -> expected_type_ctx {
    let enum_name = builtin_variant_enum_name(call_name);
    if enum_name == "" {
        return empty_expected_type_ctx();
    }
    if expected_ctx.head != "" and type_names_match(enum_name, expected_ctx.head) {
        return expected_ctx;
    }
    return make_expected_type_ctx(enum_name, "", "");
}

fn builtin_variant_payload_ctx(call_name: str, return_ctx: expected_type_ctx, index: i32) -> expected_type_ctx {
    if index != 0 {
        return empty_expected_type_ctx();
    }
    if call_name == "Some" {
        return make_expected_type_ctx(return_ctx.arg1_name, "", "");
    }
    if call_name == "Ok" {
        return make_expected_type_ctx(return_ctx.arg1_name, "", "");
    }
    if call_name == "Err" {
        return make_expected_type_ctx(return_ctx.arg2_name, "", "");
    }
    return empty_expected_type_ctx();
}

fn infer_call_expr_type_ctx(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, expected_ctx: expected_type_ctx, diags: mutref list<diag>) -> expected_type_ctx {
    let name_index = span_call_name_index(ref tokens, start, end);
    let open_index = span_call_open_index(ref tokens, start, end);
    let head = token_at(ref tokens, name_index);
    let call_name = head.text;
    let qualifier = span_call_qualifier(ref tokens, start, end);
    let mut function_return_ctx = visible_function_return_ctx(ref functions, ref uses, ref items, module, call_name);
    if qualifier != "" {
        function_return_ctx = qualified_function_return_ctx(ref functions, ref uses, ref items, module, qualifier, call_name);
        if function_return_ctx.head == "" {
            push_diag(mutref diags, module, head.start, "unknown qualified function call target");
        }
    }
    let mut variant_enum_name = visible_variant_enum_name(ref variants, ref uses, ref items, module, call_name);
    if qualifier != "" {
        variant_enum_name = "";
    }
    let mut call_return_ctx = function_return_ctx;
    if function_return_ctx.head != "" {
        if call_name == "list" and expected_ctx.head != "" and type_names_match(expected_ctx.head, "list") {
            call_return_ctx = expected_ctx;
        }
    } else {
        if variant_enum_name != "" {
            if builtin_variant_enum_name(call_name) != "" {
                call_return_ctx = builtin_variant_return_ctx(call_name, expected_ctx);
            } else {
                call_return_ctx = make_expected_type_ctx(variant_enum_name, "", "");
            }
        }
    }
    let mut arg_start = open_index + 1;
    let arg_end_limit = end - 1;
    let mut arg_index = 0;
    let mut first_arg_ctx = empty_expected_type_ctx();
    let named_args = call_args_are_named(ref tokens, arg_start, arg_end_limit);

    if named_args and variant_enum_name != "" {
        push_diag(mutref diags, module, head.start, "named arguments are only supported for function calls");
    }

    if named_args and function_return_ctx.head != "" {
        let mut fn_arity = visible_function_arity(ref functions, ref uses, ref items, module, call_name);
        if qualifier != "" {
            fn_arity = qualified_function_arity(ref functions, ref uses, ref items, module, qualifier, call_name);
        }
        let mut scan_start = arg_start;
        while scan_start < arg_end_limit {
            let scan_end = next_top_level_comma(ref tokens, scan_start, arg_end_limit);
            let label = segment_label_name(ref tokens, scan_start, scan_end);
            if label == "" {
                push_diag(mutref diags, module, head.start, "cannot mix positional and named arguments");
            } else {
                if named_arg_label_seen_before(ref tokens, arg_start, scan_start, label) {
                    push_diag(mutref diags, module, head.start, "duplicate named argument");
                }
                let mut label_known = false;
                let mut param_scan = 0;
                while param_scan < fn_arity {
                    let mut candidate_name = "";
                    if qualifier != "" {
                        candidate_name = qualified_function_param_name(ref function_params, ref uses, ref items, module, qualifier, call_name, param_scan);
                    } else {
                        candidate_name = visible_function_param_name(ref function_params, ref uses, ref items, module, call_name, param_scan);
                    }
                    if candidate_name == label {
                        label_known = true;
                    }
                    param_scan = param_scan + 1;
                }
                if not label_known {
                    push_diag(mutref diags, module, head.start, "unknown named argument");
                }
            }
            scan_start = scan_end + 1;
        }
        while arg_index < fn_arity {
            let mut expected_arg_ctx = empty_expected_type_ctx();
            if call_name == "list_push" {
                if arg_index == 0 {
                    expected_arg_ctx = make_expected_type_ctx("list", "", "");
                } else {
                    if arg_index == 1 and first_arg_ctx.head == "list" and first_arg_ctx.arg1_name != "" {
                        expected_arg_ctx = make_expected_type_ctx(first_arg_ctx.arg1_name, "", "");
                    } else {
                        expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                    }
                }
            } else {
                if call_name == "list_get" {
                    if arg_index == 0 {
                        expected_arg_ctx = make_expected_type_ctx("list", "", "");
                    } else {
                        expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                    }
                } else {
                    if qualifier != "" {
                        expected_arg_ctx = qualified_function_param_ctx(ref function_params, ref uses, ref items, module, qualifier, call_name, arg_index);
                    } else {
                        expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                    }
                }
            }
            let mut param_name = "";
            if qualifier != "" {
                param_name = qualified_function_param_name(ref function_params, ref uses, ref items, module, qualifier, call_name, arg_index);
            } else {
                param_name = visible_function_param_name(ref function_params, ref uses, ref items, module, call_name, arg_index);
            }
            let segment_start = find_named_arg_segment_start(ref tokens, arg_start, arg_end_limit, param_name);
            if segment_start < 0 {
                push_diag(mutref diags, module, head.start, "missing named argument for parameter");
            } else {
                let segment_end = next_top_level_comma(ref tokens, segment_start, arg_end_limit);
                let actual_arg_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, segment_value_start(ref tokens, segment_start, segment_end), segment_end, head.start, expected_arg_ctx, mutref diags);
                if arg_index == 0 {
                    first_arg_ctx = actual_arg_ctx;
                }
                if expected_arg_ctx.head != "" and has_known_type_ctx(actual_arg_ctx) and not type_ctx_matches(expected_arg_ctx, actual_arg_ctx) {
                    push_diag(mutref diags, module, head.start, "call argument type does not match parameter type");
                }
            }
            arg_index = arg_index + 1;
        }
    } else {
        while arg_start < arg_end_limit {
            let segment_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
            if segment_label_colon(ref tokens, arg_start, segment_end) >= 0 {
                push_diag(mutref diags, module, head.start, "cannot mix positional and named arguments");
            }
            let mut expected_arg_ctx = empty_expected_type_ctx();
            if function_return_ctx.head != "" {
                if call_name == "list_push" {
                    if arg_index == 0 {
                        expected_arg_ctx = make_expected_type_ctx("list", "", "");
                    } else {
                        if arg_index == 1 and first_arg_ctx.head == "list" and first_arg_ctx.arg1_name != "" {
                            expected_arg_ctx = make_expected_type_ctx(first_arg_ctx.arg1_name, "", "");
                        } else {
                            expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                        }
                    }
                } else {
                    if call_name == "list_get" {
                        if arg_index == 0 {
                            expected_arg_ctx = make_expected_type_ctx("list", "", "");
                        } else {
                            expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                        }
                    } else {
                        if qualifier != "" {
                            expected_arg_ctx = qualified_function_param_ctx(ref function_params, ref uses, ref items, module, qualifier, call_name, arg_index);
                        } else {
                            expected_arg_ctx = visible_function_param_ctx(ref function_params, ref uses, ref items, module, call_name, arg_index);
                        }
                    }
                }
            } else {
                if variant_enum_name != "" {
                    if builtin_variant_enum_name(call_name) != "" {
                        expected_arg_ctx = builtin_variant_payload_ctx(call_name, call_return_ctx, arg_index);
                    } else {
                        expected_arg_ctx = visible_variant_payload_ctx(ref variant_payloads, ref uses, ref items, module, call_name, arg_index);
                    }
                }
            }
            let actual_arg_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, segment_value_start(ref tokens, arg_start, segment_end), segment_end, head.start, expected_arg_ctx, mutref diags);
            if arg_index == 0 {
                first_arg_ctx = actual_arg_ctx;
            }
            if function_return_ctx.head != "" {
                if expected_arg_ctx.head != "" and has_known_type_ctx(actual_arg_ctx) and not type_ctx_matches(expected_arg_ctx, actual_arg_ctx) {
                    push_diag(mutref diags, module, head.start, "call argument type does not match parameter type");
                }
            } else {
                if variant_enum_name != "" {
                    if expected_arg_ctx.head != "" and has_known_type_ctx(actual_arg_ctx) and not type_ctx_matches(expected_arg_ctx, actual_arg_ctx) {
                        push_diag(mutref diags, module, head.start, "constructor payload type does not match variant payload type");
                    }
                }
            }
            arg_index = arg_index + 1;
            arg_start = segment_end + 1;
        }
    }

    if call_return_ctx.head != "" {
        if call_name == "list_get" and first_arg_ctx.head == "list" {
            return make_expected_type_ctx("option", first_arg_ctx.arg1_name, "");
        }
        return call_return_ctx;
    }
    return make_expected_type_ctx(variant_enum_name, "", "");
}

fn infer_struct_expr_type_ctx(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, diags: mutref list<diag>) -> expected_type_ctx {
    let type_token = token_at(ref tokens, start);
    let type_name = type_token.text;
    let origin_module = visible_type_origin_module(ref uses, ref items, module, type_name);
    if origin_module == "" {
        return empty_expected_type_ctx();
    }

    let mut field_start = start + 2;
    let field_end_limit = end - 1;
    while field_start < field_end_limit {
        let segment_end = next_top_level_comma(ref tokens, field_start, field_end_limit);
        let colon_index = find_top_level_colon(ref tokens, field_start, segment_end);
        if colon_index < 0 {
            push_stage1_limitation(mutref diags, module, type_token.start);
            return unsupported_type_ctx();
        }
        let field_token = token_at(ref tokens, field_start);
        let mut field_name = "";
        match field_token.kind {
            tk_ident => {
                field_name = field_token.text;
            },
            _ => {
                push_stage1_limitation(mutref diags, module, type_token.start);
                return unsupported_type_ctx();
            },
        }
        let expected_field_ctx = lookup_field_ctx(ref field_facts, origin_module, type_name, field_name);
        if expected_field_ctx.head == "" {
            push_diag(mutref diags, module, field_token.start, "struct literal field does not exist on type");
        }
        let actual_field_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, colon_index + 1, segment_end, field_token.start, expected_field_ctx, mutref diags);
        if expected_field_ctx.head != "" and has_known_type_ctx(actual_field_ctx) and not type_ctx_matches(expected_field_ctx, actual_field_ctx) {
            push_diag(mutref diags, module, field_token.start, "struct literal field does not match declared field type");
        }
        field_start = segment_end + 1;
    }

    let mut field_index = 0;
    while field_index < list_len(ref field_facts) {
        let entry = list_get(ref field_facts, field_index);
        match entry {
            Some(value) => {
                if value.module == origin_module and value.type_name == type_name {
                    if not struct_literal_has_field(ref tokens, start, end, value.name) {
                        push_diag(mutref diags, module, type_token.start, "struct literal is missing required field");
                    }
                }
            },
            None => {
            },
        }
        field_index = field_index + 1;
    }
    return make_expected_type_ctx(type_name, "", "");
}

fn infer_list_expr_type_ctx(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, expected_ctx: expected_type_ctx, diags: mutref list<diag>) -> expected_type_ctx {
    let open = token_at(ref tokens, start);
    let item_start_limit = start + 1;
    let item_end_limit = end - 1;
    if item_start_limit >= item_end_limit {
        if expected_ctx.head == "list" and expected_ctx.arg1_name != "" {
            return expected_ctx;
        }
        push_diag(mutref diags, module, open.start, "`[]` requires an expected `list<T>` context");
        return make_expected_type_ctx("list", "", "");
    }

    let mut declared_element_ctx = empty_expected_type_ctx();
    if expected_ctx.head == "list" and expected_ctx.arg1_name != "" {
        declared_element_ctx = make_expected_type_ctx(expected_ctx.arg1_name, "", "");
    }

    let mut first_element_ctx = empty_expected_type_ctx();
    let mut item_start = item_start_limit;
    let mut item_index = 0;
    while item_start < item_end_limit {
        let segment_end = next_top_level_comma(ref tokens, item_start, item_end_limit);
        if item_start == segment_end {
            push_diag(mutref diags, module, open.start, "list literal element cannot be empty");
            return unsupported_type_ctx();
        }
        let mut expected_element_ctx = declared_element_ctx;
        if expected_element_ctx.head == "" and first_element_ctx.head != "" {
            expected_element_ctx = first_element_ctx;
        }
        let actual_element_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, item_start, segment_end, open.start, expected_element_ctx, mutref diags);
        if is_unsupported_type_ctx(actual_element_ctx) {
            return actual_element_ctx;
        }
        if item_index == 0 and declared_element_ctx.head == "" {
            first_element_ctx = actual_element_ctx;
        } else {
            if expected_element_ctx.head != "" and has_known_type_ctx(actual_element_ctx) and not type_ctx_matches(expected_element_ctx, actual_element_ctx) {
                if declared_element_ctx.head == "" {
                    push_diag(mutref diags, module, open.start, "list literal elements must have matching types");
                }
            }
        }
        if declared_element_ctx.head != "" and has_known_type_ctx(actual_element_ctx) and not type_ctx_matches(declared_element_ctx, actual_element_ctx) {
            push_diag(mutref diags, module, open.start, "list literal element does not match expected element type");
        }
        item_index = item_index + 1;
        item_start = segment_end + 1;
    }

    if declared_element_ctx.head != "" {
        return expected_ctx;
    }
    if has_known_type_ctx(first_element_ctx) {
        return make_expected_type_ctx("list", first_element_ctx.head, "");
    }
    return make_expected_type_ctx("list", "", "");
}

fn match_pattern_is_default(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, tokens: ref list<token>, start: i32, end: i32) -> bool {
    let mut pattern_start = start;
    let mut pattern_end = end;
    while span_is_wrapped_in_parens(ref tokens, pattern_start, pattern_end) {
        pattern_start = pattern_start + 1;
        pattern_end = pattern_end - 1;
    }
    if pattern_start + 1 != pattern_end {
        return false;
    }
    let current = token_at(ref tokens, pattern_start);
    match current.kind {
        tk_ident => {
            if current.text == "_" {
                return true;
            }
            if builtin_variant_enum_name(current.text) != "" {
                return false;
            }
            if visible_variant_enum_name(ref variants, ref uses, ref items, module, current.text) != "" {
                return false;
            }
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn match_pattern_variant_name(tokens: ref list<token>, start: i32, end: i32) -> str {
    let mut pattern_start = start;
    let mut pattern_end = end;
    while span_is_wrapped_in_parens(ref tokens, pattern_start, pattern_end) {
        pattern_start = pattern_start + 1;
        pattern_end = pattern_end - 1;
    }
    if pattern_start >= pattern_end {
        return "";
    }
    let current = token_at(ref tokens, pattern_start);
    match current.kind {
        tk_ident => {
            return current.text;
        },
        _ => {
            return "";
        },
    }
}

fn match_expr_patterns_have_default(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, tokens: ref list<token>, start: i32, end: i32) -> bool {
    let mut cursor = start;
    let match_token = token_at(ref tokens, cursor);
    match match_token.kind {
        tk_kw_match => {
            cursor = cursor + 1;
        },
        _ => {
            return false;
        },
    }
    skip_until_match_block(ref tokens, mutref cursor);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            cursor = cursor + 1;
        },
        _ => {
            return false;
        },
    }
    while cursor < end {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                return false;
            },
            tk_eof => {
                return false;
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                if match_pattern_is_default(ref variants, ref uses, ref items, module, ref tokens, pattern_start, cursor) {
                    return true;
                }
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        cursor = cursor + 1;
                    },
                    _ => {
                        return false;
                    },
                }
                skip_match_arm_value_expr(ref tokens, mutref cursor);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        cursor = cursor + 1;
                    },
                    _ => {
                    },
                }
            },
        }
    }
    return false;
}

fn match_expr_patterns_include_variant(tokens: ref list<token>, start: i32, end: i32, variant_name: str) -> bool {
    let mut cursor = start;
    let match_token = token_at(ref tokens, cursor);
    match match_token.kind {
        tk_kw_match => {
            cursor = cursor + 1;
        },
        _ => {
            return false;
        },
    }
    skip_until_match_block(ref tokens, mutref cursor);
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            cursor = cursor + 1;
        },
        _ => {
            return false;
        },
    }
    while cursor < end {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                return false;
            },
            tk_eof => {
                return false;
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                if match_pattern_variant_name(ref tokens, pattern_start, cursor) == variant_name {
                    return true;
                }
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        cursor = cursor + 1;
                    },
                    _ => {
                        return false;
                    },
                }
                skip_match_arm_value_expr(ref tokens, mutref cursor);
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        cursor = cursor + 1;
                    },
                    _ => {
                    },
                }
            },
        }
    }
    return false;
}

fn match_expr_is_exhaustive(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, tokens: ref list<token>, start: i32, end: i32, scrutinee_ctx: expected_type_ctx) -> bool {
    if scrutinee_ctx.head == "option" {
        if match_expr_patterns_have_default(ref variants, ref uses, ref items, module, ref tokens, start, end) {
            return true;
        }
        return match_expr_patterns_include_variant(ref tokens, start, end, "Some") and match_expr_patterns_include_variant(ref tokens, start, end, "None");
    }
    if scrutinee_ctx.head == "result" {
        if match_expr_patterns_have_default(ref variants, ref uses, ref items, module, ref tokens, start, end) {
            return true;
        }
        return match_expr_patterns_include_variant(ref tokens, start, end, "Ok") and match_expr_patterns_include_variant(ref tokens, start, end, "Err");
    }
    let mut required = 0;
    let mut covered = 0;
    let mut index = 0;
    while index < list_len(ref variants) {
        let entry = list_get(ref variants, index);
        match entry {
            Some(value) => {
                if visible_variant_enum_name(ref variants, ref uses, ref items, module, value.name) == scrutinee_ctx.head {
                    required = required + 1;
                    if match_expr_patterns_include_variant(ref tokens, start, end, value.name) {
                        covered = covered + 1;
                    }
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    if required > 0 and match_expr_patterns_have_default(ref variants, ref uses, ref items, module, ref tokens, start, end) {
        return true;
    }
    return required > 0 and required == covered;
}

fn match_expr_scrutinee_is_supported(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, scrutinee_ctx: expected_type_ctx) -> bool {
    if scrutinee_ctx.head == "option" or scrutinee_ctx.head == "result" {
        return true;
    }
    let mut index = 0;
    while index < list_len(ref variants) {
        let entry = list_get(ref variants, index);
        match entry {
            Some(value) => {
                if visible_variant_enum_name(ref variants, ref uses, ref items, module, value.name) == scrutinee_ctx.head {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

fn infer_match_expr_type_ctx(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, at: i32, expected_ctx: expected_type_ctx, diags: mutref list<diag>) -> expected_type_ctx {
    let mut cursor = start;
    let match_token = token_at(ref tokens, cursor);
    match match_token.kind {
        tk_kw_match => {
            cursor = cursor + 1;
        },
        _ => {
            push_stage1_limitation(mutref diags, module, at);
            return unsupported_type_ctx();
        },
    }
    let scrutinee_start = cursor;
    skip_until_match_block(ref tokens, mutref cursor);
    let scrutinee_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, scrutinee_start, cursor, at, empty_expected_type_ctx(), mutref diags);
    if is_unsupported_type_ctx(scrutinee_ctx) {
        return scrutinee_ctx;
    }
    if has_known_type_ctx(scrutinee_ctx) and not match_expr_scrutinee_is_supported(ref variants, ref uses, ref items, module, scrutinee_ctx) {
        push_diag(mutref diags, module, match_token.start, "match expression scrutinee must be option, result, or enum");
        return unsupported_type_ctx();
    }
    let open = token_at(ref tokens, cursor);
    match open.kind {
        tk_lbrace => {
            cursor = cursor + 1;
        },
        _ => {
            push_diag(mutref diags, module, open.start, "expected `{` after match expression");
            return unsupported_type_ctx();
        },
    }
    let mut arm_index = 0;
    let mut result_ctx = empty_expected_type_ctx();
    while cursor < end {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_rbrace => {
                if arm_index == 0 {
                    push_diag(mutref diags, module, current.start, "match expression must have at least one arm");
                    return unsupported_type_ctx();
                }
                if not match_expr_is_exhaustive(ref variants, ref uses, ref items, module, ref tokens, start, end, scrutinee_ctx) {
                    push_diag(mutref diags, module, match_token.start, "match expression must be exhaustive");
                    return unsupported_type_ctx();
                }
                if expected_ctx.head != "" {
                    return expected_ctx;
                }
                return result_ctx;
            },
            tk_eof => {
                push_diag(mutref diags, module, current.start, "unterminated match expression");
                return unsupported_type_ctx();
            },
            _ => {
                let pattern_start = cursor;
                skip_pattern_until_arrow(ref tokens, mutref cursor);
                let pattern_end = cursor;
                let arrow = token_at(ref tokens, cursor);
                match arrow.kind {
                    tk_fat_arrow => {
                        cursor = cursor + 1;
                    },
                    _ => {
                        push_diag(mutref diags, module, arrow.start, "expected `=>` in match arm");
                        return unsupported_type_ctx();
                    },
                }
                let body_start = cursor;
                skip_match_arm_value_expr(ref tokens, mutref cursor);
                let body_end = cursor;

                let mut arm_bindings = clone_typed_bindings_for_function(ref typed_bindings, module, function_name);
                let mut ignored_pattern_bindings: list<pattern_binding_fact> = list();
                typecheck_pattern_span(ref variants, ref variant_payloads, ref uses, ref items, module, function_name, scope_id, ref tokens, pattern_start, pattern_end, scrutinee_ctx, mutref arm_bindings, mutref ignored_pattern_bindings, mutref diags);

                let mut arm_expected_ctx = expected_ctx;
                if arm_expected_ctx.head == "" and result_ctx.head != "" {
                    arm_expected_ctx = result_ctx;
                }
                let arm_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref arm_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, body_start, body_end, current.start, arm_expected_ctx, mutref diags);
                if not is_unsupported_type_ctx(arm_ctx) and has_known_type_ctx(arm_ctx) {
                    if arm_index == 0 and expected_ctx.head == "" {
                        result_ctx = arm_ctx;
                    } else {
                        if expected_ctx.head != "" {
                            if not type_ctx_matches(expected_ctx, arm_ctx) {
                                push_diag(mutref diags, module, current.start, "match expression arm result does not match expected type");
                            }
                        } else {
                            if result_ctx.head != "" and not type_ctx_matches(result_ctx, arm_ctx) {
                                push_diag(mutref diags, module, current.start, "match expression arm result types must match exactly");
                            }
                        }
                    }
                }
                arm_index = arm_index + 1;
                let maybe_comma = token_at(ref tokens, cursor);
                match maybe_comma.kind {
                    tk_comma => {
                        cursor = cursor + 1;
                    },
                    _ => {
                    },
                }
            },
        }
    }
    if arm_index == 0 {
        push_diag(mutref diags, module, at, "match expression must have at least one arm");
        return unsupported_type_ctx();
    }
    if not match_expr_is_exhaustive(ref variants, ref uses, ref items, module, ref tokens, start, end, scrutinee_ctx) {
        push_diag(mutref diags, module, match_token.start, "match expression must be exhaustive");
        return unsupported_type_ctx();
    }
    if expected_ctx.head != "" {
        return expected_ctx;
    }
    return result_ctx;
}

pub fn infer_expr_type_ctx(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, at: i32, expected_ctx: expected_type_ctx, diags: mutref list<diag>) -> expected_type_ctx
audit {
    intent("Infer the type context of a trusted-subset expression for selfhost semantic checks");
    mutates(diags);
    effects();
}
{
    let mut expr_start = expr_content_start(ref tokens, start, end);
    let mut expr_end = end;
    while span_is_wrapped_in_parens(ref tokens, expr_start, expr_end) {
        expr_start = expr_start + 1;
        expr_end = expr_end - 1;
    }
    if expr_start >= expr_end {
        return make_expected_type_ctx("unit", "", "");
    }

    let or_index = find_root_or_operator(ref tokens, expr_start, expr_end);
    if or_index >= 0 {
        let left_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, or_index, at, empty_expected_type_ctx(), mutref diags);
        let right_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, or_index + 1, expr_end, at, empty_expected_type_ctx(), mutref diags);
        if has_known_type_ctx(left_type_ctx) and left_type_ctx.head != "bool" {
            push_diag(mutref diags, module, at, "logical operand must have type `bool`");
        }
        if has_known_type_ctx(right_type_ctx) and right_type_ctx.head != "bool" {
            push_diag(mutref diags, module, at, "logical operand must have type `bool`");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let and_index = find_root_and_operator(ref tokens, expr_start, expr_end);
    if and_index >= 0 {
        let left_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, and_index, at, empty_expected_type_ctx(), mutref diags);
        let right_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, and_index + 1, expr_end, at, empty_expected_type_ctx(), mutref diags);
        if has_known_type_ctx(left_type_ctx) and left_type_ctx.head != "bool" {
            push_diag(mutref diags, module, at, "logical operand must have type `bool`");
        }
        if has_known_type_ctx(right_type_ctx) and right_type_ctx.head != "bool" {
            push_diag(mutref diags, module, at, "logical operand must have type `bool`");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let compare_index = find_root_compare_operator(ref tokens, expr_start, expr_end);
    if compare_index >= 0 {
        let left_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, compare_index, at, empty_expected_type_ctx(), mutref diags);
        let right_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, compare_index + 1, expr_end, at, empty_expected_type_ctx(), mutref diags);
        if has_known_type_ctx(left_type_ctx) and has_known_type_ctx(right_type_ctx) and not type_ctx_matches(left_type_ctx, right_type_ctx) {
            push_diag(mutref diags, module, at, "comparison operands must have matching types");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let additive_index = find_root_additive_operator(ref tokens, expr_start, expr_end);
    if additive_index >= 0 {
        let left_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, additive_index, at, empty_expected_type_ctx(), mutref diags);
        let right_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, additive_index + 1, expr_end, at, empty_expected_type_ctx(), mutref diags);
        if has_known_type_ctx(left_type_ctx) and not is_int_like(left_type_ctx.head) {
            push_diag(mutref diags, module, at, "arithmetic operand must have integer type");
        }
        if has_known_type_ctx(right_type_ctx) and not is_int_like(right_type_ctx.head) {
            push_diag(mutref diags, module, at, "arithmetic operand must have integer type");
        }
        return make_expected_type_ctx("i32", "", "");
    }

    let multiplicative_index = find_root_multiplicative_operator(ref tokens, expr_start, expr_end);
    if multiplicative_index >= 0 {
        let left_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, multiplicative_index, at, empty_expected_type_ctx(), mutref diags);
        let right_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, multiplicative_index + 1, expr_end, at, empty_expected_type_ctx(), mutref diags);
        if has_known_type_ctx(left_type_ctx) and not is_int_like(left_type_ctx.head) {
            push_diag(mutref diags, module, at, "arithmetic operand must have integer type");
        }
        if has_known_type_ctx(right_type_ctx) and not is_int_like(right_type_ctx.head) {
            push_diag(mutref diags, module, at, "arithmetic operand must have integer type");
        }
        return make_expected_type_ctx("i32", "", "");
    }

    if span_is_list_expr(ref tokens, expr_start, expr_end) {
        return infer_list_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, expr_end, expected_ctx, mutref diags);
    }

    let current = token_at(ref tokens, expr_start);
    match current.kind {
        tk_kw_match => {
            return infer_match_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, expr_end, at, expected_ctx, mutref diags);
        },
        tk_kw_ref => {
            return infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start + 1, expr_end, current.start, empty_expected_type_ctx(), mutref diags);
        },
        tk_kw_mutref => {
            return infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start + 1, expr_end, current.start, empty_expected_type_ctx(), mutref diags);
        },
        tk_kw_not => {
            let inner_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start + 1, expr_end, current.start, empty_expected_type_ctx(), mutref diags);
            if has_known_type_ctx(inner_type_ctx) and inner_type_ctx.head != "bool" {
                push_diag(mutref diags, module, current.start, "logical operand must have type `bool`");
            }
            return make_expected_type_ctx("bool", "", "");
        },
        tk_minus => {
            let inner_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start + 1, expr_end, current.start, empty_expected_type_ctx(), mutref diags);
            if has_known_type_ctx(inner_type_ctx) and not is_int_like(inner_type_ctx.head) {
                push_diag(mutref diags, module, current.start, "arithmetic operand must have integer type");
            }
            return make_expected_type_ctx("i32", "", "");
        },
        tk_kw_true => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("bool", "", "");
            }
        },
        tk_kw_false => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("bool", "", "");
            }
        },
        tk_int_lit => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("i32", "", "");
            }
        },
        tk_string_lit => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("str", "", "");
            }
        },
        tk_ident => {
            if span_is_call_expr(ref tokens, expr_start, expr_end) {
                return infer_call_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, expr_end, expected_ctx, mutref diags);
            }
            if span_is_struct_expr(ref tokens, expr_start, expr_end) {
                return infer_struct_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, expr_end, mutref diags);
            }
            if expr_start + 1 == expr_end {
                let binding_ctx = visible_typed_binding_ctx(ref typed_bindings, ref scopes, module, function_name, scope_id, current.text, current.start);
                if binding_ctx.head != "" {
                    return binding_ctx;
                }
                let const_ctx = visible_const_ctx(ref consts, ref uses, ref items, module, current.text);
                if const_ctx.head != "" {
                    return const_ctx;
                }
                return visible_zero_arg_variant_ctx(ref variants, ref uses, ref items, module, current.text, expected_ctx);
            }
        },
        _ => {
        },
    }

    let dot_index = find_root_field_dot(ref tokens, expr_start, expr_end);
    if dot_index >= 0 {
        let field_token = token_at(ref tokens, dot_index + 1);
        match field_token.kind {
            tk_ident => {
                if dot_index + 2 == expr_end {
                    let base_type_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, expr_start, dot_index, field_token.start, empty_expected_type_ctx(), mutref diags);
                    if is_unsupported_type_ctx(base_type_ctx) {
                        return base_type_ctx;
                    }
                    if base_type_ctx.head == "" {
                        return empty_expected_type_ctx();
                    }
                    let origin_module = visible_type_origin_module(ref uses, ref items, module, base_type_ctx.head);
                    if origin_module == "" {
                        if base_type_ctx.head == "bool" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `bool`");
                            return empty_expected_type_ctx();
                        }
                        if is_int_like(base_type_ctx.head) {
                            push_diag(mutref diags, module, field_token.start, "field access base has integer type");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "str" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `str`");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "option" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `option`");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "result" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `result`");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "list" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `list`");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "token_kind" {
                            push_diag(mutref diags, module, field_token.start, "field access base has type `token_kind`");
                            return empty_expected_type_ctx();
                        }
                        if base_type_ctx.head == "process_result" {
                            if field_token.text == "exit_code" {
                                return make_expected_type_ctx("i32", "", "");
                            }
                            if field_token.text == "stdout" or field_token.text == "stderr" {
                                return make_expected_type_ctx("str", "", "");
                            }
                            push_diag(mutref diags, module, field_token.start, "field does not exist on base type");
                            return empty_expected_type_ctx();
                        }
                        push_diag(mutref diags, module, field_token.start, "field access base does not name a readable product type");
                        return empty_expected_type_ctx();
                    }
                    let field_ctx = lookup_field_ctx(ref field_facts, origin_module, base_type_ctx.head, field_token.text);
                    if field_ctx.head == "" {
                        push_diag(mutref diags, module, field_token.start, "field does not exist on base type");
                        return empty_expected_type_ctx();
                    }
                    return field_ctx;
                }
            },
            _ => {
            },
        }
        push_stage1_limitation(mutref diags, module, at);
        return unsupported_type_ctx();
    }

    push_stage1_limitation(mutref diags, module, at);
    return unsupported_type_ctx();
}

fn infer_expr_type_name(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, at: i32, expected_ctx: expected_type_ctx, diags: mutref list<diag>) -> str {
    let ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref typed_bindings, ref field_facts, ref uses, ref items, module, function_name, scope_id, ref tokens, start, end, at, expected_ctx, mutref diags);
    return ctx.head;
}

fn is_const_safe_type(type_name: str, arg1_name: str, arg2_name: str, is_borrow: bool) -> bool {
    if is_borrow {
        return false;
    }
    if arg1_name != "" or arg2_name != "" {
        return false;
    }
    return type_name == "i32" or type_name == "bool" or type_name == "str";
}

fn infer_const_expr_type_ctx(tokens: ref list<token>, start: i32, end: i32, module: str, at: i32, diags: mutref list<diag>) -> expected_type_ctx {
    let mut expr_start = expr_content_start(ref tokens, start, end);
    let mut expr_end = end;
    while span_is_wrapped_in_parens(ref tokens, expr_start, expr_end) {
        expr_start = expr_start + 1;
        expr_end = expr_end - 1;
    }
    if expr_start >= expr_end {
        push_diag(mutref diags, module, at, "const initializer cannot be empty");
        return empty_expected_type_ctx();
    }

    let or_index = find_root_or_operator(ref tokens, expr_start, expr_end);
    if or_index >= 0 {
        let left_type = infer_const_expr_type_ctx(ref tokens, expr_start, or_index, module, at, mutref diags);
        let right_type = infer_const_expr_type_ctx(ref tokens, or_index + 1, expr_end, module, at, mutref diags);
        if has_known_type_ctx(left_type) and left_type.head != "bool" {
            push_diag(mutref diags, module, at, "const logical operand must have type `bool`");
        }
        if has_known_type_ctx(right_type) and right_type.head != "bool" {
            push_diag(mutref diags, module, at, "const logical operand must have type `bool`");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let and_index = find_root_and_operator(ref tokens, expr_start, expr_end);
    if and_index >= 0 {
        let left_type = infer_const_expr_type_ctx(ref tokens, expr_start, and_index, module, at, mutref diags);
        let right_type = infer_const_expr_type_ctx(ref tokens, and_index + 1, expr_end, module, at, mutref diags);
        if has_known_type_ctx(left_type) and left_type.head != "bool" {
            push_diag(mutref diags, module, at, "const logical operand must have type `bool`");
        }
        if has_known_type_ctx(right_type) and right_type.head != "bool" {
            push_diag(mutref diags, module, at, "const logical operand must have type `bool`");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let compare_index = find_root_compare_operator(ref tokens, expr_start, expr_end);
    if compare_index >= 0 {
        let left_type = infer_const_expr_type_ctx(ref tokens, expr_start, compare_index, module, at, mutref diags);
        let right_type = infer_const_expr_type_ctx(ref tokens, compare_index + 1, expr_end, module, at, mutref diags);
        if has_known_type_ctx(left_type) and has_known_type_ctx(right_type) and not type_ctx_matches(left_type, right_type) {
            push_diag(mutref diags, module, at, "const comparison operands must have matching types");
        }
        if has_known_type_ctx(left_type) and not is_int_like(left_type.head) {
            push_diag(mutref diags, module, at, "const comparison operand must have integer type");
        }
        if has_known_type_ctx(right_type) and not is_int_like(right_type.head) {
            push_diag(mutref diags, module, at, "const comparison operand must have integer type");
        }
        return make_expected_type_ctx("bool", "", "");
    }

    let additive_index = find_root_additive_operator(ref tokens, expr_start, expr_end);
    if additive_index >= 0 {
        let left_type = infer_const_expr_type_ctx(ref tokens, expr_start, additive_index, module, at, mutref diags);
        let right_type = infer_const_expr_type_ctx(ref tokens, additive_index + 1, expr_end, module, at, mutref diags);
        if has_known_type_ctx(left_type) and not is_int_like(left_type.head) {
            push_diag(mutref diags, module, at, "const arithmetic operand must have integer type");
        }
        if has_known_type_ctx(right_type) and not is_int_like(right_type.head) {
            push_diag(mutref diags, module, at, "const arithmetic operand must have integer type");
        }
        return make_expected_type_ctx("i32", "", "");
    }

    let multiplicative_index = find_root_multiplicative_operator(ref tokens, expr_start, expr_end);
    if multiplicative_index >= 0 {
        let left_type = infer_const_expr_type_ctx(ref tokens, expr_start, multiplicative_index, module, at, mutref diags);
        let right_type = infer_const_expr_type_ctx(ref tokens, multiplicative_index + 1, expr_end, module, at, mutref diags);
        if has_known_type_ctx(left_type) and not is_int_like(left_type.head) {
            push_diag(mutref diags, module, at, "const arithmetic operand must have integer type");
        }
        if has_known_type_ctx(right_type) and not is_int_like(right_type.head) {
            push_diag(mutref diags, module, at, "const arithmetic operand must have integer type");
        }
        return make_expected_type_ctx("i32", "", "");
    }

    let current = token_at(ref tokens, expr_start);
    match current.kind {
        tk_kw_not => {
            let inner = infer_const_expr_type_ctx(ref tokens, expr_start + 1, expr_end, module, current.start, mutref diags);
            if has_known_type_ctx(inner) and inner.head != "bool" {
                push_diag(mutref diags, module, current.start, "const logical operand must have type `bool`");
            }
            return make_expected_type_ctx("bool", "", "");
        },
        tk_minus => {
            let inner = infer_const_expr_type_ctx(ref tokens, expr_start + 1, expr_end, module, current.start, mutref diags);
            if has_known_type_ctx(inner) and not is_int_like(inner.head) {
                push_diag(mutref diags, module, current.start, "const arithmetic operand must have integer type");
            }
            return make_expected_type_ctx("i32", "", "");
        },
        tk_kw_true => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("bool", "", "");
            }
        },
        tk_kw_false => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("bool", "", "");
            }
        },
        tk_int_lit => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("i32", "", "");
            }
        },
        tk_string_lit => {
            if expr_start + 1 == expr_end {
                return make_expected_type_ctx("str", "", "");
            }
        },
        _ => {
        },
    }

    push_diag(mutref diags, module, at, "stage1 limitation: unsupported const initializer expression");
    return unsupported_type_ctx();
}

pub fn typecheck_const_facts(consts: ref list<const_fact>, sources: ref list<source_file>, diags: mutref list<diag>) -> typecheck_summary
audit {
    intent("Validate top-level constants against the narrow stage1 const-expression subset");
    mutates(diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let mut index = 0;
    while index < list_len(ref consts) {
        let entry = list_get(ref consts, index);
        match entry {
            Some(value) => {
                if not is_const_safe_type(value.type_name, value.type_arg1_name, value.type_arg2_name, value.is_borrow) {
                    push_diag(mutref diags, value.module, value.at, "top-level const supports only non-borrow i32, bool, or str in v1");
                }
                let text = module_source_text(ref sources, value.module);
                let tokens = lex(text);
                let actual = infer_const_expr_type_ctx(ref tokens, value.expr_start, value.expr_end, value.module, value.at, mutref diags);
                let expected = make_expected_type_ctx(value.type_name, value.type_arg1_name, value.type_arg2_name);
                if has_known_type_ctx(actual) and not type_ctx_matches(expected, actual) {
                    push_diag(mutref diags, value.module, value.at, "const initializer does not match declared type");
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return make_typecheck_summary(0, 0, 0, list_len(ref diags) - start_diag_count);
}

fn pattern_payload_ctx(variant_payloads: ref list<variant_payload_fact>, variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, variant_name: str, scrutinee_ctx: expected_type_ctx, index: i32) -> expected_type_ctx {
    if builtin_variant_enum_name(variant_name) != "" {
        return builtin_variant_payload_ctx(variant_name, scrutinee_ctx, index);
    }
    return visible_variant_payload_ctx(ref variant_payloads, ref uses, ref items, module, variant_name, index);
}

fn typecheck_pattern_span(variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, scope_id: i32, tokens: ref list<token>, start: i32, end: i32, scrutinee_ctx: expected_type_ctx, resolved_bindings: mutref list<typed_binding_fact>, pattern_bindings: mutref list<pattern_binding_fact>, diags: mutref list<diag>) -> unit {
    let mut pattern_start = start;
    let mut pattern_end = end;
    while span_is_wrapped_in_parens(ref tokens, pattern_start, pattern_end) {
        pattern_start = pattern_start + 1;
        pattern_end = pattern_end - 1;
    }
    if pattern_start >= pattern_end {
        return;
    }
    let current = token_at(ref tokens, pattern_start);
    match current.kind {
        tk_ident => {
            if current.text == "_" and pattern_start + 1 == pattern_end {
                return;
            }
            if span_is_call_expr(ref tokens, pattern_start, pattern_end) {
                let ctor_enum_name = visible_variant_enum_name(ref variants, ref uses, ref items, module, current.text);
                if ctor_enum_name == "" {
                    push_stage1_limitation(mutref diags, module, current.start);
                    return;
                }
                if has_known_type_ctx(scrutinee_ctx) and not type_names_match(scrutinee_ctx.head, ctor_enum_name) {
                    push_diag(mutref diags, module, current.start, "pattern does not match scrutinee type");
                }
                let mut arg_start = pattern_start + 2;
                let arg_end_limit = pattern_end - 1;
                let mut arg_index = 0;
                while arg_start < arg_end_limit {
                    let segment_end = next_top_level_comma(ref tokens, arg_start, arg_end_limit);
                    let payload_ctx = pattern_payload_ctx(ref variant_payloads, ref variants, ref uses, ref items, module, current.text, scrutinee_ctx, arg_index);
                    typecheck_pattern_span(ref variants, ref variant_payloads, ref uses, ref items, module, function_name, scope_id, ref tokens, arg_start, segment_end, payload_ctx, mutref resolved_bindings, mutref pattern_bindings, mutref diags);
                    arg_index = arg_index + 1;
                    arg_start = segment_end + 1;
                }
                return;
            }
            if pattern_start + 1 == pattern_end {
                let zero_arg_ctx = visible_zero_arg_variant_ctx(ref variants, ref uses, ref items, module, current.text, scrutinee_ctx);
                if zero_arg_ctx.head != "" {
                    if has_known_type_ctx(scrutinee_ctx) and not type_ctx_matches(zero_arg_ctx, scrutinee_ctx) {
                        push_diag(mutref diags, module, current.start, "pattern does not match scrutinee type");
                    }
                    return;
                }
                if has_known_type_ctx(scrutinee_ctx) {
                    list_push(mutref resolved_bindings, make_typed_binding_fact(module, function_name, scope_id, current.text, current.start, scrutinee_ctx.head, scrutinee_ctx.arg1_name, scrutinee_ctx.arg2_name, false, false));
                    list_push(mutref pattern_bindings, make_pattern_binding_fact(module, function_name, scope_id, current.text, current.start, scrutinee_ctx.head, scrutinee_ctx.arg1_name, scrutinee_ctx.arg2_name, false, false));
                }
                return;
            }
        },
        _ => {
        },
    }
    push_stage1_limitation(mutref diags, module, current.start);
    return;
}

fn typecheck_match_arm(variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, functions: ref list<function_fact>, function_params: ref list<function_param_fact>, scopes: ref list<body_scope>, field_facts: ref list<field_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, function_name: str, tokens: ref list<token>, arm: match_arm_fact, resolved_bindings: mutref list<typed_binding_fact>, pattern_bindings: mutref list<pattern_binding_fact>, diags: mutref list<diag>) -> unit {
    let scrutinee_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, module, function_name, arm.scope_id, ref tokens, arm.scrutinee_start, arm.scrutinee_end, arm.at, empty_expected_type_ctx(), mutref diags);
    if is_unsupported_type_ctx(scrutinee_ctx) {
        return;
    }
    typecheck_pattern_span(ref variants, ref variant_payloads, ref uses, ref items, module, function_name, arm.scope_id, ref tokens, arm.pattern_start, arm.pattern_end, scrutinee_ctx, mutref resolved_bindings, mutref pattern_bindings, mutref diags);
    return;
}

fn let_else_payload_ctx(variant_name: str, scrutinee_ctx: expected_type_ctx, module: str, at: i32, diags: mutref list<diag>) -> expected_type_ctx {
    if variant_name == "Some" {
        if has_known_type_ctx(scrutinee_ctx) and scrutinee_ctx.head != "option" {
            push_diag(mutref diags, module, at, "let-else `Some` pattern requires an option scrutinee");
            return empty_expected_type_ctx();
        }
        if scrutinee_ctx.head == "option" {
            return make_expected_type_ctx(scrutinee_ctx.arg1_name, "", "");
        }
        return empty_expected_type_ctx();
    }
    if variant_name == "Ok" {
        if has_known_type_ctx(scrutinee_ctx) and scrutinee_ctx.head != "result" {
            push_diag(mutref diags, module, at, "let-else `Ok` pattern requires a result scrutinee");
            return empty_expected_type_ctx();
        }
        if scrutinee_ctx.head == "result" {
            return make_expected_type_ctx(scrutinee_ctx.arg1_name, "", "");
        }
        return empty_expected_type_ctx();
    }
    push_diag(mutref diags, module, at, "let-else V1 only supports `Some(name)` and `Ok(name)` patterns");
    return empty_expected_type_ctx();
}

fn local_init_is_let_else(local: local_init_fact) -> bool {
    return local.expr_member_name == "let_else";
}

pub fn typecheck_value_facts(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, match_arms: ref list<match_arm_fact>, locals: ref list<local_init_fact>, returns: ref list<return_expr_fact>, conditions: ref list<condition_fact>, assignments: ref list<assignment_fact>, uses: ref list<module_use>, items: ref list<top_item>, sources: ref list<source_file>, diags: mutref list<diag>) -> value_typecheck_summary
audit {
    intent("Run the next selfhost type-checker slice over local initializers, return expressions, condition types, and assignment compatibility");
    mutates(diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let mut total_resolved_binding_count = 0;
    let mut ignored_pattern_bindings: list<pattern_binding_fact> = list();
    let mut source_index = 0;
    while source_index < list_len(ref sources) {
        let source_entry = list_get(ref sources, source_index);
        match source_entry {
            Some(current_source) => {
                let tokens = lex(current_source.text);
                let mut function_index = 0;
                while function_index < list_len(ref functions) {
                    let function_entry = list_get(ref functions, function_index);
                    match function_entry {
                        Some(current_function) => {
                            if current_function.module == current_source.name {
                                let mut resolved_bindings = clone_typed_bindings_for_function(ref typed_bindings, current_function.module, current_function.name);
                                let function_match_arms = clone_match_arms_for_function(ref match_arms, current_function.module, current_function.name);
                                let function_locals = clone_local_inits_for_function(ref locals, current_function.module, current_function.name);
                                let function_assignments = clone_assignments_for_function(ref assignments, current_function.module, current_function.name);
                                let function_returns = clone_returns_for_function(ref returns, current_function.module, current_function.name);
                                let function_conditions = clone_conditions_for_function(ref conditions, current_function.module, current_function.name);

                                let mut local_index = 0;
                                let mut arm_index = 0;
                                while local_index < list_len(ref function_locals) or arm_index < list_len(ref function_match_arms) {
                                    let mut next_local_at = 2147483647;
                                    let mut next_arm_at = 2147483647;
                                    let local_entry = list_get(ref function_locals, local_index);
                                    match local_entry {
                                        Some(value) => {
                                            next_local_at = value.at;
                                        },
                                        None => {
                                        },
                                    }
                                    let arm_entry = list_get(ref function_match_arms, arm_index);
                                    match arm_entry {
                                        Some(value) => {
                                            next_arm_at = value.at;
                                        },
                                        None => {
                                        },
                                    }

                                    if next_arm_at <= next_local_at {
                                        match arm_entry {
                                            Some(current) => {
                                                typecheck_match_arm(ref variants, ref variant_payloads, ref consts, ref functions, ref function_params, ref scopes, ref field_facts, ref uses, ref items, current.module, current.function_name, ref tokens, current, mutref resolved_bindings, mutref ignored_pattern_bindings, mutref diags);
                                            },
                                            None => {
                                            },
                                        }
                                        arm_index = arm_index + 1;
                                    } else {
                                        match local_entry {
                                            Some(current) => {
                                                let mut expected_ctx = empty_expected_type_ctx();
                                                let mut expr_start = current.expr_start;
                                                let eq_token = token_at(ref tokens, expr_start);
                                                match eq_token.kind {
                                                    tk_eq => {
                                                        expr_start = expr_start + 1;
                                                    },
                                                    _ => {
                                                    },
                                                }
                                                if current.expected_type_name != "" {
                                                    expected_ctx = exact_typed_binding_ctx(ref resolved_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                                                }
                                                let actual_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, current.module, current.function_name, current.scope_id, ref tokens, expr_start, current.expr_end, current.at, expected_ctx, mutref diags);
                                                if local_init_is_let_else(current) {
                                                    let payload_ctx = let_else_payload_ctx(current.expr_name, actual_ctx, current.module, current.at, mutref diags);
                                                    if current.name != "" and has_known_type_ctx(payload_ctx) {
                                                        list_push(mutref resolved_bindings, make_typed_binding_fact(current.module, current.function_name, current.scope_id, current.name, current.at, payload_ctx.head, payload_ctx.arg1_name, payload_ctx.arg2_name, false, false));
                                                    }
                                                } else {
                                                    if current.expected_type_name != "" {
                                                        if not current.expected_is_borrow {
                                                            if expected_ctx.head != "" and has_known_type_ctx(actual_ctx) and not type_ctx_matches(expected_ctx, actual_ctx) {
                                                                push_diag(mutref diags, current.module, current.at, "annotated local initializer does not match declared type");
                                                            }
                                                        }
                                                    } else {
                                                        if current.name != "" and has_known_type_ctx(actual_ctx) {
                                                            list_push(mutref resolved_bindings, make_typed_binding_fact(current.module, current.function_name, current.scope_id, current.name, current.at, actual_ctx.head, actual_ctx.arg1_name, actual_ctx.arg2_name, false, false));
                                                        }
                                                    }
                                                }
                                            },
                                            None => {
                                            },
                                        }
                                        local_index = local_index + 1;
                                    }
                                }

                                let mut assignment_index = 0;
                                while assignment_index < list_len(ref function_assignments) {
                                    let assignment_entry = list_get(ref function_assignments, assignment_index);
                                    match assignment_entry {
                                        Some(current) => {
                                            let expected_ctx = visible_typed_binding_ctx(ref resolved_bindings, ref scopes, current.module, current.function_name, current.scope_id, current.target_name, current.at);
                                            if expected_ctx.head != "" {
                                                let actual_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, current.module, current.function_name, current.scope_id, ref tokens, current.expr_start, current.expr_end, current.at, expected_ctx, mutref diags);
                                                if has_known_type_ctx(actual_ctx) and not type_ctx_matches(expected_ctx, actual_ctx) {
                                                    push_diag(mutref diags, current.module, current.at, "assignment value does not match target type");
                                                }
                                            }
                                        },
                                        None => {
                                        },
                                    }
                                    assignment_index = assignment_index + 1;
                                }

                                let mut return_index = 0;
                                while return_index < list_len(ref function_returns) {
                                    let return_entry = list_get(ref function_returns, return_index);
                                    match return_entry {
                                        Some(current) => {
                                            let expected_return_ctx = visible_function_return_ctx(ref functions, ref uses, ref items, current.module, current.function_name);
                                            let expected_is_borrow = visible_function_return_is_borrow(ref functions, ref uses, ref items, current.module, current.function_name);
                                            if expected_return_ctx.head != "" and not expected_is_borrow {
                                                let actual_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, current.module, current.function_name, current.scope_id, ref tokens, current.expr_start, current.expr_end, current.at, expected_return_ctx, mutref diags);
                                                if has_known_type_ctx(actual_ctx) and not type_ctx_matches(expected_return_ctx, actual_ctx) {
                                                    push_diag(mutref diags, current.module, current.at, "return expression does not match function return type");
                                                }
                                            }
                                        },
                                        None => {
                                        },
                                    }
                                    return_index = return_index + 1;
                                }

                                let mut condition_index = 0;
                                while condition_index < list_len(ref function_conditions) {
                                    let condition_entry = list_get(ref function_conditions, condition_index);
                                    match condition_entry {
                                        Some(current) => {
                                            let actual_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, current.module, current.function_name, current.scope_id, ref tokens, current.expr_start, current.expr_end, current.at, make_expected_type_ctx("bool", "", ""), mutref diags);
                                            if has_known_type_ctx(actual_ctx) and actual_ctx.head != "bool" {
                                                match current.kind {
                                                    condition_if => {
                                                        push_diag(mutref diags, current.module, current.at, "`if` condition must have type `bool`");
                                                    },
                                                    condition_while => {
                                                        push_diag(mutref diags, current.module, current.at, "`while` condition must have type `bool`");
                                                    },
                                                }
                                            }
                                        },
                                        None => {
                                        },
                                    }
                                    condition_index = condition_index + 1;
                                }

                                total_resolved_binding_count = total_resolved_binding_count + list_len(ref resolved_bindings);
                            }
                        },
                        None => {
                        },
                    }
                    function_index = function_index + 1;
                }
            },
            None => {
            },
        }
        source_index = source_index + 1;
    }

    return make_value_typecheck_summary(
        total_resolved_binding_count,
        list_len(ref locals),
        list_len(ref returns),
        list_len(ref conditions),
        list_len(ref assignments),
        list_len(ref diags) - start_diag_count
    );
}

pub fn collect_resolved_binding_facts(functions: ref list<function_fact>, function_params: ref list<function_param_fact>, variants: ref list<variant_fact>, variant_payloads: ref list<variant_payload_fact>, consts: ref list<const_fact>, scopes: ref list<body_scope>, typed_bindings: ref list<typed_binding_fact>, field_facts: ref list<field_fact>, match_arms: ref list<match_arm_fact>, locals: ref list<local_init_fact>, uses: ref list<module_use>, items: ref list<top_item>, sources: ref list<source_file>, resolved_bindings_out: mutref list<typed_binding_fact>, pattern_bindings_out: mutref list<pattern_binding_fact>, diags: mutref list<diag>) -> resolved_binding_summary
audit {
    intent("Materialize resolved binding and typed pattern facts for the structured checked handoff");
    mutates(resolved_bindings_out, pattern_bindings_out, diags);
    effects();
}
{
    let start_diag_count = list_len(ref diags);
    let start_binding_count = list_len(ref resolved_bindings_out);
    let start_pattern_binding_count = list_len(ref pattern_bindings_out);
    let mut source_index = 0;
    while source_index < list_len(ref sources) {
        let source_entry = list_get(ref sources, source_index);
        match source_entry {
            Some(current_source) => {
                let tokens = lex(current_source.text);
                let mut function_index = 0;
                while function_index < list_len(ref functions) {
                    let function_entry = list_get(ref functions, function_index);
                    match function_entry {
                        Some(current_function) => {
                            if current_function.module == current_source.name {
                                let mut resolved_bindings = clone_typed_bindings_for_function(ref typed_bindings, current_function.module, current_function.name);
                                let function_match_arms = clone_match_arms_for_function(ref match_arms, current_function.module, current_function.name);
                                let function_locals = clone_local_inits_for_function(ref locals, current_function.module, current_function.name);

                                let mut local_index = 0;
                                let mut arm_index = 0;
                                while local_index < list_len(ref function_locals) or arm_index < list_len(ref function_match_arms) {
                                    let mut next_local_at = 2147483647;
                                    let mut next_arm_at = 2147483647;
                                    let local_entry = list_get(ref function_locals, local_index);
                                    match local_entry {
                                        Some(value) => {
                                            next_local_at = value.at;
                                        },
                                        None => {
                                        },
                                    }
                                    let arm_entry = list_get(ref function_match_arms, arm_index);
                                    match arm_entry {
                                        Some(value) => {
                                            next_arm_at = value.at;
                                        },
                                        None => {
                                        },
                                    }

                                    if next_arm_at <= next_local_at {
                                        match arm_entry {
                                            Some(current) => {
                                                typecheck_match_arm(ref variants, ref variant_payloads, ref consts, ref functions, ref function_params, ref scopes, ref field_facts, ref uses, ref items, current.module, current.function_name, ref tokens, current, mutref resolved_bindings, mutref pattern_bindings_out, mutref diags);
                                            },
                                            None => {
                                            },
                                        }
                                        arm_index = arm_index + 1;
                                    } else {
                                        match local_entry {
                                            Some(current) => {
                                                let mut expected_ctx = empty_expected_type_ctx();
                                                let mut expr_start = current.expr_start;
                                                let eq_token = token_at(ref tokens, expr_start);
                                                match eq_token.kind {
                                                    tk_eq => {
                                                        expr_start = expr_start + 1;
                                                    },
                                                    _ => {
                                                    },
                                                }
                                                if current.expected_type_name != "" {
                                                    expected_ctx = exact_typed_binding_ctx(ref resolved_bindings, current.module, current.function_name, current.scope_id, current.name, current.at);
                                                }
                                                let actual_ctx = infer_expr_type_ctx(ref functions, ref function_params, ref variants, ref variant_payloads, ref consts, ref scopes, ref resolved_bindings, ref field_facts, ref uses, ref items, current.module, current.function_name, current.scope_id, ref tokens, expr_start, current.expr_end, current.at, expected_ctx, mutref diags);
                                                if local_init_is_let_else(current) {
                                                    let payload_ctx = let_else_payload_ctx(current.expr_name, actual_ctx, current.module, current.at, mutref diags);
                                                    if current.name != "" and has_known_type_ctx(payload_ctx) {
                                                        list_push(mutref resolved_bindings, make_typed_binding_fact(current.module, current.function_name, current.scope_id, current.name, current.at, payload_ctx.head, payload_ctx.arg1_name, payload_ctx.arg2_name, false, false));
                                                    }
                                                } else {
                                                    if current.expected_type_name == "" {
                                                        if current.name != "" and has_known_type_ctx(actual_ctx) {
                                                            list_push(mutref resolved_bindings, make_typed_binding_fact(current.module, current.function_name, current.scope_id, current.name, current.at, actual_ctx.head, actual_ctx.arg1_name, actual_ctx.arg2_name, false, false));
                                                        }
                                                    }
                                                }
                                            },
                                            None => {
                                            },
                                        }
                                        local_index = local_index + 1;
                                    }
                                }

                                let mut resolved_index = 0;
                                while resolved_index < list_len(ref resolved_bindings) {
                                    let resolved_entry = list_get(ref resolved_bindings, resolved_index);
                                    match resolved_entry {
                                        Some(value) => {
                                            list_push(mutref resolved_bindings_out, value);
                                        },
                                        None => {
                                        },
                                    }
                                    resolved_index = resolved_index + 1;
                                }
                            }
                        },
                        None => {
                        },
                    }
                    function_index = function_index + 1;
                }
            },
            None => {
            },
        }
        source_index = source_index + 1;
    }

    return make_resolved_binding_summary(
        list_len(ref resolved_bindings_out) - start_binding_count,
        list_len(ref pattern_bindings_out) - start_pattern_binding_count,
        list_len(ref diags) - start_diag_count
    );
}
