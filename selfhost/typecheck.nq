    if end - start < 3 {
        return false;
    }
    let head = token_at(ref tokens, start);
    let open = token_at(ref tokens, start + 1);
    match head.kind {
        tk_ident => {
        },
        _ => {
            return false;
        },
    }
    match open.kind {
        tk_lbrace => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start + 1;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lbrace => {
