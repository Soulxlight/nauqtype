fn lookup_const_ctx(consts: ref list<const_fact>, module: str, name: str) -> expected_type_ctx {
    let mut index = 0;
    while index < list_len(ref consts) {
        let entry = list_get(ref consts, index);
        match entry {
            Some(value) => {
                if value.module == module and value.name == name {
                    return make_expected_type_ctx(value.type_name, value.type_arg1_name, value.type_arg2_name);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return empty_expected_type_ctx();
}

pub fn visible_const_origin_module(uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str
audit {
    intent("Resolve the origin module for a visible top-level constant");
    mutates();
    effects();
}
{
    if module_has_local_const_name(ref items, module, name) {
        return module;
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_const_name(ref items, value.name, name) {
                    return value.name;
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return "";
}

pub fn visible_const_ctx(consts: ref list<const_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> expected_type_ctx
audit {
    intent("Resolve the checked type context for a visible top-level constant");
    mutates();
    effects();
}
{
    let origin = visible_const_origin_module(ref uses, ref items, module, name);
    if origin == "" {
        return empty_expected_type_ctx();
    }
    return lookup_const_ctx(ref consts, origin, name);
}

fn visible_function_return_name(functions: ref list<function_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str {
    let builtin = builtin_function_return_name(name);
    if builtin != "" {
        return builtin;
    }
    if module_has_local_function_name(ref items, module, name) {
        return lookup_function_fact_return_name(ref functions, module, name);
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_function_name(ref items, value.name, name) {
                    return lookup_function_fact_return_name(ref functions, value.name, name);
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return "";
}

fn visible_function_return_ctx(functions: ref list<function_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> expected_type_ctx {
    let builtin = builtin_function_return_name(name);
    if builtin != "" {
        return make_expected_type_ctx(builtin, builtin_function_return_arg1_name(name), builtin_function_return_arg2_name(name));
    }
    if module_has_local_function_name(ref items, module, name) {
        return make_expected_type_ctx(
            lookup_function_fact_return_name(ref functions, module, name),
            lookup_function_fact_return_arg1_name(ref functions, module, name),
            lookup_function_fact_return_arg2_name(ref functions, module, name)
        );
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_function_name(ref items, value.name, name) {
                    return make_expected_type_ctx(
                        lookup_function_fact_return_name(ref functions, value.name, name),
                        lookup_function_fact_return_arg1_name(ref functions, value.name, name),
                        lookup_function_fact_return_arg2_name(ref functions, value.name, name)
                    );
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return empty_expected_type_ctx();
}

fn visible_function_return_is_borrow(functions: ref list<function_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> bool {
    let builtin = builtin_function_return_name(name);
    if builtin != "" {
        return false;
    }
    if module_has_local_function_name(ref items, module, name) {
        return lookup_function_fact_return_is_borrow(ref functions, module, name);
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_function_name(ref items, value.name, name) {
                    return lookup_function_fact_return_is_borrow(ref functions, value.name, name);
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return false;
}

pub fn visible_variant_enum_name(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str
audit {
    intent("Resolve the enum name for a visible variant constructor");
    mutates();
    effects();
}
{
    let builtin = builtin_variant_enum_name(name);
    if builtin != "" {
        return builtin;
    }
    if module_has_local_variant_name(ref items, module, name) {
        return lookup_variant_fact_enum_name(ref variants, module, name);
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_variant_name(ref items, value.name, name) {
                    return lookup_variant_fact_enum_name(ref variants, value.name, name);
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return "";
}

pub fn visible_function_origin_module(uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str
audit {
    intent("Resolve the origin module for a visible function call target");
    mutates();
    effects();
}
{
    if builtin_function_arity(name) >= 0 {
        return "__builtin__";
    }
    if module_has_local_function_name(ref items, module, name) {
        return module;
