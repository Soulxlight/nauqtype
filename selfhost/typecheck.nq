    if module_directly_imports(ref uses, module, qualifier) and module_exports_function_name(ref items, qualifier, function_name) {
        return lookup_function_param_ctx(ref function_params, qualifier, function_name, index);
    }
    return empty_expected_type_ctx();
}

fn qualified_function_param_name(function_params: ref list<function_param_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, qualifier: str, function_name: str, index: i32) -> str {
    if module_directly_imports(ref uses, module, qualifier) and module_exports_function_name(ref items, qualifier, function_name) {
        return lookup_function_param_name(ref function_params, qualifier, function_name, index);
    }
    return "";
}

fn qualified_function_arity(functions: ref list<function_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, qualifier: str, function_name: str) -> i32 {
    if module_directly_imports(ref uses, module, qualifier) and module_exports_function_name(ref items, qualifier, function_name) {
        return lookup_function_fact_arity(ref functions, qualifier, function_name);
    }
    return -1;
}

fn lookup_variant_payload_type_name(variant_payloads: ref list<variant_payload_fact>, module: str, variant_name: str, index: i32) -> str {
    let mut cursor = 0;
    while cursor < list_len(ref variant_payloads) {
        let entry = list_get(ref variant_payloads, cursor);
        match entry {
            Some(value) => {
                if value.module == module and value.variant_name == variant_name and value.index == index {
                    return value.type_name;
                }
            },
            None => {
            },
        }
        cursor = cursor + 1;
    }
    return "";
}

fn lookup_variant_payload_ctx(variant_payloads: ref list<variant_payload_fact>, module: str, variant_name: str, index: i32) -> expected_type_ctx {
    let mut cursor = 0;
    while cursor < list_len(ref variant_payloads) {
        let entry = list_get(ref variant_payloads, cursor);
        match entry {
            Some(value) => {
                if value.module == module and value.variant_name == variant_name and value.index == index {
                    return make_expected_type_ctx(value.type_name, value.type_arg1_name, value.type_arg2_name);
                }
            },
            None => {
            },
        }
        cursor = cursor + 1;
    }
    return empty_expected_type_ctx();
}

fn visible_variant_payload_type_name(variant_payloads: ref list<variant_payload_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, variant_name: str, index: i32) -> str {
    if builtin_variant_enum_name(variant_name) != "" {
        return "";
    }
    if module_has_local_variant_name(ref items, module, variant_name) {
        return lookup_variant_payload_type_name(ref variant_payloads, module, variant_name, index);
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_variant_name(ref items, value.name, variant_name) {
                    return lookup_variant_payload_type_name(ref variant_payloads, value.name, variant_name, index);
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return "";
}

pub fn visible_variant_payload_ctx(variant_payloads: ref list<variant_payload_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, variant_name: str, index: i32) -> expected_type_ctx
audit {
    intent("Resolve the expected type context for a visible constructor payload");
    mutates();
    effects();
}
{
    if builtin_variant_enum_name(variant_name) != "" {
        return empty_expected_type_ctx();
    }
    if module_has_local_variant_name(ref items, module, variant_name) {
        return lookup_variant_payload_ctx(ref variant_payloads, module, variant_name, index);
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_variant_name(ref items, value.name, variant_name) {
                    return lookup_variant_payload_ctx(ref variant_payloads, value.name, variant_name, index);
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return empty_expected_type_ctx();
}

fn module_source_text(sources: ref list<source_file>, module: str) -> str {
    let mut cursor = 0;
    while cursor < list_len(ref sources) {
        let entry = list_get(ref sources, cursor);
        match entry {
            Some(value) => {
                if value.name == module {
                    return value.text;
                }
            },
            None => {
            },
        }
        cursor = cursor + 1;
    }
    return "";
}

fn unsupported_type_name() -> str {
    return "__stage1_unsupported__";
}

fn unsupported_type_ctx() -> expected_type_ctx {
    return make_expected_type_ctx(unsupported_type_name(), "", "");
}

fn is_unsupported_type_name(type_name: str) -> bool {
    return type_name == unsupported_type_name();
}

pub fn is_unsupported_type_ctx(type_ctx: expected_type_ctx) -> bool
audit {
    intent("Check whether a type context marks a retained stage1 limitation");
    mutates();
    effects();
}
{
    return is_unsupported_type_name(type_ctx.head);
}

fn has_known_type_name(type_name: str) -> bool {
    if type_name == "" {
        return false;
    }
    return not is_unsupported_type_name(type_name);
}

pub fn has_known_type_ctx(type_ctx: expected_type_ctx) -> bool
audit {
    intent("Check whether a type context carries a known non-limitation type");
    mutates();
    effects();
}
{
    return has_known_type_name(type_ctx.head);
}

fn is_int_like(type_name: str) -> bool {
    if type_name == "int" {
        return true;
    }
    return type_name == "i32";
}

fn expr_content_start(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut cursor = start;
    while cursor < end {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eq => {
                cursor = cursor + 1;
            },
            _ => {
                return cursor;
            },
        }
    }
    return cursor;
}

fn skip_until_match_block(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    let mut bracket_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                cursor = cursor + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
                cursor = cursor + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbrace => {
                if paren_depth == 0 and bracket_depth == 0 {
                    return;
                }
                cursor = cursor + 1;
            },
            _ => {
                cursor = cursor + 1;
            },
        }
    }
}

fn skip_pattern_until_arrow(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                cursor = cursor + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_fat_arrow => {
                if paren_depth == 0 {
                    return;
                }
                cursor = cursor + 1;
            },
            _ => {
                cursor = cursor + 1;
            },
        }
    }
}

fn skip_match_arm_value_expr(tokens: ref list<token>, cursor: mutref i32) -> unit {
    let mut paren_depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    while true {
        let current = token_at(ref tokens, cursor);
        match current.kind {
            tk_eof => {
                return;
            },
            tk_lparen => {
                paren_depth = paren_depth + 1;
                cursor = cursor + 1;
            },
            tk_rparen => {
                if paren_depth > 0 {
                    paren_depth = paren_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
                cursor = cursor + 1;
            },
            tk_rbrace => {
                if paren_depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return;
                }
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
                cursor = cursor + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
                cursor = cursor + 1;
            },
            tk_comma => {
                if paren_depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return;
                }
                cursor = cursor + 1;
            },
            _ => {
                cursor = cursor + 1;
            },
        }
    }
}

fn token_can_end_expr(tok: token) -> bool {
    match tok.kind {
        tk_ident => {
            return true;
        },
        tk_int_lit => {
            return true;
        },
        tk_string_lit => {
            return true;
        },
        tk_kw_true => {
            return true;
        },
        tk_kw_false => {
            return true;
        },
        tk_rparen => {
            return true;
        },
        tk_rbrace => {
            return true;
        },
        tk_rbracket => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn span_is_wrapped_in_parens(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 2 {
        return false;
    }
    let first = token_at(ref tokens, start);
    let last = token_at(ref tokens, end - 1);
    match first.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    match last.kind {
        tk_rparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 and index + 1 < end {
                    return false;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return depth == 0;
}

fn find_root_or_operator(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let mut depth = 0;
    let mut brace_depth = 0;
    let mut bracket_depth = 0;
    let mut index = start;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                if depth > 0 {
                    depth = depth - 1;
                }
            },
            tk_lbrace => {
                brace_depth = brace_depth + 1;
            },
            tk_rbrace => {
                if brace_depth > 0 {
                    brace_depth = brace_depth - 1;
                }
            },
            tk_lbracket => {
                bracket_depth = bracket_depth + 1;
            },
            tk_rbracket => {
                if bracket_depth > 0 {
                    bracket_depth = bracket_depth - 1;
                }
            },
            tk_kw_or => {
                if depth == 0 and brace_depth == 0 and bracket_depth == 0 {
                    return index;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return -1;
}

