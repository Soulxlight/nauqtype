fn qualified_function_return_ctx(functions: ref list<function_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, qualifier: str, function_name: str) -> expected_type_ctx {
    if module_directly_imports(ref uses, module, qualifier) and module_exports_function_name(ref items, qualifier, function_name) {
        return make_expected_type_ctx(
            lookup_function_fact_return_name(ref functions, qualifier, function_name),
            lookup_function_fact_return_arg1_name(ref functions, qualifier, function_name),
            lookup_function_fact_return_arg2_name(ref functions, qualifier, function_name)
        );
    }
    return empty_expected_type_ctx();
}

