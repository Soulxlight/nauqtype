fn type_names_match(expected: str, actual: str) -> bool {
    if expected == actual {
        return true;
    }
    if expected == "int" and actual == "i32" {
        return true;
    }
    if expected == "i32" and actual == "int" {
        return true;
    }
    return false;
}

fn type_ctx_arg_matches(expected: str, actual: str) -> bool {
    if expected == "" or actual == "" {
        return true;
    }
    return type_names_match(expected, actual);
}

fn type_ctx_matches(expected: expected_type_ctx, actual: expected_type_ctx) -> bool {
    if expected.head == "" or actual.head == "" {
        return false;
    }
    if not type_names_match(expected.head, actual.head) {
        return false;
    }
    if expected.head == "option" or expected.head == "list" {
        return type_ctx_arg_matches(expected.arg1_name, actual.arg1_name);
    }
    if expected.head == "result" {
        if not type_ctx_arg_matches(expected.arg1_name, actual.arg1_name) {
            return false;
        }
        if not type_ctx_arg_matches(expected.arg2_name, actual.arg2_name) {
            return false;
        }
    }
    return true;
}

