fn span_call_open_index(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let head = token_at(ref tokens, start);
    match head.kind {
        tk_ident => {
        },
        _ => {
            return -1;
        },
    }
    if end - start >= 3 {
        let open = token_at(ref tokens, start + 1);
        match open.kind {
            tk_lparen => {
                return start + 1;
            },
            _ => {
            },
        }
    }
    if end - start >= 5 {
        let first_colon = token_at(ref tokens, start + 1);
        let second_colon = token_at(ref tokens, start + 2);
        let name = token_at(ref tokens, start + 3);
        let open = token_at(ref tokens, start + 4);
        match first_colon.kind {
            tk_colon => {
                match second_colon.kind {
                    tk_colon => {
                        match name.kind {
                            tk_ident => {
                                match open.kind {
                                    tk_lparen => {
                                        return start + 4;
                                    },
                                    _ => {
                                    },
                                }
                            },
                            _ => {
                            },
                        }
                    },
                    _ => {
                    },
                }
            },
            _ => {
            },
        }
    }
    return -1;
}

fn span_call_name_index(tokens: ref list<token>, start: i32, end: i32) -> i32 {
    let open_index = span_call_open_index(ref tokens, start, end);
    if open_index == start + 4 {
        return start + 3;
    }
    if open_index == start + 1 {
        return start;
    }
    return -1;
}

fn span_call_qualifier(tokens: ref list<token>, start: i32, end: i32) -> str {
    let open_index = span_call_open_index(ref tokens, start, end);
    if open_index == start + 4 {
        let module_token = token_at(ref tokens, start);
        return module_token.text;
    }
    return "";
}

fn span_is_call_expr(tokens: ref list<token>, start: i32, end: i32) -> bool {
    if end - start < 3 {
        return false;
    }
    let open_index = span_call_open_index(ref tokens, start, end);
    if open_index < 0 {
        return false;
    }
    let open = token_at(ref tokens, open_index);
    match open.kind {
        tk_lparen => {
        },
        _ => {
            return false;
        },
    }
    let mut depth = 0;
    let mut index = open_index;
    while index < end {
        let current = token_at(ref tokens, index);
        match current.kind {
            tk_lparen => {
                depth = depth + 1;
            },
            tk_rparen => {
                depth = depth - 1;
                if depth == 0 {
                    return index + 1 == end;
                }
            },
            _ => {
            },
        }
        index = index + 1;
    }
    return false;
}

