use ast;
use diag;
use lexer;
use source;
use token;

pub type expected_type_ctx {
    head: str,
    arg1_name: str,
    arg2_name: str,
}

pub fn make_expected_type_ctx(head: str, arg1_name: str, arg2_name: str) -> expected_type_ctx
audit {
    intent("Construct an expected type context for selfhost semantic checks");
    mutates();
    effects();
}
{
    return expected_type_ctx {
        head: head,
        arg1_name: arg1_name,
        arg2_name: arg2_name,
    };
}

pub fn empty_expected_type_ctx() -> expected_type_ctx
audit {
    intent("Construct an empty expected type context for selfhost semantic checks");
    mutates();
    effects();
}
{
    return make_expected_type_ctx("", "", "");
}

fn push_diag(diags: mutref list<diag>, file: str, at: i32, message: str) -> unit {
    list_push(mutref diags, make_diag(file, at, message));
    return;
}

fn token_at(tokens: ref list<token>, index: i32) -> token {
    let found = list_get(ref tokens, index);
    match found {
        Some(value) => {
            return value;
        },
        None => {
            return eof_token(index);
        },
    }
}

fn is_function_item(item: top_item) -> bool {
    match item.kind {
        item_fn => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_variant_item(item: top_item) -> bool {
    match item.kind {
        item_variant => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_const_item(item: top_item) -> bool {
    match item.kind {
        item_const => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn is_type_item(item: top_item) -> bool {
    match item.kind {
        item_type => {
            return true;
        },
        item_enum => {
            return true;
        },
        _ => {
            return false;
        },
    }
}

fn module_has_local_function_name(items: ref list<top_item>, module: str, name: str) -> bool {
    let mut index = 0;
    while index < list_len(ref items) {
        let entry = list_get(ref items, index);
        match entry {
            Some(value) => {
                if value.module == module and value.name == name and is_function_item(value) {
                    return true;
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return false;
}

