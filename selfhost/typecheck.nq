    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
            Some(value) => {
                if value.module == module and module_exports_function_name(ref items, value.name, name) {
                    return value.name;
                }
            },
            None => {
            },
        }
        use_index = use_index + 1;
    }
    return "";
}

pub fn visible_variant_origin_module(variants: ref list<variant_fact>, uses: ref list<module_use>, items: ref list<top_item>, module: str, name: str) -> str
audit {
    intent("Resolve the origin module for a visible constructor target");
    mutates();
    effects();
}
{
    if builtin_variant_enum_name(name) != "" {
        return "__builtin__";
    }
    if module_has_local_variant_name(ref items, module, name) {
        return module;
    }
    let mut use_index = 0;
    while use_index < list_len(ref uses) {
        let entry = list_get(ref uses, use_index);
        match entry {
