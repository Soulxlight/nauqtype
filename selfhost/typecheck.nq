fn clone_typed_bindings_for_function(source: ref list<typed_binding_fact>, module: str, function_name: str) -> list<typed_binding_fact> {
    let mut copied: list<typed_binding_fact> = list();
    let mut index = 0;
    while index < list_len(ref source) {
        let entry = list_get(ref source, index);
        match entry {
            Some(value) => {
                if value.module == module and value.function_name == function_name {
                    list_push(mutref copied, value);
                }
            },
            None => {
            },
        }
        index = index + 1;
    }
    return copied;
}

