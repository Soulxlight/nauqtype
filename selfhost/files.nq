use source;

pub fn read_named_module(name: str) -> result<source_file, io_err>
audit {
    intent("Read one known selfhost module by name");
    mutates();
    effects();
}
{
    if name == "main" {
        let data = read_file("main.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "files" {
        let data = read_file("files.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "source" {
        let data = read_file("source.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "diag" {
        let data = read_file("diag.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "token" {
        let data = read_file("token.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "lexer" {
        let data = read_file("lexer.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "ast" {
        let data = read_file("ast.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "parser" {
        let data = read_file("parser.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    if name == "resolve" {
        let data = read_file("resolve.nq");
        match data {
            Ok(text) => {
                return Ok(make_source_file(name, text));
            },
            Err(err) => {
                return Err(err);
            },
        }
    }
    let data = read_file("missing-module.nq");
    match data {
        Ok(text) => {
            return Ok(make_source_file(name, text));
        },
        Err(err) => {
            return Err(err);
        },
    }
}
