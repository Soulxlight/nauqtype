{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nauqtype.dev/schemas/policy-check-v1.schema.json",
  "title": "Nauqtype Policy Check v1",
  "type": "object",
  "required": ["version", "command", "ok", "source", "policy_path", "summary", "targets", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "command": { "const": "policy-check" },
    "ok": { "type": "boolean" },
    "source": { "type": "string" },
    "policy_path": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["targets", "errors"],
      "additionalProperties": false,
      "properties": {
        "targets": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "owner", "review", "known", "owner_valid", "review_valid", "duplicate"],
        "additionalProperties": false,
        "properties": {
          "target_id": { "type": "string" },
          "owner": { "type": "string" },
          "review": { "type": "string" },
          "known": { "type": "boolean" },
          "owner_valid": { "type": "boolean" },
          "review_valid": { "type": "boolean" },
          "duplicate": { "type": "boolean" }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
