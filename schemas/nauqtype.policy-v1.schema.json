{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nauqtype.dev/schemas/nauqtype.policy-v1.schema.json",
  "title": "Nauqtype Sidecar Policy v1",
  "type": "object",
  "required": ["version", "targets"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "owner", "review"],
        "additionalProperties": false,
        "properties": {
          "target_id": { "type": "string" },
          "owner": { "type": "string", "pattern": "^(human|agent):" },
          "review": { "enum": ["required", "supervised", "optional"] }
        }
      }
    }
  }
}
